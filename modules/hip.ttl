hip-schema:definitionSource rdf:type owl:AnnotationProperty .


#################################################################
#    Classes
#################################################################

###  http://www.w3.org/ns/org#Organization
org:Organization rdfs:subClassOf dcterms:Agent .


###  https://undrr-hip.org/HIP-ClassificationSystem
hip-schema:HIP-ClassificationSystem rdf:type owl:Class ;
                                    rdfs:subClassOf skos:ConceptScheme ;
                                    rdfs:isDefinedBy <https://www.undrr.org/publication/documents-and-publications/hazard-information-profiles-hips-2025-version> ;
                                    rdfs:label "UNDRR Hazard Information Profiles"@en .


###  https://undrr-hip.org/HazardCluster
hip-schema:HazardCluster rdf:type owl:Class ;
                         rdfs:subClassOf skos:Concept ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty skos:broader ;
                                           owl:allValuesFrom hip-schema:HazardType
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty skos:inScheme ;
                                           owl:allValuesFrom hip-schema:HIP-ClassificationSystem
                                         ] ;
                         rdfs:label "Hazard Cluster"@en .


###  https://undrr-hip.org/HazardType
hip-schema:HazardType rdf:type owl:Class ;
                      rdfs:subClassOf skos:Concept ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty skos:inScheme ;
                                        owl:allValuesFrom hip-schema:HIP-ClassificationSystem
                                      ] ;
                      rdfs:label "Hazard Type"@en .


###  https://undrr-hip.org/Organization
hip-schema:Organization rdf:type owl:Class ;
                        rdfs:subClassOf org:Organization .


###  https://undrr-hip.org/SpecificHazard
hip-schema:SpecificHazard rdf:type owl:Class ;
                          rdfs:subClassOf skos:Concept ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty skos:broader ;
                                            owl:allValuesFrom hip-schema:HazardCluster
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty skos:inScheme ;
                                            owl:allValuesFrom hip-schema:HIP-ClassificationSystem
                                          ] ;
                          rdfs:label "Specific Hazard"@en .


