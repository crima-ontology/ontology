ecv:Lightning a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "lightning"@en ;
    skos:broader ecv:UpperAtmosphere ;
    skos:definition "Total number of detected strokes in the corresponding time interval and the space unit. The space unit (grid box) should be on the order of the horizontal resolution and the accumulation time to the observing cycle."@en .

ecv:NitrousOxide a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "nitrous oxide"@en ;
    skos:broader ecv:Biogeochemical ;
    skos:definition "Concentration of N₂O gas in the water column."@en .

ecv:OceanColour a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "ocean colour"@en ;
    skos:broader ecv:Biogeochemical ;
    skos:definition "Concentration of chlorophyll-a pigment in the surface water."@en .

ecv:RiverDischarge a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "river discharge"@en ;
    skos:broader ecv:Hydrology .

ecv:SeaLevel a ecv:ECV-variable,
