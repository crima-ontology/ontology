ecv:Ocean a ecv:ECV-domain,
        owl:NamedIndividual ;
    rdfs:label "ocean"@en .

ecv:OceanSurfaceHeatFlux a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "ocean surface heat flux"@en ;
    skos:broader ecv:Physical .

ecv:Permafrost a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "permafrost"@en ;
    skos:broader ecv:Cryosphere ;
    skos:definition "Permafrost is subsurface earth material that remains continuously at or below 0 °C throughout at least two consecutive years, usually for extended time periods."@en .

ecv:Snow a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "snow"@en ;
    skos:broader ecv:Cryosphere .

ecv:SoilCarbon a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "soil carbon"@en ;
    skos:broader ecv:Biology .

ecv:SurfaceRadiationBudget a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "surface radiation budget"@en ;
    skos:broader ecv:Surface .

ecv:SurfaceWaterVapour a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "surface water vapour"@en ;
    skos:broader ecv:Surface .

ecv:SurfaceWindSpeedAndDirection a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "surface wind speed and direction"@en ;
    skos:broader ecv:Surface ;
    skos:definition """Wind Speed (near surface): Speed of air at a known height above the surface which is to be specified in the metadata.
Wind Direction (near surface): Direction from which wind is blowing at a known height above the surface which is to be specified in the metadata."""@en .

ecv:Cryosphere a ecv:ECV-subdomain,
        owl:NamedIndividual ;
    rdfs:label "cryosphere"@en ;
    skos:broader ecv:Land .

ecv:IceSheetsAndIceShelves a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "ice sheets and ice shelves"@en ;
    skos:broader ecv:Cryosphere .

ecv:Land a ecv:ECV-domain,
        owl:NamedIndividual ;
    rdfs:label "land"@en .

ecv:MarineHabitats a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "marine habitats"@en ;
    skos:broader ecv:Biological-Ecosystems ;
    skos:definition "Extent of mangroves and species types in coastal environments (percent or ha and number of species per area)."@en .

ecv:Plankton a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "plankton"@en ;
    skos:broader ecv:Biological-Ecosystems ;
    skos:definition "Number of species, functional traits, molecular biology groups (Operational Taxonomic Unit/OUT, other) per unit seawater volume or unit sea surface area, or unit benthos area."@en .

ecv:SoilMoisture a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "soil moisture"@en ;
    skos:broader ecv:Hydrology .

ecv:TransientTracers a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "transient tracers"@en ;
    skos:broader ecv:Biogeochemical .

ecv:UpperAtmosphere a ecv:ECV-subdomain,
        owl:NamedIndividual ;
    rdfs:label "upper atmosphere"@en ;
    skos:broader ecv:Atmosphere .

ecv:AtmosphericComposition a ecv:ECV-subdomain,
        owl:NamedIndividual ;
    rdfs:label "atmospheric composition"@en ;
    skos:broader ecv:Atmosphere .

ecv:CarbonDioxideMethaneAndOtherGreenhouseGases a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "carbon dioxide methane and other greenhouse gases"@en ;
    skos:broader ecv:AtmosphericComposition .

ecv:EarthRadiationBudget a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "Earth radiation budget"@en ;
    skos:broader ecv:UpperAtmosphere .

ecv:EvaporationFromLand a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "evaporation from land"@en ;
    skos:broader ecv:Hydrology .

ecv:Upper-airTemperature a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "upper-air temperature"@en ;
    skos:broader ecv:Surface .

ecv:Biogeochemical a ecv:ECV-subdomain,
        owl:NamedIndividual ;
    rdfs:label "biogeochemical"@en ;
    skos:broader ecv:Ocean .

ecv:Hydrology a ecv:ECV-subdomain,
        owl:NamedIndividual ;
    rdfs:label "hydrology"@en ;
    skos:broader ecv:Land .

ecv:Lakes a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "lakes"@en ;
    skos:broader ecv:Hydrology .

ecv:Ozone a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "ozone"@en ;
    skos:broader ecv:AtmosphericComposition ;
    skos:definition "2D field of total amount of O3 molecules per unit area in an atmospheric column extending from the Earth's surface to the tropopause."@en .

ecv:Aerosols a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "aerosols"@en ;
    skos:broader ecv:AtmosphericComposition ;
    skos:definition "Above-ground biomass is defined as the mass of live and/or dead organic matter in terrestrial vegetation."@en .

ecv:Clouds a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "clouds"@en ;
    skos:broader ecv:AtmosphericComposition .

ecv:PrecursorsForAerosolsAndOzone a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "precursors for aerosols and ozone"@en ;
    skos:broader ecv:AtmosphericComposition .

ecv:SeaIce a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "sea ice"@en ;
    skos:broader ecv:Physical .

ecv:Surface a ecv:ECV-subdomain,
        owl:NamedIndividual ;
    rdfs:label "surface"@en ;
    skos:broader ecv:Atmosphere .

ecv:AnthropogenicGreenhouseGasEmissions a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "anthropogenic greenhouse gas emissions"@en ;
    skos:broader ecv:HumanUseOfNaturalResources ;
    skos:definition "Anthropogenic long-cycle C emissions are mainly originating from combustion of fossil fuels, and for about 10% also from non-combustion sources, such as cement production, ferrous and non-ferrous metal production processes, urea production, agricultural liming and solvent use."@en .

ecv:Biology a ecv:ECV-subdomain,
        owl:NamedIndividual ;
    rdfs:label "biology"@en ;
    skos:broader ecv:Land .

ecv:Upper-airWaterVapour a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "upper-air water vapour"@en ;
    skos:broader ecv:UpperAtmosphere .

ecv:Upper-airWindSpeedAndDirection a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "upper-air wind speed and direction"@en ;
    skos:broader ecv:UpperAtmosphere .

ecv:Physical a ecv:ECV-subdomain,
        owl:NamedIndividual ;
    rdfs:label "physical"@en ;
    skos:broader ecv:Ocean .

