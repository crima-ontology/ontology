ecv:Fire a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "fire"@en ;
    skos:broader ecv:Biology .

ecv:Glaciers a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "glaciers"@en ;
    skos:broader ecv:Cryosphere .

ecv:InorganicCarbon a ecv:ECV-variable,
        owl:NamedIndividual ;
    rdfs:label "inorganic carbon"@en ;
