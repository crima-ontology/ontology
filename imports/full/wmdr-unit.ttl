    dct:description "SI derived unit of mass fraction, equivalent to ppmm (parts per million by mass) or ppm (parts per million); SI base unit equivalent: 1E-6"@en ;
    skos:notation "mg.kg-1" ;
.

<http://codes.wmo.int/wmdr/unit/mg.l-1>
    a skos:Concept ;
    rdfs:label "milligram per litre" ;
    dct:description "SI derived unit of density or mass concentration; SI base unit equivalent: 0.001 kg.m-3"@en ;
    skos:notation "mg.l-1" ;
.

<http://codes.wmo.int/wmdr/unit/mg.m-3>
    a skos:Concept ;
    rdfs:label "milligram per cubic metre" ;
    dct:description "SI derived unit of density or mass concentration; SI base unit equivalent: 1E-6 kg/m3"@en ;
    skos:notation "mg.m-3" ;
.

<http://codes.wmo.int/wmdr/unit/min>
    a skos:Concept ;
    rdfs:label "minute (time)" ;
    dct:description "Unit of time, accepted for use with SI: 1 min = 60 s"@en ;
    skos:notation "min" ;
.

<http://codes.wmo.int/wmdr/unit/missing>
    a skos:Concept ;
    rdfs:label "missing" ;
    dct:description "The correct value is not readily available to the sender of this data. Furthermore, a correct value may not exist"@en ;
    skos:notation "missing" ;
.

<http://codes.wmo.int/wmdr/unit/mm>
    a skos:Concept ;
    rdfs:label "millimetre" ;
    dct:description "SI prefixed unit of length; SI base unit equivalent: 0.001 m"@en ;
    skos:notation "mm" ;
.

<http://codes.wmo.int/wmdr/unit/mm.h-1>
    a skos:Concept ;
    rdfs:label "millimetre per hour" ;
    dct:description "SI derived unit of speed; SI base unit equivalent: 1/3.6E6 m.s-1"@en ;
    skos:notation "mm.h-1" ;
.

<http://codes.wmo.int/wmdr/unit/mm.s-1>
    a skos:Concept ;
    rdfs:label "millimetre per second" ;
    dct:description "SI derived unit of speed; SI base unit equivalent: 0.001 m.s-1"@en ;
    skos:notation "mm.s-1" ;
.

<http://codes.wmo.int/wmdr/unit/mm3.m-3>
    a skos:Concept ;
    rdfs:label "cubic millimetre per cubic metre" ;
    dct:description "SI derived unit of volumetric mixing ratio, equivalent to ppbv (parts per billion by volume); SI base unit equivalent: 1E-9"@en ;
    skos:notation "mm3.m-3" ;
.

<http://codes.wmo.int/wmdr/unit/mm6.m-3>
    a skos:Concept ;
    rdfs:label "millimetre to the sixth power per cubic metre" ;
    dct:description "SI derived unit of quantity with dimension of L3; SI base unit equivalent: 1E-18 m3"@en ;
    skos:notation "mm6.m-3" ;
.

<http://codes.wmo.int/wmdr/unit/mmHg>
    a skos:Concept ;
    rdfs:label "millimetre of mercury" ;
    dct:description "Conventional unit of pressure, equal to 133.322387415 Pa"@en ;
    skos:notation "mmHg" ;
.

<http://codes.wmo.int/wmdr/unit/mmol.mol-1>
    a skos:Concept ;
    rdfs:label "millimole per mole" ;
    dct:description "SI derived unit equivalent to expressing mole fraction in parts per thousand; SI base unit equivalent: 0.001"@en ;
    skos:notation "mmol.mol-1" ;
.

<http://codes.wmo.int/wmdr/unit/mol>
    a skos:Concept ;
    rdfs:label "mole" ;
    dct:description "SI base unit of amount of substance"@en ;
    skos:notation "mol" ;
.

<http://codes.wmo.int/wmdr/unit/mol.mol-1>
    a skos:Concept ;
    rdfs:label "mole per mole" ;
    dct:description "SI derived unit of mole fraction; SI base unit equivalent: 1"@en ;
    skos:notation "mol.mol-1" ;
.

<http://codes.wmo.int/wmdr/unit/mon>
    a skos:Concept ;
    rdfs:label "month" ;
    dct:description "Conventional unit of time duration of between 28-31 days whereby 12 months amount to one year"@en ;
    skos:notation "mon" ;
.

<http://codes.wmo.int/wmdr/unit/nT2.Hz-1>
    a skos:Concept ;
    rdfs:label "nanoTesla squared per Hertz" ;
    dct:description "SI derived unit for magnetic power spectrum commonly used to describe Schumann Resonances. SI base unit equivalent: 1E-9 A.m-1.s"@en ;
    skos:notation "nT2.Hz-1" ;
.

<http://codes.wmo.int/wmdr/unit/nbar>
    a skos:Concept ;
    rdfs:label "nanobar" ;
    dct:description "Conventional unit of pressure; SI base unit equivalent: 1E-4 kg.m-1.s-2"@en ;
    skos:notation "nbar" ;
.

<http://codes.wmo.int/wmdr/unit/ng.kg-1>
    a skos:Concept ;
    rdfs:label "nanogram per kilogram" ;
    dct:description "SI derived unit of mass fraction, equivalent to pptm (parts per trillion by mass) or ppt (parts per trillion); SI base unit equivalent: 1E-12"@en ;
    skos:notation "ng.kg-1" ;
.

<http://codes.wmo.int/wmdr/unit/ng.m-3>
    a skos:Concept ;
    rdfs:label "nanogram per cubic metre" ;
    dct:description "SI derived unit of mass concentration; SI base unit equivalent: 1E-12 kg.m-3"@en ;
    skos:notation "ng.m-3" ;
.

<http://codes.wmo.int/wmdr/unit/nm>
    a skos:Concept ;
    rdfs:label "nanometre" ;
    dct:description "SI prefixed unit of length; SI base unit equivalent: 1E-9 m"@en ;
    skos:notation "nm" ;
.

<http://codes.wmo.int/wmdr/unit/nmi>
    a skos:Concept ;
    rdfs:label "nautical mile" ;
    dct:description "Conventional unit of length; SI base unit equivalent: 1852 m"@en ;
    skos:notation "nmi" ;
.

<http://codes.wmo.int/wmdr/unit/nmol.kg-1>
    a skos:Concept ;
    rdfs:label "nanomole per kilogram" ;
    dct:description "SI derived unit of amount per unit mass; SI base unit equivalent: 1E-9 mol.kg-1"@en ;
    skos:notation "nmol.kg-1" ;
.

<http://codes.wmo.int/wmdr/unit/nmol.mol-1>
    a skos:Concept ;
    rdfs:label "nanomole per mole" ;
    dct:description "SI derived unit of mole fraction; SI base unit equivalent: 1E-9"@en ;
    skos:notation "nmol.mol-1" ;
.

<http://codes.wmo.int/wmdr/unit/okta>
    a skos:Concept ;
    rdfs:label "eights of sky covered by cloud" ;
    dct:description "Unit of cloud amount, expressed as number of eighths of the sky dome that is covered by clouds; SI base unit equivalent: 0.125"@en ;
    skos:notation "okta" ;
.

<http://codes.wmo.int/wmdr/unit/pH_unit>
    a skos:Concept ;
    rdfs:label "pH unit" ;
    dct:description "Negative decimal logarithm of the hydrogen ion activity ('effective' concentration) specified in moles per litre; SI base unit equivalent: 0.001 m-3"@en ;
    skos:notation "pH_unit" ;
.

<http://codes.wmo.int/wmdr/unit/pT2.Hz-1>
    a skos:Concept ;
    rdfs:label "picoTesla squared per Hertz" ;
    dct:description "SI derived unit for magnetic power spectrum commonly used to describe Schumann Resonances. SI base unit equivalent: 1E-12 A.m-1.s"@en ;
    skos:notation "pT2.Hz-1" ;
.

<http://codes.wmo.int/wmdr/unit/pc>
    a skos:Concept ;
    rdfs:label "parsec" ;
    dct:description "Astronomical unit of length, 1 pc = 64800/Π AU"@en ;
    skos:notation "pc" ;
.

<http://codes.wmo.int/wmdr/unit/percent>
    a skos:Concept ;
    rdfs:label "per cent" ;
    dct:description "Dimensionless number, expressed as a fraction of 100; SI base unit equivalent: 0.01"@en ;
    skos:notation "percent" ;
.

<http://codes.wmo.int/wmdr/unit/permeg>
    a skos:Concept ;
    rdfs:label "per meg" ;
    dct:description "Dimensionless number, expressed as a fraction of 1000000; SI base unit equivalent: 0.000001; also referred as parts per million (ppm)"@en ;
    skos:notation "permeg" ;
.

<http://codes.wmo.int/wmdr/unit/permil>
    a skos:Concept ;
    rdfs:label "per mille" ;
    dct:description "Dimensionless number, expressed as a fraction of 1000; SI base unit equivalent: 0.001"@en ;
    skos:notation "permil" ;
.

<http://codes.wmo.int/wmdr/unit/pmol.kg-1>
    a skos:Concept ;
    rdfs:label "picomole per kilogram" ;
    dct:description "SI derived unit of amount per unit mass; SI base unit equivalent: 1E-12 mol.kg-1"@en ;
    skos:notation "pmol.kg-1" ;
.

<http://codes.wmo.int/wmdr/unit/pmol.mol-1>
    a skos:Concept ;
    rdfs:label "picomole per mole" ;
    dct:description "SI derived unit equivalent of mole fraction; SI base unit equivalent: 1E-12"@en ;
    skos:notation "pmol.mol-1" ;
.

<http://codes.wmo.int/wmdr/unit/ppbv>
    a skos:Concept ;
    rdfs:label "parts per billion by volume" ;
    dct:description "Unit of volume fraction, equivalent to SI derived unit: 1E-9"@en ;
    skos:notation "ppbv" ;
.

<http://codes.wmo.int/wmdr/unit/ppmv>
    a skos:Concept ;
    rdfs:label "parts per million by volume" ;
    dct:description "Unit of volume fraction, equivalent to SI derived unit: 1E-6"@en ;
    skos:notation "ppmv" ;
.

<http://codes.wmo.int/wmdr/unit/pptv>
    a skos:Concept ;
    rdfs:label "parts per trillion by volume" ;
    dct:description "Unit of volume fraction, equivalent to SI derived unit: 1E-12"@en ;
    skos:notation "pptv" ;
.

<http://codes.wmo.int/wmdr/unit/psu>
    a skos:Concept ;
    rdfs:label "practical salinity unit" ;
    dct:description "Conventional unit, equivalent to per mille; SI based unit equivalent: 0.001"@en ;
    skos:notation "psu" ;
.

<http://codes.wmo.int/wmdr/unit/rad>
    a skos:Concept ;
    rdfs:label "radian" ;
    dct:description "SI derived unit of plane angle; SI base unit equivalent: 1"@en ;
    skos:notation "rad" ;
.

<http://codes.wmo.int/wmdr/unit/rad.m-1>
    a skos:Concept ;
    rdfs:label "radian per metre" ;
    dct:description "SI derived unit of spatial gradient of plane angle"@en ;
    skos:notation "rad.m-1" ;
.

<http://codes.wmo.int/wmdr/unit/rad.s-1>
    a skos:Concept ;
    rdfs:label "radian per second" ;
    dct:description "SI derived unit of angular velocity; SI base unit equivalent: s-1"@en ;
    skos:notation "rad.s-1" ;
.

<http://codes.wmo.int/wmdr/unit/s>
    a skos:Concept ;
    rdfs:label "second" ;
    dct:description "SI base unit of time"@en ;
    skos:notation "s" ;
.

<http://codes.wmo.int/wmdr/unit/s-2>
    a skos:Concept ;
    rdfs:label "per second squared" ;
    dct:description "SI derived unit of second order time derivative"@en ;
    skos:notation "s-2" ;
.

<http://codes.wmo.int/wmdr/unit/s.m-1>
    a skos:Concept ;
    rdfs:label "second per metre" ;
    dct:description "SI derived unit of quantity with dimension of T.L-1"@en ;
    skos:notation "s.m-1" ;
.

<http://codes.wmo.int/wmdr/unit/sr>
    a skos:Concept ;
    rdfs:label "steradian" ;
    dct:description "SI derived unit of solid angle; SI base unit equivalent: 1"@en ;
    skos:notation "sr" ;
.

<http://codes.wmo.int/wmdr/unit/t>
    a skos:Concept ;
    rdfs:label "tonne" ;
    dct:description "Unit of mass, accepted for use with SI; SI base unit equivalent: 1000 kg"@en ;
    skos:notation "t" ;
.

<http://codes.wmo.int/wmdr/unit/t.ha-1>
    a skos:Concept ;
    rdfs:label "(metric) ton per hectare" ;
    dct:description "Unit of area density, equal to 0.1 kg.m-2"@en ;
    skos:notation "t.ha-1" ;
.

<http://codes.wmo.int/wmdr/unit/u>
    a skos:Concept ;
    rdfs:label "unified atomic mass unit" ;
    dct:description "Conventional unit of mass; 1 u = 1 Da (Dalton) = 1.66053906660(50)E-27 kg"@en ;
    skos:notation "u" ;
.

<http://codes.wmo.int/wmdr/unit/uS.cm-1>
    a skos:Concept ;
    rdfs:label "microsiemens per centimetre" ;
    dct:description "SI derived unit of spatial gradient of electrical conductance; SI base unit equivalent: 1E-4 m-3.kg-1.s3.A2"@en ;
    skos:notation "uS.cm-1" ;
.

<http://codes.wmo.int/wmdr/unit/ug.kg-1>
    a skos:Concept ;
    rdfs:label "microgram per kilogram" ;
    dct:description "SI derived unit of mass fraction, equivalent to ppbm (parts per billion per mass) or ppb (parts per billion); SI base unit equivalent: 1E-9"@en ;
    skos:notation "ug.kg-1" ;
.

<http://codes.wmo.int/wmdr/unit/ug.l-1>
    a skos:Concept ;
    rdfs:label "microgram per litre" ;
    dct:description "SI derived unit of mass concentration; SI base unit equivalent: 1E-6 kg.m-3"@en ;
    skos:notation "ug.l-1" ;
.

<http://codes.wmo.int/wmdr/unit/ug.m-3>
    a skos:Concept ;
    rdfs:label "microgram per cubic metre" ;
    dct:description "SI derived unit of mass concentration; SI base unit equivalent: 1E-9 kg.m-3"@en ;
    skos:notation "ug.m-3" ;
.

<http://codes.wmo.int/wmdr/unit/um>
    a skos:Concept ;
    rdfs:label "micrometre" ;
    dct:description "SI prefixed unit of length; SI base unit equivalent: 1E-6 m"@en ;
    skos:notation "um" ;
.

<http://codes.wmo.int/wmdr/unit/um3.cm-3>
    a skos:Concept ;
    rdfs:label "cubic micrometre per cubic centimetre" ;
    dct:description "SI derived unit of volume fraction, equivalent to pptv (parts per trillion by volume); SI base unit equivalent: 1E-12"@en ;
    skos:notation "um3.cm-3" ;
.

<http://codes.wmo.int/wmdr/unit/umol.kg-1>
    a skos:Concept ;
    rdfs:label "micromole per kilogram" ;
    dct:description "SI derived unit of amount per unit mass; SI base unit equivalent: 1E-6 mol.kg-1"@en ;
    skos:notation "umol.kg-1" ;
.

<http://codes.wmo.int/wmdr/unit/umol.l-1>
    a skos:Concept ;
    rdfs:label "micromole per litre" ;
    dct:description "SI derived unit of amount concentration; SI base unit equivalent: 0.001 mol.m-3"@en ;
    skos:notation "umol.l-1" ;
.

<http://codes.wmo.int/wmdr/unit/umol.mol-1>
    a skos:Concept ;
    rdfs:label "micromole per mole" ;
    dct:description "SI derived unit of mole fraction; SI base unit equivalent: 1E-6"@en ;
    skos:notation "umol.mol-1" ;
.

<http://codes.wmo.int/wmdr/unit/unknown>
    a skos:Concept ;
    rdfs:label "unknown" ;
    dct:description "The correct value is not known to, and not computable by, the sender of this data. However, a correct value probably exists."@en ;
    skos:notation "unknown" ;
.

<http://codes.wmo.int/wmdr/unit/week>
    a skos:Concept ;
    rdfs:label "week" ;
    dct:description "Conventional unit of time, equivalent to 604800 s"@en ;
    skos:notation "week" ;
.

