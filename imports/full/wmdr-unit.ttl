<http://codes.wmo.int/wmdr/unit/'>
    a skos:Concept ;
    rdfs:label "minute (angle)" ;
    dct:description "Unit of plane or phase angle, accepted for use with SI: 1 ' = (pi/10800) rad"@en ;
    skos:notation "'" ;
.

<http://codes.wmo.int/wmdr/unit/''>
    a skos:Concept ;
    rdfs:label "second (angle)" ;
    dct:description "Unit of plane or phase angle, accepted for use with SI: 1 '' = (pi/648000) rad"@en ;
    skos:notation "''" ;
.

<http://codes.wmo.int/wmdr/unit/1>
    a skos:Concept ;
    rdfs:label "dimensionless" ;
    dct:description "Dimensionless; SI base unit equivalent: 1"@en ;
    skos:notation "1" ;
.

<http://codes.wmo.int/wmdr/unit/A>
    a skos:Concept ;
    rdfs:label "ampere" ;
    dct:description "SI base unit of electric current"@en ;
    skos:notation "A" ;
.

<http://codes.wmo.int/wmdr/unit/AU>
    a skos:Concept ;
    rdfs:label "astronomical unit" ;
    dct:description "Unit of length, accepted for use with SI: 1 AU = 149597870700 m, roughly the distance from Earth to the Sun"@en ;
    skos:notation "AU" ;
.

<http://codes.wmo.int/wmdr/unit/Bq>
    a skos:Concept ;
    rdfs:label "becquerel" ;
    dct:description "SI derived unit of radioactivity; SI base unit equivalent: s-1"@en ;
    skos:notation "Bq" ;
.

<http://codes.wmo.int/wmdr/unit/Bq.l-1>
    a skos:Concept ;
    rdfs:label "becquerel per litre" ;
    dct:description "Unit of radioactivity concentration; SI base unit equivalent: 0.001 s-1.m-3"@en ;
    skos:notation "Bq.l-1" ;
.

<http://codes.wmo.int/wmdr/unit/Bq.m-2>
    a skos:Concept ;
    rdfs:label "becquerel per square metre" ;
    dct:description "SI derived unit of radioactivity area concentration; SI base unit equivalent: s-1.m-2"@en ;
    skos:notation "Bq.m-2" ;
.

<http://codes.wmo.int/wmdr/unit/Bq.m-3>
    a skos:Concept ;
    rdfs:label "becquerel per cubic metre" ;
    dct:description "SI derived unit of radioactivity concentration; SI base unit equivalent: s-1.m-3"@en ;
    skos:notation "Bq.m-3" ;
.

<http://codes.wmo.int/wmdr/unit/Bq.s.m-3>
    a skos:Concept ;
    rdfs:label "becquerel second per cubic metre" ;
    dct:description "SI derived unit of time integrated radioactivity concentration; SI base unit equivalent: m-3"@en ;
    skos:notation "Bq.s.m-3" ;
.

<http://codes.wmo.int/wmdr/unit/C>
    a skos:Concept ;
    rdfs:label "coulomb" ;
    dct:description "SI derived unit of electric charge; SI base unit equivalent: s.A"@en ;
    skos:notation "C" ;
.

<http://codes.wmo.int/wmdr/unit/CFU.ml-1>
    a skos:Concept ;
    rdfs:label "colony-forming unit per millilitre" ;
    dct:description "Unit of number concentration of viable bacteria or fungal cells in a sample as a result of a plate count test"@en ;
    skos:notation "CFU.ml-1" ;
.

<http://codes.wmo.int/wmdr/unit/DU>
    a skos:Concept ;
    rdfs:label "Dobson Unit" ;
    dct:description "Unit of column abundance of molecules in the atmosphere. 1 DU is defined to be 0.01 mm thickness at STP (standard temperature and pressure, 0.00 degC and 1013.25 hPa) and is equivalent of 2.6867 x 1E20 molecules per square metre."@en ;
    skos:notation "DU" ;
.

<http://codes.wmo.int/wmdr/unit/E>
    a skos:Concept ;
    rdfs:label "Eötvös" ;
    dct:description "Unit of acceleration divided by distance,1 E = 1E-9 Gal/cm; SI base unit equivalent: 1E-9 s-2"@en ;
    skos:notation "E" ;
.

<http://codes.wmo.int/wmdr/unit/F>
    a skos:Concept ;
    rdfs:label "farad" ;
    dct:description "SI derived unit of electrical capacitance; SI base unit equivalent: kg-1.m-2.s4.A2"@en ;
    skos:notation "F" ;
.

<http://codes.wmo.int/wmdr/unit/GHz>
    a skos:Concept ;
    rdfs:label "gigahertz" ;
    dct:description "SI derived unit of frequency; SI base unit equivalent: 1E9 s-1"@en ;
    skos:notation "GHz" ;
.

<http://codes.wmo.int/wmdr/unit/Gy>
    a skos:Concept ;
    rdfs:label "gray" ;
    dct:description "SI derived unit of absorbed dose (of ionizing radiation); SI base unit equivalent: m2.s-2"@en ;
    skos:notation "Gy" ;
.

<http://codes.wmo.int/wmdr/unit/H>
    a skos:Concept ;
    rdfs:label "henry" ;
    dct:description "SI derived unit of electrical inductance; SI base unit equivalent: kg.m2.s-2.A-2"@en ;
    skos:notation "H" ;
.

<http://codes.wmo.int/wmdr/unit/HU>
    a skos:Concept ;
    rdfs:label "Hazen unit" ;
    dct:description "Unit of color according to the Platinum/Cobalt or Apha-Hazen scale"@en ;
    skos:notation "HU" ;
.

<http://codes.wmo.int/wmdr/unit/Hz>
    a skos:Concept ;
    rdfs:label "hertz" ;
    dct:description "SI derived unit of frequency; SI base unit equivalent: s-1"@en ;
    skos:notation "Hz" ;
.

<http://codes.wmo.int/wmdr/unit/J>
    a skos:Concept ;
    rdfs:label "joule" ;
    dct:description "SI derived unit of energy, work, heat; SI base unit equivalent: kg.m2.s-2"@en ;
    skos:notation "J" ;
.

<http://codes.wmo.int/wmdr/unit/J.kg-1>
    a skos:Concept ;
    rdfs:label "joule per kilogram" ;
    dct:description "SI derived unit of specific energy or specific potential enthalpy; SI base unit equivalent: m2.kg.s-2.kg-1"@en ;
    skos:notation "J.kg-1" ;
.

<http://codes.wmo.int/wmdr/unit/J.m-2>
    a skos:Concept ;
    rdfs:label "joule per square metre" ;
    dct:description "SI derived unit of radiant exposure; SI base unit equivalent: m2.kg.s-2"@en ;
    skos:notation "J.m-2" ;
.

<http://codes.wmo.int/wmdr/unit/K>
    a skos:Concept ;
    rdfs:label "kelvin" ;
    dct:description "SI base unit of thermodynamic temperature"@en ;
    skos:notation "K" ;
.

<http://codes.wmo.int/wmdr/unit/K.m-1>
    a skos:Concept ;
    rdfs:label "kelvin per metre" ;
    dct:description "SI derived unit of spatial gradient of temperature"@en ;
    skos:notation "K.m-1" ;
.

<http://codes.wmo.int/wmdr/unit/K.m.s-1>
    a skos:Concept ;
    rdfs:label "kelvin metre per second" ;
    dct:description "SI derived unit of covariance of wind speed and temperature or the product of wind speed and temperature"@en ;
    skos:notation "K.m.s-1" ;
.

<http://codes.wmo.int/wmdr/unit/K.m2.kg-1.s-1>
    a skos:Concept ;
    rdfs:label "kelvin square metre per kilogram per second" ;
    dct:description "SI derived unit of potential vorticity"@en ;
    skos:notation "K.m2.kg-1.s-1" ;
.

<http://codes.wmo.int/wmdr/unit/MHz>
    a skos:Concept ;
    rdfs:label "megahertz" ;
    dct:description "SI derived unit of frequency; SI base unit equivalent: 1E6 s-1"@en ;
    skos:notation "MHz" ;
.

<http://codes.wmo.int/wmdr/unit/MPN.ml-1>
    a skos:Concept ;
    rdfs:label "most probable number index number in 1 millilitre" ;
    dct:description "Unit of expected number concentration of bacteria in the original sample based upon the statistical probability of the coincidence of microorganisms in each sample replicate"@en ;
    skos:notation "MPN.ml-1" ;
.

<http://codes.wmo.int/wmdr/unit/Mm-1>
    a skos:Concept ;
    rdfs:label "per megametre" ;
    dct:description "Unit of quantity with dimension of reciprocal length, e.g., optical attenuation coefficients; SI base unit equivalent: 1E-6 m-1"@en ;
    skos:notation "Mm-1" ;
.

<http://codes.wmo.int/wmdr/unit/Mm-1.sr-1>
    a skos:Concept ;
    rdfs:label "per megametre per steradian" ;
    dct:description "SI derived unit of the scattering coefficient at a given direction; SI base unit equivalent: 1E-6 m-1"@en ;
    skos:notation "Mm-1.sr-1" ;
.

<http://codes.wmo.int/wmdr/unit/N>
    a skos:Concept ;
    rdfs:label "newton" ;
    dct:description "SI derived unit of force, weight"@en ;
    skos:notation "N" ;
.

<http://codes.wmo.int/wmdr/unit/N.m-2>
    a skos:Concept ;
    rdfs:label "newton per square metre" ;
    dct:description "SI derived unit of pressure or equivalent quantity"@en ;
    skos:notation "N.m-2" ;
.

<http://codes.wmo.int/wmdr/unit/NTU>
    a skos:Concept ;
    rdfs:label "nephelometric turbidity unit" ;
    dct:description "Units of turbidity from a calibrated nephelometer; SI base unit equivalent: 10-3 kg.m-3"@en ;
    skos:notation "NTU" ;
.

<http://codes.wmo.int/wmdr/unit/N_units>
    a skos:Concept ;
    rdfs:label "N units" ;
    dct:description "Unit of atmospheric refractivity, the refractivity, N, is related to the refractive index, n, by the formula N=1E6(n-1). N is therefore dimensionless but values computed by the formula are by convention described as being in 'N units'"@en ;
    skos:notation "N_units" ;
.

<http://codes.wmo.int/wmdr/unit/Ohm>
    a skos:Concept ;
    rdfs:label "ohm" ;
    dct:description "SI derived unit of electrical resistance, impedance, reactance"@en ;
    skos:notation "Ohm" ;
.

<http://codes.wmo.int/wmdr/unit/Pa>
    a skos:Concept ;
    rdfs:label "pascal" ;
    dct:description "SI derived unit of pressure/stress; SI base unit equivalent: kg.m-1.s-2"@en ;
    skos:notation "Pa" ;
.

<http://codes.wmo.int/wmdr/unit/Pa.s-1>
    a skos:Concept ;
    rdfs:label "pascal per second" ;
    dct:description "SI derived unit of temporal derivative of pressure/stress; SI base unit equivalent: kg.m-1.s-3"@en ;
    skos:notation "Pa.s-1" ;
.

<http://codes.wmo.int/wmdr/unit/S>
    a skos:Concept ;
    rdfs:label "siemens" ;
    dct:description "SI derived unit of electrical conductance; SI base unit equivalent: kg-1.m-2.s3.A2"@en ;
    skos:notation "S" ;
.

<http://codes.wmo.int/wmdr/unit/S.m-1>
    a skos:Concept ;
    rdfs:label "siemens per metre" ;
    dct:description "SI derived unit of spatial gradient of electric conductance"@en ;
    skos:notation "S.m-1" ;
.

<http://codes.wmo.int/wmdr/unit/Sv>
    a skos:Concept ;
    rdfs:label "sievert" ;
    dct:description "SI derived unit of equivalent dose (of ionizing radiation); SI base unit equivalent: m2.s-2"@en ;
    skos:notation "Sv" ;
.

<http://codes.wmo.int/wmdr/unit/T>
    a skos:Concept ;
    rdfs:label "tesla" ;
    dct:description "SI derived unit of magnetic induction, magnetic flux density; SI base unit equivalent: kg.s-2.A-1"@en ;
    skos:notation "T" ;
.

<http://codes.wmo.int/wmdr/unit/THz>
    a skos:Concept ;
    rdfs:label "terahertz" ;
    dct:description "SI derived unit of frequency; SI base unit equivalent: 1E12 s-1"@en ;
    skos:notation "THz" ;
.

<http://codes.wmo.int/wmdr/unit/V>
    a skos:Concept ;
    rdfs:label "volt" ;
    dct:description "SI derived unit of voltage, electrical potential difference, electromotive force; SI base unit equivalent: kg.m2.s-3.A-1"@en ;
    skos:notation "V" ;
.

<http://codes.wmo.int/wmdr/unit/V2.m-2.Hz-1>
    a skos:Concept ;
    rdfs:label "Volt squared per metre squared per Hertz" ;
    dct:description "'SI derived unit for electric field spectral density commonly used to describe Schumann Resonances. SI base unit equivalent: kg2.m2.s-5.A-2'"@en ;
    skos:notation "V2.m-2.Hz-1" ;
.

<http://codes.wmo.int/wmdr/unit/W>
    a skos:Concept ;
    rdfs:label "watt" ;
    dct:description "SI derived unit of power, radiant flux; SI base unit equivalent: kg.m2.s-3"@en ;
    skos:notation "W" ;
.

<http://codes.wmo.int/wmdr/unit/W.m-1.sr-1>
    a skos:Concept ;
    rdfs:label "watt per metre per steradian" ;
    dct:description "SI derived unit of spectral intensity, a directional quantity; SI base unit equivalent: kg.m.s-3"@en ;
    skos:notation "W.m-1.sr-1" ;
.

<http://codes.wmo.int/wmdr/unit/W.m-2>
    a skos:Concept ;
    rdfs:label "watt per square metre" ;
    dct:description "SI derived unit of heat flux density or irradiance; SI base unit equivalent: kg.s-3"@en ;
    skos:notation "W.m-2" ;
.

<http://codes.wmo.int/wmdr/unit/W.m-2.sr-1>
    a skos:Concept ;
    rdfs:label "watt per square metre per steradian" ;
    dct:description "SI derived unit of radiance; SI base unit equivalent: kg.s-3"@en ;
    skos:notation "W.m-2.sr-1" ;
.

<http://codes.wmo.int/wmdr/unit/W.m-2.sr-1.Hz-1>
    a skos:Concept ;
    rdfs:label "watt per square metre per steradian per hertz" ;
    dct:description "SI derived unit of spectral radiance per unit frequency; SI base unit equivalent: kg.s-2"@en ;
    skos:notation "W.m-2.sr-1.Hz-1" ;
.

<http://codes.wmo.int/wmdr/unit/W.m-2.sr-1.cm>
    a skos:Concept ;
    rdfs:label "watt per square metre per steradian per inverse centimetre" ;
    dct:description "SI derived unit of spectral radiance per unit wavenumber, wavenumber expressed in 100 m-1; equivalent to W.m-2.sr-1.(cm-1)-1; SI base unit equivalent: 0.01 kg.m.s-3"@en ;
    skos:notation "W.m-2.sr-1.cm" ;
.

<http://codes.wmo.int/wmdr/unit/W.m-2.sr-1.m>
    a skos:Concept ;
    rdfs:label "watt per square metre per steradian per inverse metre" ;
    dct:description "SI derived unit of spectral radiance per inverse metre; SI base unit equivalent: kg.m.s-3"@en ;
    skos:notation "W.m-2.sr-1.m" ;
.

<http://codes.wmo.int/wmdr/unit/W.m-3.sr-1>
    a skos:Concept ;
    rdfs:label "watt per square metre per steradian per metre" ;
    dct:description "SI derived unit of spectral radiance per unit wavelength; SI base unit equivalent: kg.m-1.s-3"@en ;
    skos:notation "W.m-3.sr-1" ;
.

<http://codes.wmo.int/wmdr/unit/Wb>
    a skos:Concept ;
    rdfs:label "Weber" ;
    dct:description "SI derived unit of magnetic flux; SI base unit equivalent: kg.m2.s-2.A-1"@en ;
    skos:notation "Wb" ;
.

<http://codes.wmo.int/wmdr/unit/a>
    a skos:Concept ;
    rdfs:label "year" ;
    dct:description "Conventional unit of time duration, ranging from 365 days to 366 days"@en ;
    skos:notation "a" ;
.

<http://codes.wmo.int/wmdr/unit/cb.(12h)-1>
    a skos:Concept ;
    rdfs:label "centibar per 12 hours" ;
    dct:description "Conventional unit of time derivative of pressure, pressure tendency; SI base unit: 10/432 kg.m-1.s-3"@en ;
    skos:notation "cb.(12h)-1" ;
.

<http://codes.wmo.int/wmdr/unit/cb.s-1>
    a skos:Concept ;
    rdfs:label "centibar per second" ;
    dct:description "Conventional unit of time derivative of pressure, pressure tendency; SI base unit: 1000 kg.m-1.s-3"@en ;
    skos:notation "cb.s-1" ;
.

<http://codes.wmo.int/wmdr/unit/cd>
    a skos:Concept ;
    rdfs:label "candela" ;
    dct:description "SI base unit of luminous intensity"@en ;
    skos:notation "cd" ;
.

<http://codes.wmo.int/wmdr/unit/cm>
    a skos:Concept ;
    rdfs:label "centimetre" ;
    dct:description "SI prefixed unit of length; SI base unit equivalent: 0.01 m"@en ;
    skos:notation "cm" ;
.

<http://codes.wmo.int/wmdr/unit/cm-3>
    a skos:Concept ;
    rdfs:label "per cubic centimetre" ;
    dct:description "SI derived unit of specific volume; SI base unit equivalent: 1E-6 m-3"@en ;
    skos:notation "cm-3" ;
.

<http://codes.wmo.int/wmdr/unit/cm.h-1>
    a skos:Concept ;
    rdfs:label "centimetre per hour" ;
    dct:description "SI derived unit of speed; SI base unit equivalent: 1/360000 m.s-1"@en ;
    skos:notation "cm.h-1" ;
.

<http://codes.wmo.int/wmdr/unit/cm.s-1>
    a skos:Concept ;
    rdfs:label "centimetre per second" ;
    dct:description "SI derived unit of speed; SI base unit equivalent: 0.01 m.s-1"@en ;
    skos:notation "cm.s-1" ;
.

<http://codes.wmo.int/wmdr/unit/cm2>
    a skos:Concept ;
    rdfs:label "square centimetre" ;
    dct:description "SI derived unit of area; SI base unit equivalent: 1E-4 m2"@en ;
    skos:notation "cm2" ;
.

<http://codes.wmo.int/wmdr/unit/cm3.m-3>
    a skos:Concept ;
    rdfs:label "cubic centimetre per cubic metre" ;
    dct:description "SI derived unit of volumetric mixing ratio, equivalent to ppmv (parts per million by volume); SI base unit equivalent: 1E-6"@en ;
    skos:notation "cm3.m-3" ;
.

<http://codes.wmo.int/wmdr/unit/d>
    a skos:Concept ;
    rdfs:label "day" ;
    dct:description "Unit of time, accepted for use with SI: 1 d = 86400 s"@en ;
    skos:notation "d" ;
.

<http://codes.wmo.int/wmdr/unit/dB>
    a skos:Concept ;
    rdfs:label "decibel" ;
    dct:description "Unit of sound intensity, accepted for use with SI"@en ;
    skos:notation "dB" ;
.

<http://codes.wmo.int/wmdr/unit/dB.deg-1>
    a skos:Concept ;
    rdfs:label "decibel per degree (angle)" ;
    dct:description "Unit of angular gradient of sound intensity"@en ;
    skos:notation "dB.deg-1" ;
.

<http://codes.wmo.int/wmdr/unit/dB.m-1>
    a skos:Concept ;
    rdfs:label "decibel per metre" ;
    dct:description "Unit of spatial gradient of sound intensity"@en ;
    skos:notation "dB.m-1" ;
.

<http://codes.wmo.int/wmdr/unit/dPa.s-1>
    a skos:Concept ;
    rdfs:label "decipascal per second (microbar per second)" ;
    dct:description "SI derived unit of time derivative of pressure, pressure tendency; SI base unit equivalent: 0.1 kg.m-1.s-3"@en ;
    skos:notation "dPa.s-1" ;
.

<http://codes.wmo.int/wmdr/unit/daPa>
    a skos:Concept ;
    rdfs:label "dekapascal" ;
    dct:description "SI derived unit of pressure/stress; SI base unit equivalent: 10 kg.m-1.s-2"@en ;
    skos:notation "daPa" ;
.

<http://codes.wmo.int/wmdr/unit/deg>
    a skos:Concept ;
    rdfs:label "degree (angle)" ;
    dct:description "Unit of plane or phase angle, accepted for use with SI: 1 deg = (pi/180) rad"@en ;
    skos:notation "deg" ;
.

<http://codes.wmo.int/wmdr/unit/deg.s-1>
    a skos:Concept ;
    rdfs:label "degree (angle) per second" ;
    dct:description "Unit of angular speed, accepted for use with SI"@en ;
    skos:notation "deg.s-1" ;
.

<http://codes.wmo.int/wmdr/unit/deg2>
    a skos:Concept ;
    rdfs:label "square degree (angle)" ;
    dct:description "Unit of square of phase or plane angle, accepted for use with SI"@en ;
    skos:notation "deg2" ;
.

<http://codes.wmo.int/wmdr/unit/degC>
    a skos:Concept ;
    rdfs:label "degree Celsius (°C)" ;
    dct:description "SI derived unit of temperature, as defined by ITS-90; SI base unit equivalent: K, with t/degC = T/K + 273.15"@en ;
    skos:notation "degC" ;
.

<http://codes.wmo.int/wmdr/unit/degC.hm-1>
    a skos:Concept ;
    rdfs:label "degree Celsius per 100 metres" ;
    dct:description "SI derived unit of spatial gradient of temperature per 100 metres; SI base unit equivalent: 0.01 K.m-1"@en ;
    skos:notation "degC.hm-1" ;
.

<http://codes.wmo.int/wmdr/unit/degC.m-1>
    a skos:Concept ;
    rdfs:label "degree Celsius per metre" ;
    dct:description "SI derived unit of spatial gradient of temperature per metre; SI base unit equivalent: K.m-1"@en ;
    skos:notation "degC.m-1" ;
.

<http://codes.wmo.int/wmdr/unit/dm>
    a skos:Concept ;
    rdfs:label "decimetre" ;
    dct:description "SI prefixed unit of length; SI base unit equivalent: 0.1 m"@en ;
    skos:notation "dm" ;
.

<http://codes.wmo.int/wmdr/unit/eV>
    a skos:Concept ;
    rdfs:label "electron volt" ;
    dct:description "Unit of energy, accepted for use with SI; SI base unit equivalent: 1.602176634E19 kg m2 s-2"@en ;
    skos:notation "eV" ;
.

<http://codes.wmo.int/wmdr/unit/fmol.kg-1>
    a skos:Concept ;
    rdfs:label "femtomole per kilogram" ;
    dct:description "SI derived unit of amount per unit mass; SI base unit equivalent: 1E-15 mol.kg-1"@en ;
    skos:notation "fmol.kg-1" ;
.

<http://codes.wmo.int/wmdr/unit/ft>
    a skos:Concept ;
    rdfs:label "foot" ;
    dct:description "Imperial/US unit of length, equal to 1200/3937 metre or 0.3048 metre (approximately)"@en ;
    skos:notation "ft" ;
.

<http://codes.wmo.int/wmdr/unit/g.cm-3>
    a skos:Concept ;
    rdfs:label "gram per cubic centimetre" ;
    dct:description "SI derived unit of density, equivalent to kilograms per litre; SI base unit equivalent: 1000 kg.m-3"@en ;
    skos:notation "g.cm-3" ;
.

<http://codes.wmo.int/wmdr/unit/g.kg-1>
    a skos:Concept ;
    rdfs:label "gram per kilogram" ;
    dct:description "SI derived unit of mass fraction, dimensionless; SI base unit equivalent: 0.001"@en ;
    skos:notation "g.kg-1" ;
.

<http://codes.wmo.int/wmdr/unit/g.kg-1.s-1>
    a skos:Concept ;
    rdfs:label "gram per kilogram per second" ;
    dct:description "SI derived unit of time derivative of mass fraction; SI base unit equivalent: 0.001 s-1"@en ;
    skos:notation "g.kg-1.s-1" ;
.

<http://codes.wmo.int/wmdr/unit/g0>
    a skos:Concept ;
    rdfs:label "standard acceleration due to gravity" ;
    dct:description "Conventional unit of gravity acceleration; g0 = 9.80665 m.s-2"@en ;
    skos:notation "g0" ;
.

<http://codes.wmo.int/wmdr/unit/gpm>
    a skos:Concept ;
    rdfs:label "geopotential metre" ;
    dct:description "The height of a given point in the atmosphere in units proportional to the potential energy of unit mass (geopotential) at this height relative to sea level. (AMS Glossary of Meteorology)"@en ;
    skos:notation "gpm" ;
.

<http://codes.wmo.int/wmdr/unit/h>
    a skos:Concept ;
    rdfs:label "hour" ;
    dct:description "Unit of time, accepted for use with SI: 1 h = 3600 s"@en ;
    skos:notation "h" ;
.

<http://codes.wmo.int/wmdr/unit/hPa>
    a skos:Concept ;
    rdfs:label "hectopascal" ;
    dct:description "SI derived unit of pressure/stress; SI base unit equivalent: 100 kg.m-1.s-2"@en ;
    skos:notation "hPa" ;
.

<http://codes.wmo.int/wmdr/unit/hPa.(3h)-1>
    a skos:Concept ;
    rdfs:label "hectopascal per 3 hours" ;
    dct:description "SI derived unit of time derivative of pressure; SI base unit equivalent: 1/108 kg.m-1.s-3"@en ;
    skos:notation "hPa.(3h)-1" ;
.

<http://codes.wmo.int/wmdr/unit/hPa.h-1>
    a skos:Concept ;
    rdfs:label "hectopascal per hour" ;
    dct:description "SI derived unit of time derivative of pressure; SI base unit equivalent: 1/36 kg.m-1.s-3"@en ;
    skos:notation "hPa.h-1" ;
.

<http://codes.wmo.int/wmdr/unit/hPa.s-1>
    a skos:Concept ;
    rdfs:label "hectopascal per second" ;
    dct:description "SI derived unit of time derivative of pressure; SI base unit equivalent: 100 kg.m-1.s-3"@en ;
    skos:notation "hPa.s-1" ;
.

<http://codes.wmo.int/wmdr/unit/ha>
    a skos:Concept ;
    rdfs:label "hectare" ;
    dct:description "Unit of area, accepted for use with SI: 1 ha = 1E4 m2"@en ;
    skos:notation "ha" ;
.

<http://codes.wmo.int/wmdr/unit/in>
    a skos:Concept ;
    rdfs:label "inch" ;
    dct:description "Imperial/US unit of length, equal to 25.4 millimetres"@en ;
    skos:notation "in" ;
.

<http://codes.wmo.int/wmdr/unit/inapplicable>
    a skos:Concept ;
    rdfs:label "inapplicable" ;
    dct:description "There is no value (categorical data)"@en ;
    skos:notation "inapplicable" ;
.

<http://codes.wmo.int/wmdr/unit/kHz>
    a skos:Concept ;
    rdfs:label "kilohertz" ;
    dct:description "SI derived unit of frequency; SI base unit equivalent: 1000 s-1"@en ;
    skos:notation "kHz" ;
.

<http://codes.wmo.int/wmdr/unit/kPa>
    a skos:Concept ;
    rdfs:label "kilopascal" ;
    dct:description "SI derived unit of pressure/stress, equal to 1000 Pa; SI base unit equivalent: 1000 kg.m-1.s-2"@en ;
    skos:notation "kPa" ;
.

<http://codes.wmo.int/wmdr/unit/kcal.cm-2>
    a skos:Concept ;
    rdfs:label "kilocalory per square centimetre" ;
    dct:description "Unit of radiant exposure, equal to 4.184E7 J.m-2"@en ;
    skos:notation "kcal.cm-2" ;
.

<http://codes.wmo.int/wmdr/unit/kg>
    a skos:Concept ;
    rdfs:label "kilogram" ;
    dct:description "SI base unit of mass"@en ;
    skos:notation "kg" ;
.

<http://codes.wmo.int/wmdr/unit/kg-2.s-1>
    a skos:Concept ;
    rdfs:label "per square kilogram per second" ;
    dct:description "SI derived unit of quantity with dimension of M-2.T-1"@en ;
    skos:notation "kg-2.s-1" ;
.

<http://codes.wmo.int/wmdr/unit/kg.kg-1>
    a skos:Concept ;
    rdfs:label "kilogram per kilogram" ;
    dct:description "SI derived unit of mass fraction; SI base unit equivalent: 1"@en ;
    skos:notation "kg.kg-1" ;
.

<http://codes.wmo.int/wmdr/unit/kg.kg-1.s-1>
    a skos:Concept ;
    rdfs:label "kilogram per kilogram per second" ;
    dct:description "SI derived unit of time derivative of mass fraction; SI base unit equivalent: s-1"@en ;
    skos:notation "kg.kg-1.s-1" ;
.

<http://codes.wmo.int/wmdr/unit/kg.m-1>
    a skos:Concept ;
    rdfs:label "kilogram per metre" ;
    dct:description "SI derived unit of linear mass density or quantity with dimension of M.L-1"@en ;
    skos:notation "kg.m-1" ;
.

<http://codes.wmo.int/wmdr/unit/kg.m-2>
    a skos:Concept ;
    rdfs:label "kilogram per square metre" ;
    dct:description "SI derived unit of area density"@en ;
    skos:notation "kg.m-2" ;
.

<http://codes.wmo.int/wmdr/unit/kg.m-2.s-1>
    a skos:Concept ;
    rdfs:label "kilogram per square metre per second" ;
    dct:description "SI derived unit of time derivative of mass area density"@en ;
    skos:notation "kg.m-2.s-1" ;
.

<http://codes.wmo.int/wmdr/unit/kg.m-3>
    a skos:Concept ;
    rdfs:label "kilogram per cubic metre" ;
    dct:description "SI derived unit of density, mass density"@en ;
    skos:notation "kg.m-3" ;
.

<http://codes.wmo.int/wmdr/unit/km>
    a skos:Concept ;
    rdfs:label "kilometre" ;
    dct:description "SI prefixed unit of length; SI base unit equivalent: 1000 m"@en ;
    skos:notation "km" ;
.

<http://codes.wmo.int/wmdr/unit/km-1>
    a skos:Concept ;
    rdfs:label "per kilometre" ;
    dct:description "SI derived unit of quantity with dimension of reciprocal length, e.g., optical attenuation coefficients; SI base unit equivalent: 0.001 m-1"@en ;
    skos:notation "km-1" ;
.

<http://codes.wmo.int/wmdr/unit/km-1.sr-1>
    a skos:Concept ;
    rdfs:label "per kilometre per steradian" ;
    dct:description "SI derived unit of the scattering coefficient at a given direction; SI base unit equivalent: 0.001 m-1"@en ;
    skos:notation "km-1.sr-1" ;
.

<http://codes.wmo.int/wmdr/unit/km.d-1>
    a skos:Concept ;
    rdfs:label "kilometre per day" ;
    dct:description "SI derived unit of speed; SI base unit equivalent: 1000/86400 m.s-1"@en ;
    skos:notation "km.d-1" ;
.

<http://codes.wmo.int/wmdr/unit/km.h-1>
    a skos:Concept ;
    rdfs:label "kilometre per hour" ;
    dct:description "SI derived unit of speed; SI base unit equivalent: 1000/3600 m.s-1"@en ;
    skos:notation "km.h-1" ;
.

<http://codes.wmo.int/wmdr/unit/kt>
    a skos:Concept ;
    rdfs:label "knot" ;
    dct:description "Conventional unit of speed, equal to 1 nmi/h; SI base unit equivalent: (1852/3600)m.s-1"@en ;
    skos:notation "kt" ;
.

<http://codes.wmo.int/wmdr/unit/kt.km-1>
    a skos:Concept ;
    rdfs:label "knot per 1000 metres" ;
    dct:description "Conventional unit of spatial gradient of speed; SI base unit equivalent: 1852/3600000 s-1"@en ;
    skos:notation "kt.km-1" ;
.

<http://codes.wmo.int/wmdr/unit/l>
    a skos:Concept ;
    rdfs:label "litre" ;
    dct:description "SI derived unit of volume; SI base unit equivalent: 0.001 m3"@en ;
    skos:notation "l" ;
.

<http://codes.wmo.int/wmdr/unit/lm>
    a skos:Concept ;
    rdfs:label "lumen" ;
    dct:description "SI derived unit of luminous flux; SI base unit equivalent: 1 cd = 4π lm for a uniform source emitting in all directions."@en ;
    skos:notation "lm" ;
.

<http://codes.wmo.int/wmdr/unit/lx>
    a skos:Concept ;
    rdfs:label "lux" ;
    dct:description "SI derived unit of illuminance; SI base unit equivalent: cd.m-2"@en ;
    skos:notation "lx" ;
.

<http://codes.wmo.int/wmdr/unit/m>
    a skos:Concept ;
    rdfs:label "metre" ;
    dct:description "SI base unit of length"@en ;
    skos:notation "m" ;
.

<http://codes.wmo.int/wmdr/unit/m(2.3-1).s-1>
    a skos:Concept ;
    rdfs:label "metre to the two thirds power per second" ;
