    skos:notation "m(2.3-1).s-1" ;
.

<http://codes.wmo.int/wmdr/unit/m-1>
    a skos:Concept ;
    rdfs:label "per metre" ;
    dct:description "SI derived unit of quantity with dimension of reciprocal length, e.g., wave number, optical power, curvature, spatial frequency"@en ;
    skos:notation "m-1" ;
.

<http://codes.wmo.int/wmdr/unit/m-1.sr-1>
    a skos:Concept ;
    rdfs:label "per metre per steradian" ;
    dct:description "SI derived unit of the scattering coefficient at a given direction"@en ;
    skos:notation "m-1.sr-1" ;
.

<http://codes.wmo.int/wmdr/unit/m-3>
    a skos:Concept ;
    rdfs:label "per cubic metre" ;
    dct:description "SI derived unit of specific volume"@en ;
    skos:notation "m-3" ;
.

<http://codes.wmo.int/wmdr/unit/m.a-1>
    a skos:Concept ;
    rdfs:label "metre per year" ;
    dct:description "Conventional unit of velocity"@en ;
    skos:notation "m.a-1" ;
.

<http://codes.wmo.int/wmdr/unit/m.s-1>
    a skos:Concept ;
    rdfs:label "metre per second" ;
    dct:description "SI derived unit of speed"@en ;
    skos:notation "m.s-1" ;
.

<http://codes.wmo.int/wmdr/unit/m.s-1.km-1>
    a skos:Concept ;
    rdfs:label "metre per second per 1000 metres" ;
    dct:description "SI derived unit of spatial gradient of speed; SI base unit equivalent: 0.001 s-1"@en ;
    skos:notation "m.s-1.km-1" ;
.

<http://codes.wmo.int/wmdr/unit/m.s-1.m-1>
    a skos:Concept ;
    rdfs:label "metre per second per metre" ;
    dct:description "SI derived unit of spatial gradient of speed"@en ;
    skos:notation "m.s-1.m-1" ;
.

<http://codes.wmo.int/wmdr/unit/m.s-2>
    a skos:Concept ;
    rdfs:label "metre per second squared" ;
    dct:description "SI derived unit of acceleration"@en ;
    skos:notation "m.s-2" ;
.

<http://codes.wmo.int/wmdr/unit/m2>
    a skos:Concept ;
    rdfs:label "square metre" ;
    dct:description "SI derived unit of area"@en ;
    skos:notation "m2" ;
.

<http://codes.wmo.int/wmdr/unit/m2.s>
    a skos:Concept ;
    rdfs:label "square metre second" ;
    dct:description "SI derived unit of sea surface wave variance spectral density"@en ;
    skos:notation "m2.s" ;
.

<http://codes.wmo.int/wmdr/unit/m2.s-1>
    a skos:Concept ;
    rdfs:label "square metre per second" ;
    dct:description "SI derived unit of kinematic viscosity, thermal diffusivity, diffusion coefficient"@en ;
    skos:notation "m2.s-1" ;
.

<http://codes.wmo.int/wmdr/unit/m2.s-2>
    a skos:Concept ;
    rdfs:label "square metre per square second" ;
    dct:description "SI derived quantity with dimension of squared speed"@en ;
    skos:notation "m2.s-2" ;
.

<http://codes.wmo.int/wmdr/unit/m2.s.rad-1>
    a skos:Concept ;
    rdfs:label "square metre second per radian" ;
    dct:description "SI derived unit of sea surface wave directional variance spectral density"@en ;
    skos:notation "m2.s.rad-1" ;
.

<http://codes.wmo.int/wmdr/unit/m3>
    a skos:Concept ;
    rdfs:label "cubic metres" ;
    dct:description "SI derived unit of volume"@en ;
    skos:notation "m3" ;
.

<http://codes.wmo.int/wmdr/unit/m3.m-3>
    a skos:Concept ;
    rdfs:label "cubic metre per cubic metre" ;
    dct:description "SI derived unit of volume fraction; SI base unit equivalent: 1"@en ;
    skos:notation "m3.m-3" ;
.

<http://codes.wmo.int/wmdr/unit/m3.s-1>
    a skos:Concept ;
    rdfs:label "cubic metre per second" ;
    dct:description "SI derived unit of volume flow rate or time derivative of volume"@en ;
    skos:notation "m3.s-1" ;
.

<http://codes.wmo.int/wmdr/unit/m4>
    a skos:Concept ;
    rdfs:label "metre to the fourth power" ;
    dct:description "SI derived unit of the second moment of area, area moment of inertia"@en ;
