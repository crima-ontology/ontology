PREFIX ar5-adapt: <http://www.semanticweb.org/crima/ipcc-ar5-adaptation#>
PREFIX ar6-cid: <http://www.semanticweb.org/crima/ipcc-ar6-cid#>
PREFIX ar6-impact: <http://www.semanticweb.org/crima/ipcc-ar6-impacts#>
PREFIX as: <https://www.w3.org/ns/activitystreams#>
PREFIX bibo: <http://purl.org/ontology/bibo/>
PREFIX cbib: <http://www.semanticweb.org/crima/crima-bib#>
PREFIX cc: <http://creativecommons.org/ns#>
PREFIX ccore: <http://www.semanticweb.org/crima/crima-core#>
PREFIX clc: <http://www.w3.org/2015/03/corine#>
PREFIX clex: <http://www.semanticweb.org/crima/crima-lexicon#>
PREFIX cplace: <http://www.semanticweb.org/crima/crima-place#>
PREFIX crid: <http://www.semanticweb.org/crima/crima-id#>
PREFIX ecv-data: <http://www.semanticweb.org/crima/crima-ecv-data#>
PREFIX ctlo: <http://www.semanticweb.org/crima/crima-tlo#>
PREFIX cunit: <http://www.semanticweb.org/crima/crima-unit#>
PREFIX dbo: <http://dbpedia.org/ontology/>
PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX ecv: <http://www.semanticweb.org/crima/crima-ecv#>
PREFIX emdat: <http://www.semanticweb.org/crima/emdat#>
PREFIX ex: <http://example.org/ontology/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
PREFIX geo: <http://www.opengis.net/ont/geosparql#>
PREFIX ich: <http://www.semanticweb.org/crima/crima-impactchain#>
PREFIX mod: <mod:>
PREFIX org: <http://www.w3.org/ns/org#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <http://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX sosa: <http://www.w3.org/ns/sosa/>
PREFIX sosa-common: <http://www.w3.org/ns/sosa/common/>
PREFIX sosa-obs: <http://www.w3.org/ns/sosa/obs/>
PREFIX vann: <http://purl.org/vocab/vann/>
PREFIX wmdr-unit: <http://codes.wmo.int/wmdr/unit/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>


# IMPORTED VOCABULARIES

as:
    mod:hasSerialization "imports/fragments/as.ttl" ;
    mod:definesNamespace "https://www.w3.org/ns/activitystreams#"^^xsd:anyURI .

bibo:
    mod:hasSerialization "imports/fragments/bibo.ttl" ;
    mod:definesNamespace "http://purl.org/ontology/bibo/"^^xsd:anyURI .

cc:
    mod:hasSerialization "imports/fragments/cc.ttl" ;
    mod:definesNamespace "http://creativecommons.org/ns#"^^xsd:anyURI ;
    mod:definesTerm <https://creativecommons.org/publicdomain/zero/1.0/> .

clc:
    mod:hasSerialization "imports/fragments/clc.ttl" ;
    mod:definesNamespace "http://www.w3.org/2015/03/corine#"^^xsd:anyURI ;
    mod:includesObjectsOf
        dcterms:creator ,
        dcterms:source ,
        foaf:PersonalProfileDocument ,
        foaf:homepage ,
        foaf:maker .

dbo:
    mod:hasSerialization "imports/fragments/dbo.ttl" ;
    mod:definesNamespace "http://dbpedia.org/ontology/"^^xsd:anyURI .

<http://www.w3.org/ns/dcat>
    mod:hasSerialization "imports/fragments/dcat.ttl" ;
    mod:definesNamespace "http://www.w3.org/ns/dcat#"^^xsd:anyURI ;
    mod:includesObjectsOf rdfs:isDefinedBy .

dcterms:
    mod:hasSerialization "imports/fragments/dcterms.ttl" ;
    mod:definesNamespace "http://purl.org/dc/terms/"^^xsd:anyURI .

<http://knowwheregraph/ontology/dpo>
    mod:hasSerialization "imports/fragments/dpo.ttl" ;
    mod:definesNamespace "http://knowwheregraph/ontology/dpo#"^^xsd:anyURI .

<http://www.linkedmodel.org/schema/dtype>
    mod:hasSerialization "imports/fragments/dtype.ttl" ;
    mod:definesNamespace "http://www.linkedmodel.org/schema/dtype#"^^xsd:anyURI .

foaf:
    mod:hasSerialization "imports/fragments/foaf.ttl" ;
    mod:definesNamespace "http://xmlns.com/foaf/0.1/"^^xsd:anyURI .

<http://www.opengis.net/ont/geosparql>
    mod:hasSerialization "imports/fragments/geo.ttl" ;
    mod:definesNamespace "http://www.opengis.net/ont/geosparql#"^^xsd:anyURI ;
    mod:includesObjectsOf
        rdfs:isDefinedBy ,
        rdfs:seeAlso .

org:
    mod:hasSerialization "imports/fragments/org.ttl" ;
    mod:definesNamespace "http://www.w3.org/ns/org#"^^xsd:anyURI .

<http://www.w3.org/ns/prov-o#>
    mod:hasSerialization "imports/fragments/prov.ttl" ;
    mod:definesNamespace "http://www.w3.org/ns/prov#"^^xsd:anyURI .

<http://qudt.org/schema/qudt>
    mod:hasSerialization "imports/fragments/qudt.ttl" ;
    mod:definesNamespace "http://qudt.org/schema/qudt/"^^xsd:anyURI ;
    mod:includesObjectsOf rdfs:isDefinedBy .

<http://qudt.org/vocab/unit>
    mod:hasSerialization "imports/fragments/qudt-unit.ttl" ;
    mod:definesNamespace "http://qudt.org/vocab/unit/"^^xsd:anyURI ;
    mod:includesObjectsOf
        dcterms:source ,
        rdfs:isDefinedBy .

schema:
    mod:hasSerialization "imports/fragments/schema.ttl" ;
    mod:definesNamespace "http://schema.org/"^^xsd:anyURI .

<http://www.w3.org/2004/02/skos/core>
    mod:hasSerialization "imports/fragments/skos.ttl" ;
    mod:definesNamespace "http://www.w3.org/2004/02/skos/core#"^^xsd:anyURI .

sosa-common:
    mod:hasSerialization "imports/fragments/sosa-common.ttl" ;
    mod:includesObjectsOf dcterms:source .

sosa-obs:
    mod:hasSerialization "imports/fragments/sosa-obs.ttl" .

<http://www.w3.org/2006/time>
    mod:hasSerialization "imports/fragments/time.ttl" ;
    mod:definesNamespace "http://www.w3.org/2006/time#"^^xsd:anyURI .

vann:
    mod:hasSerialization "imports/fragments/vann.ttl" ;
    mod:definesNamespace "http://purl.org/vocab/vann/"^^xsd:anyURI .

<http://purl.org/vocommons/voaf>
    mod:hasSerialization "imports/fragments/voaf.ttl" ;
    mod:definesNamespace "http://purl.org/vocommons/voaf#"^^xsd:anyURI .

wmdr-unit:
    mod:hasSerialization "imports/fragments/wmdr-unit.ttl" ;
    mod:definesNamespace "http://codes.wmo.int/wmdr/unit/"^^xsd:anyURI .

<http://rdf-vocabulary.ddialliance.org/xkos>
    mod:hasSerialization "imports/fragments/xkos.ttl" ;
    mod:definesNamespace "http://rdf-vocabulary.ddialliance.org/xkos#"^^xsd:anyURI .


# ONTOLOGY MODULES

ar5-adapt:
    mod:hasSerialization "modules/ar5-adapt.ttl" ;
    mod:definesNamespace "http://www.semanticweb.org/crima/ipcc-ar5-adaptation#"^^xsd:anyURI .

ar6-cid:
    mod:hasSerialization "modules/ar6-cid.ttl" ;
    mod:definesNamespace "http://www.semanticweb.org/crima/ipcc-ar6-cid#"^^xsd:anyURI .

ar6-impact:
    mod:hasSerialization "modules/ar6-impact.ttl" ;
    mod:definesNamespace "http://www.semanticweb.org/crima/ipcc-ar6-impacts#"^^xsd:anyURI .

cbib:
    mod:hasSerialization "modules/cbib.ttl" ;
    mod:definesNamespace "http://www.semanticweb.org/crima/crima-bib#"^^xsd:anyURI ;
    mod:includesStatementsWith
        ( dcterms:date skos:scopeNote ) ,
        ( dcterms:hasPart skos:note ) ,
        ( dcterms:isPartOf skos:note ) ,
        ( dcterms:publisher skos:scopeNote ) ,
        ( dcterms:subject dcat:Resource ) ,
        ( dcterms:subject skos:note ) ,
        ( dcterms:subject <http://dublincore.org/usage/terms/history/#subjectT-001> ) ,
        ( bibo:Document dcterms:BibliographicResource ) ,
        ( bibo:abstract dcterms:BibliographicResource ) ,
        ( bibo:doi dcterms:identifier ) ,
        ( bibo:isbn dcterms:identifier ) ,
        ( bibo:uri dcterms:identifier ) ,
        ( rdf:List owl:Class ) ,
        ( rdf:first owl:ObjectProperty ) ,
        ( rdf:first rdfs:domain ) ,
        ( rdf:rest owl:ObjectProperty ) ,
        ( rdf:rest rdfs:domain ) ,
        ( rdf:rest rdfs:range ) .

ccore:
    mod:hasSerialization "modules/ccore.ttl" ;
    mod:definesNamespace "http://www.semanticweb.org/crima/crima-core#"^^xsd:anyURI ;
    mod:includesStatementsWith
        ( sosa:Property ctlo:Quality ) .

clex:
    mod:hasSerialization "modules/clex.ttl" ;
    mod:definesNamespace "http://www.semanticweb.org/crima/crima-lexicon#"^^xsd:anyURI .

cplace:
    mod:hasSerialization "modules/cplace.ttl" ;
    mod:definesNamespace "http://www.semanticweb.org/crima/crima-place#"^^xsd:anyURI ;
    mod:includesStatementsWith
        ( as:latitude geo:hasSerialization ) ,
        ( as:longitude geo:hasSerialization ) ,
        ( dbo:ArchitecturalStructure geo:Feature ) ,
        ( dbo:ArchitecturalStructure sosa:FeatureOfInterest ) ,
        ( dbo:Place geo:Feature ) ,
        ( dbo:Place sosa:FeatureOfInterest ) ,
        ( sosa:Platform geo:Feature ) .

crid:
    mod:hasSerialization "modules/crid.ttl" ;
    mod:definesNamespace "http://www.semanticweb.org/crima/crima-id#"^^xsd:anyURI .

ctlo:
    mod:hasSerialization "modules/ctlo.ttl" ;
    mod:definesNamespace "http://www.semanticweb.org/crima/crima-tlo#"^^xsd:anyURI .

cunit:
    mod:hasSerialization "modules/cunit.ttl" ;
    mod:definesNamespace "http://www.semanticweb.org/crima/crima-unit#"^^xsd:anyURI .

ecv:
    mod:hasSerialization "modules/ecv.ttl" ;
    mod:definesNamespaceTBox "http://www.semanticweb.org/crima/crima-ecv#"^^xsd:anyURI .

ecv-data:
    mod:hasSerialization "modules/ecv-data.ttl" ;
    mod:definesNamespaceABox "http://www.semanticweb.org/crima/crima-ecv#"^^xsd:anyURI .

emdat:
    mod:hasSerialization "modules/emdat.ttl" ;
    mod:definesNamespace "http://www.semanticweb.org/crima/emdat#"^^xsd:anyURI .

ex:
    mod:hasSerialization "modules/ex.ttl" ;
    mod:definesNamespace "http://example.org/ontology/"^^xsd:anyURI .

<https://undrr-hip.org/hip-data/>
    mod:hasSerialization "modules/hip-data.ttl" ;
    mod:definesNamespace
        "https://unece.org/transport/dangerous-goods/ghs-rev10-2023#"^^xsd:anyURI ,
        "https://www.preventionweb.net/drr-glossary/"^^xsd:anyURI ,
        "https://www.preventionweb.net/hips-cluster/"^^xsd:anyURI ,
        "https://www.preventionweb.net/hips-type/"^^xsd:anyURI ,
        "https://www.undrr.org/terms/hips/"^^xsd:anyURI ;
    mod:definesNamespaceABox "https://undrr-hip.org/"^^xsd:anyURI ;
    mod:includesObjectsOf
        dcterms:hasPart ,
        dcterms:references ,
        dcterms:source ,
        prov:wasInfluencedBy .

<https://undrr-hip.org/hip-schema/>
    mod:hasSerialization "modules/hip.ttl" ;
    mod:definesNamespaceTBox "https://undrr-hip.org/"^^xsd:anyURI ;
    mod:includesObjectsOf rdfs:isDefinedBy ;
    mod:includesStatementsWith
        ( org:Organization dcterms:Agent ) .

ich:
    mod:hasSerialization "modules/ich.ttl" ;
    mod:definesNamespace "http://www.semanticweb.org/crima/crima-impactchain#"^^xsd:anyURI ;
    mod:includesObjectsOf rdfs:isDefinedBy .


# ONTOLOGY MAIN FILE

<http://www.semanticweb.org/crima>
    mod:hasSerialization "crima.ttl" ;
    mod:includesObjectsOf
        dcterms:license ,
        owl:versionIRI .
