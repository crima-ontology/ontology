    qudt:derivedCoherentUnitOfSystem sou:SI ;
    qudt:expression "$J/kg$"^^qudt:LatexString ;
    qudt:hasDimensionVector qkdv:A0E0L2I0M0H0T-2D0 ;
    qudt:hasFactorUnit 
