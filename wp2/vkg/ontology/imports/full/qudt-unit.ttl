unit:HZ-PER-V
    a qudt:Unit ;
    rdfs:label
        "Hertz per Volt" ,
        "Херц на Волт"@bg ,
        "Hertz na Volt"@cs ,
        "Hertz pro Volt"@de ,
        "Χερτζ ανά Βολτ"@el ,
        "Hertz per Volt"@en ,
