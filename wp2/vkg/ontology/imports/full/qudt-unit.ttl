    qudt:hasFactorUnit 
        [
            a qudt:FactorUnit ;
            qudt:exponent 3 ;
            qudt:hasUnit unit:M ;
        ] ,
        [
            a qudt:FactorUnit ;
            qudt:exponent -1 ;
            qudt:hasUnit unit:KiloGM ;
        ] ;
    qudt:hasQuantityKind
