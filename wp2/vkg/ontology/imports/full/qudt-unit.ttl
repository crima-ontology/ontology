    qudt:omUnit <http://www.ontology-of-units-of-measure.org/resource/om-2/stathenry> ;
    qudt:scalingOf unit:H ;
    qudt:symbol "statH" ;
    qudt:wikidataMatch <http://www.wikidata.org/entity/Q12955440> ;
    rdfs:isDefinedBy <http://qudt.org/vocab/unit> ;
