unit:M2-PER-SEC
    a
        qudt:DerivedUnit ,
        qudt:Unit ;
    rdfs:label
        "Square Metre per Second" ,
        "متر مربع في الثانية"@ar ,
        "Квадратен Метър на Секунда"@bg ,
        "Čtvereční Metr na Sekunda"@cs ,
        "Quadratmeter pro Sekunde"@de ,
        "Τετραγωνικό Μέτρο ανά Δευτερόλεπτο"@el ,
