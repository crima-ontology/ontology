    qudt:definedUnitOfSystem
        sou:IMPERIAL ,
        sou:USCS ;
    qudt:expression "$ft/s$"^^qudt:LatexString ;
    qudt:hasDimensionVector qkdv:A0E0L1I0M0H0T-1D0 ;
    qudt:hasFactorUnit 
