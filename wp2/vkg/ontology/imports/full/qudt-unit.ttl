        quantitykind:MolarHeatCapacity ;
    qudt:iec61360Code "0112/2///62720#UAA184" ;
    qudt:informativeReference "https://cdd.iec.ch/cdd/iec62720/iec62720.nsf/Units/0112-2---62720%23UAA184"^^xsd:anyURI ;
