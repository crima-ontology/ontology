            a qudt:FactorUnit ;
            qudt:exponent 1 ;
            qudt:hasUnit unit:BTU_TH ;
        ] ;
    qudt:hasQuantityKind quantitykind:ThermalConductivity ;
    qudt:hasReciprocalUnit unit:DEG_F-HR-FT2-PER-BTU_TH-IN ;
