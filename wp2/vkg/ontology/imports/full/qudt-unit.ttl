    qudt:uneceCommonCode
        "G23" ,
        "PY" ;
    qudt:wikidataMatch <http://www.wikidata.org/entity/Q101427873> ;
    rdfs:isDefinedBy <http://qudt.org/vocab/unit> ;
.

