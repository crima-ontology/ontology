        [
            a qudt:FactorUnit ;
            qudt:exponent -1 ;
            qudt:hasUnit unit:V ;
        ] ,
        [
            a qudt:FactorUnit ;
            qudt:exponent 1 ;
            qudt:hasUnit unit:HZ ;
        ] ;
    qudt:hasQuantityKind quantitykind:InverseMagneticFlux ;
    qudt:symbol "Hz/V" ;
    qudt:ucumCode "Hz.V-1"^^qudt:UCUMcs ;
    qudt:wikidataMatch <http://www.wikidata.org/entity/Q101195156> ;
