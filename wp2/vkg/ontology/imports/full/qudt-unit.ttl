unit:M3-PER-MOL
    a qudt:Unit ;
    rdfs:label
        "Cubic Metre per Mole" ,
        "متر مكعب لكل مول"@ar ,
        "Кубичен Метър на Мол"@bg ,
        "Metr Krychlový na Mol"@cs ,
