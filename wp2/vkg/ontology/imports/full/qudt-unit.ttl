  """^^qudt:LatexString ;
    qudt:conversionMultiplier 101325.0 ;
    qudt:conversionMultiplierSN 1.01325e+05 ;
    qudt:hasDimensionVector qkdv:A-1E0L2I0M1H0T-2D0 ;
