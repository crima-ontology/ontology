        "https://en.wikipedia.org/wiki/Tex?oldid=457265525"^^xsd:anyURI ,
        "https://en.wikipedia.org/wiki/Units_of_textile_measurement"^^xsd:anyURI ;
    qudt:scalingOf unit:GM-PER-MilliM ;
    qudt:symbol "tex" ;
    qudt:ucumCode "tex"^^qudt:UCUMcs ;
    qudt:uneceCommonCode "D34" ;
    qudt:wikidataMatch <http://www.wikidata.org/entity/Q1091257> ;
    rdfs:isDefinedBy <http://qudt.org/vocab/unit> ;
