            a qudt:FactorUnit ;
            qudt:exponent 1 ;
            qudt:hasUnit unit:FT ;
        ] ;
    qudt:hasQuantityKind
        quantitykind:LinearVelocity ,
        quantitykind:Velocity ;
    qudt:iec61360Code "0112/2///62720#UAA449" ;
    qudt:informativeReference
        "https://cdd.iec.ch/cdd/iec62720/iec62720.nsf/Units/0112-2---62720%23UAA449"^^xsd:anyURI ,
        "https://en.wikipedia.org/wiki/Foot_per_second?oldid=491316573"^^xsd:anyURI ;
