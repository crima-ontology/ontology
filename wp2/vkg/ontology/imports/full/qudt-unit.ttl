            qudt:exponent 1 ;
            qudt:hasUnit unit:LM ;
        ] ,
        [
            a qudt:FactorUnit ;
            qudt:exponent -2 ;
            qudt:hasUnit unit:M ;
        ] ;
    qudt:hasQuantityKind quantitykind:LuminousFluxPerArea ;
    qudt:iec61360Code "0112/2///62720#UAA723" ;
    qudt:informativeReference
        "https://cdd.iec.ch/cdd/iec62720/iec62720.nsf/Units/0112-2---62720%23UAA723"^^xsd:anyURI ,
        "https://en.wikipedia.org/wiki/Lux?oldid=494700274"^^xsd:anyURI ;
    qudt:omUnit <http://www.ontology-of-units-of-measure.org/resource/om-2/lux> ;
