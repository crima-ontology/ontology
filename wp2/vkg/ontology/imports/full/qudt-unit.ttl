            qudt:exponent 1 ;
            qudt:hasUnit unit:C ;
        ] ,
        [
            a qudt:FactorUnit ;
            qudt:exponent -1 ;
            qudt:hasUnit unit:V ;
        ] ;
    qudt:hasQuantityKind quantitykind:Capacitance ;
    qudt:iec61360Code "0112/2///62720#UAA144" ;
    qudt:informativeReference
        "https://cdd.iec.ch/cdd/iec62720/iec62720.nsf/Units/0112-2---62720%23UAA144"^^xsd:anyURI ,
        "https://en.wikipedia.org/wiki/Farad?oldid=493070876"^^xsd:anyURI ;
    qudt:omUnit <http://www.ontology-of-units-of-measure.org/resource/om-2/farad> ;
