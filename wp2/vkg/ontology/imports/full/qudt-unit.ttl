        "https://cdd.iec.ch/cdd/iec62720/iec62720.nsf/Units/0112-2---62720%23UAB208"^^xsd:anyURI ;
    qudt:symbol "mi²" ;
    qudt:ucumCode "[mi_i]2"^^qudt:UCUMcs ;
