    qudt:hasQuantityKind quantitykind:EnergyDensity ;
    qudt:iec61360Code "0112/2///62720#UAB281" ;
    qudt:informativeReference
        "http://physics.nist.gov/Pubs/SP811/appenB9.html"^^xsd:anyURI ,
