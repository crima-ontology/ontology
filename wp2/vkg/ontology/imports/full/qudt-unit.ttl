    qudt:scalingOf unit:M ;
    qudt:symbol "nmi" ;
    qudt:ucumCode "[nmi_i]"^^qudt:UCUMcs ;
    qudt:uneceCommonCode "NMI" ;
    qudt:wikidataMatch <http://www.wikidata.org/entity/Q93318> ;
    rdfs:isDefinedBy <http://qudt.org/vocab/unit> ;
.

