            qudt:hasUnit unit:SEC ;
        ] ,
        [
            a qudt:FactorUnit ;
            qudt:exponent 2 ;
            qudt:hasUnit unit:CentiM ;
        ] ;
    qudt:hasQuantityKind quantitykind:Energy ;
    qudt:iec61360Code "0112/2///62720#UAA429" ;
