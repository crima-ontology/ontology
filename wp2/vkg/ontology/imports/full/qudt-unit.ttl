    rdfs:seeAlso unit:IU ;
.

unit:IU-PER-MilliGM
    a qudt:Unit ;
    rdfs:label
        "International Unit per Milligram" ,
        "International Unit per Milligram"@en ;
    dcterms:description """
<p>International Unit per milligramme.
