PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema1: <http://schema.org/>
PREFIX sosa: <http://www.w3.org/ns/sosa/>
PREFIX sosa-act: <http://www.w3.org/ns/sosa/act/>
PREFIX sosa-common: <http://www.w3.org/ns/sosa/common/>
PREFIX sosa-dep: <http://www.w3.org/ns/sosa/dep/>
PREFIX sosa-obs: <http://www.w3.org/ns/sosa/obs/>
PREFIX sosa-sam: <http://www.w3.org/ns/sosa/sam/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

sosa:
    a owl:Ontology ;
    dcterms:created "2017-04-17"^^xsd:date ;
    dcterms:creator
        [
            a foaf:Agent ;
            foaf:name "W3C/OGC Spatial Data on the Web Working Group"@en ;
        ] ;
    dcterms:description """
  This module imports all the terms in the SOSA module, and adds cross-module annotations (domain/rangeIncludes). 
  """@en ;
    dcterms:license
        <http://www.opengeospatial.org/ogc/Software> ,
        <http://www.w3.org/Consortium/Legal/2015/copyright-software-and-document> ;
    dcterms:modified "2024-02-03"^^xsd:date ;
    dcterms:rights "Copyright 2025 W3C/OGC." ;
    dcterms:title "Sensor, Observation, Sample, and Actuator (SOSA) Ontology"@en ;
    owl:imports
        sosa-act: ,
        sosa-dep: ,
        sosa-obs: ,
        sosa-sam: ;
    owl:priorVersion <http://www.w3.org/ns/sosa/2017/> ;
    owl:versionIRI <http://www.w3.org/ns/sosa/2023/> ;
.

sosa:madeBySystem
    schema1:domainIncludes
        sosa:Actuation ,
        sosa:ActuationCollection ,
        sosa:Observation ,
        sosa:ObservationCollection ,
        sosa:Sampling ,
        sosa:SamplingCollection ;
    schema1:rangeIncludes
        sosa:Actuator ,
        sosa:Sampler ,
        sosa:Sensor ;
    rdfs:isDefinedBy sosa-common: ;
.

sosa:madeExecution
    schema1:domainIncludes
        sosa:Actuator ,
        sosa:Sampler ,
        sosa:Sensor ;
    schema1:rangeIncludes
        sosa:Actuation ,
        sosa:ActuationCollection ,
        sosa:Observation ,
        sosa:ObservationCollection ,
        sosa:Sampling ,
        sosa:SamplingCollection ;
    rdfs:isDefinedBy sosa-common: ;
.

sosa:observationRelatedTo
    schema1:rangeIncludes
        sosa:Actuation ,
        sosa:ActuationCollection ,
        sosa:Sampling ,
        sosa:SamplingCollection ;
    rdfs:isDefinedBy sosa-obs: ;
.

sosa:relatedObservation
    schema1:domainIncludes
        sosa:Actuation ,
        sosa:ActuationCollection ,
        sosa:Sampling ,
        sosa:SamplingCollection ;
    rdfs:isDefinedBy sosa-obs: ;
.
