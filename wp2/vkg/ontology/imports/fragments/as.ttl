###  https://www.w3.org/ns/activitystreams#altitude
as:altitude rdf:type owl:DatatypeProperty ;
            rdfs:range xsd:float ;
            rdfs:comment "Indicates the altitude of a place. The measurement units is indicated using the units property. If units is not specified, the default is assumed to be \"m\" indicating meters." ;
            rdfs:isDefinedBy "https://www.w3.org/TR/activitystreams-vocabulary/" .


###  https://www.w3.org/ns/activitystreams#latitude
as:latitude rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:range xsd:float ;
            rdfs:comment "The latitude of a place"@en ;
            rdfs:isDefinedBy "https://www.w3.org/TR/activitystreams-vocabulary/" ;
            rdfs:label "latitude"@en ;
            rdfs:seeAlso "Open Geospatial Consortium: OGC GeoSPARQL - A Geographic Query Language for RDF Data. Section: E.3. W3C Activity Streams Vocabulary (https://docs.ogc.org/is/22-047r1/22-047r1.html#_28864842-9099-4b71-b1d0-e5f6554de626)" .


###  https://www.w3.org/ns/activitystreams#longitude
as:longitude rdf:type owl:DatatypeProperty ,
                      owl:FunctionalProperty ;
             rdfs:range xsd:float ;
             rdfs:comment "The longitude of a place"@en ;
             rdfs:label "longitude"@en ;
             rdfs:seeAlso "Open Geospatial Consortium: OGC GeoSPARQL - A Geographic Query Language for RDF Data. Section: E.3. W3C Activity Streams Vocabulary (https://docs.ogc.org/is/22-047r1/22-047r1.html#_28864842-9099-4b71-b1d0-e5f6554de626)" ,
