@prefix : <https://w3id.org/crima-ontology/cclc#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix cclc: <https://w3id.org/crima-ontology/cclc#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <https://w3id.org/crima-ontology/cclc#> .

<https://w3id.org/crima-ontology/cclc#> rdf:type owl:Ontology ;
                                               owl:imports <http://www.w3.org/2004/02/skos/core> ;
                                               vann:preferredNamespacePrefix "cclc" ;
                                               vann:preferredNamespaceUri "https://w3id.org/crima-ontology/cclc#"^^xsd:anyURI .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/vocab/vann/preferredNamespacePrefix
vann:preferredNamespacePrefix rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
vann:preferredNamespaceUri rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  https://w3id.org/crima-ontology/cclc#CorineValue
cclc:CorineValue rdf:type rdfs:Datatype ;
                 rdfs:comment "A numerical value from the CORINE Land Cover nomenclature" ;
                 rdfs:label "CORINE value"@en .


#################################################################
#    Object Properties
#################################################################

###  http://www.w3.org/2004/02/skos/core#inScheme
skos:inScheme rdf:type owl:ObjectProperty .


###  http://www.w3.org/2004/02/skos/core#narrower
skos:narrower rdf:type owl:ObjectProperty .


#################################################################
#    Classes
#################################################################

###  https://w3id.org/crima-ontology/cclc#CORINE-Class_level1
cclc:CORINE-Class_level1 rdf:type owl:Class ;
                         rdfs:subClassOf skos:Concept ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty skos:inScheme ;
                                           owl:allValuesFrom cclc:CORINE-classification
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty skos:narrower ;
                                           owl:allValuesFrom cclc:CORINE-Class_level2
                                         ] .


###  https://w3id.org/crima-ontology/cclc#CORINE-Class_level2
cclc:CORINE-Class_level2 rdf:type owl:Class ;
                         rdfs:subClassOf skos:Concept ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty skos:inScheme ;
                                           owl:allValuesFrom cclc:CORINE-classification
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty skos:narrower ;
                                           owl:allValuesFrom cclc:CORINE-Class_level2
                                         ] .


###  https://w3id.org/crima-ontology/cclc#CORINE-Class_level3
cclc:CORINE-Class_level3 rdf:type owl:Class ;
                         rdfs:subClassOf skos:Concept ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty skos:inScheme ;
                                           owl:allValuesFrom cclc:CORINE-classification
                                         ] .


###  https://w3id.org/crima-ontology/cclc#CORINE-classification
cclc:CORINE-classification rdf:type owl:Class ;
                           rdfs:subClassOf skos:ConceptScheme .


###  http://www.w3.org/2004/02/skos/core#Concept
skos:Concept rdf:type owl:Class .


###  http://www.w3.org/2004/02/skos/core#ConceptScheme
skos:ConceptScheme rdf:type owl:Class .


