@prefix : <http://www.semanticweb.org/crima/crima-place#> .
@prefix as: <https://www.w3.org/ns/activitystreams#> .
@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ctlo: <http://www.semanticweb.org/crima/crima-tlo#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix cplace: <http://www.semanticweb.org/crima/crima-place#> .
@prefix sosa-common: <http://www.w3.org/ns/sosa/common/> .
@base <http://www.semanticweb.org/crima/crima-place#> .

<http://www.semanticweb.org/crima/crima-place#> rdf:type owl:Ontology ;
                                                 owl:imports dbo: ,
                                                             <http://www.opengis.net/ont/geosparql> ,
                                                             ctlo: ,
                                                             sosa-common: ;
                                                 vann:preferredNamespacePrefix "cplace" ;
                                                 vann:preferredNamespaceUri "http://www.semanticweb.org/crima/crima-place#"^^xsd:anyURI ;
                                                 voaf:extends ctlo: ;
                                                 voaf:metadataVoc vann: ,
                                                                  <http://purl.org/vocommons/voaf> ;
                                                 voaf:specializes dbo: ,
                                                                  <http://www.opengis.net/ont/geosparql> ,
                                                                  ctlo: ,
                                                                  sosa-common: .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocommons/voaf#extends
voaf:extends rdf:type owl:AnnotationProperty .


###  http://purl.org/vocommons/voaf#specializes
voaf:specializes rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/crima/crima-place#inHealthDistrict
cplace:inHealthDistrict rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf ctlo:constantPartOf ;
                        rdfs:domain ctlo:PhysicalEndurant ;
                        rdfs:range cplace:HealthDistrict .


###  http://www.semanticweb.org/crima/crima-place#inHealthRegion
cplace:inHealthRegion rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf ctlo:constantPartOf ;
                      rdfs:domain ctlo:PhysicalEndurant ;
                      rdfs:range cplace:HealthRegion .


#################################################################
#    Data properties
#################################################################

###  https://www.w3.org/ns/activitystreams#latitude
as:latitude rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf geo:hasSerialization .


###  https://www.w3.org/ns/activitystreams#longitude
as:longitude rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf geo:hasSerialization .


#################################################################
#    Classes
#################################################################

###  http://dbpedia.org/ontology/ArchitecturalStructure
dbo:ArchitecturalStructure rdfs:subClassOf geo:Feature ,
                                           sosa:FeatureOfInterest .


###  http://dbpedia.org/ontology/Place
dbo:Place rdfs:subClassOf geo:Feature ,
                          sosa:FeatureOfInterest .


###  http://www.semanticweb.org/crima/crima-place#CommunityDistrict
cplace:CommunityDistrict rdf:type owl:Class ;
                         rdfs:subClassOf dbo:District ;
                         rdfs:comment "es. BURGRAVIATO, VALVENOSTA, BASSAATESINA,..." .


###  http://www.semanticweb.org/crima/crima-place#DrainageBasin
cplace:DrainageBasin rdf:type owl:Class ;
                     rdfs:subClassOf dbo:NaturalPlace .


###  http://www.semanticweb.org/crima/crima-place#HealthDistrict
cplace:HealthDistrict rdf:type owl:Class ;
                      rdfs:subClassOf dbo:District .


###  http://www.semanticweb.org/crima/crima-place#HealthRegion
cplace:HealthRegion rdf:type owl:Class ;
                    rdfs:subClassOf dbo:GovernmentalAdministrativeRegion ;
                    rdfs:comment "The sum of multiple contingous health districts (tentative)." .


###  http://www.semanticweb.org/crima/crima-place#HydrologicalStation
cplace:HydrologicalStation rdf:type owl:Class ;
                           rdfs:subClassOf sosa:Platform ;
                           rdfs:isDefinedBy "International Glossary of Hydrology / Glossaire International d’Hydrologie. World Meteorological Organization, United Nations Educational, Scientific and Cultural Organization (eds.). WMO (Series), no385. WMO, Geneva (2016). ISBN 978-92-63-03385-8. ISBN 978-92-3-001154-3." ;
                           <http://www.w3.org/2004/02/skos/core#definition> "Hydrological station established for the observation of a specific element or elements in order to investigate hydrological events. (TR)" .


###  http://www.semanticweb.org/crima/crima-place#Watercourse
cplace:Watercourse rdf:type owl:Class ;
                   rdfs:subClassOf dbo:Stream ;
                   <http://purl.org/dc/terms/description> "Natural or man-made channel through or along which water may flow [9], including large interstices in the ground, such as cave, cavern or a group of these in karst terrain." ;
                   rdfs:isDefinedBy "OGC® WaterML 2: Part 3 - Surface Hydrology Features (HY_Features) - Conceptual Model. Open Geospatial Consortium, 2018." ,
                                    "http://www.opengis.net/doc/IS/hy-features/1.0" ;
                   rdfs:seeAlso "International Glossary of Hydrology / Glossaire International d’Hydrologie. World Meteorological Organization, United Nations Educational, Scientific and Cultural Organization (eds.). WMO (Series), no385. WMO, Geneva (2016). ISBN 978-92-63-03385-8. ISBN 978-92-3-001154-3." ,
                                "http://purl.obolibrary.org/obo/ENVO_00000029 " .


###  http://www.semanticweb.org/crima/crima-place#WeatherStation
cplace:WeatherStation rdf:type owl:Class ;
                      rdfs:subClassOf sosa:Platform ;
                      rdfs:isDefinedBy "https://en.wikipedia.org/wiki/Weather_station" ;
                      rdfs:seeAlso """Guide to Meteorological Instruments and Methods of Observation. WMO-No. 8. World Meteorological Organization, 2008.
https://www.weather.gov/media/epz/mesonet/CWOP-WMO8.pdf""" ;
                      <http://www.w3.org/2004/02/skos/core#definition> "A weather station is a facility, either on land or sea, with instruments and equipment for measuring atmospheric conditions to provide information for weather forecasts and to study the weather and climate. The measurements taken include temperature, atmospheric pressure, humidity, wind speed, wind direction, and precipitation amounts. Wind measurements are taken with as few other obstructions as possible, while temperature and humidity measurements are kept free from direct solar radiation, or insolation." .


###  http://www.w3.org/ns/sosa/Platform
sosa:Platform rdfs:subClassOf geo:Feature .


