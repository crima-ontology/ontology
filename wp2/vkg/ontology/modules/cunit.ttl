cquak:MinAmbientTemperature a qudt:QuantityKind ;
    rdfs:label "minimum ambient temperature"@en ;
    skos:definition "The minimum ambient temperature in the environment."@en ;
    rdfs:isDefinedBy <https://w3id.org/crima-ontology/cquak#> .

cquak:MaxAmbientTemperature a qudt:QuantityKind ;
    rdfs:label "maximum ambient temperature"@en ;
    skos:definition "The maximum ambient temperature in the environment."@en ;
    rdfs:isDefinedBy <https://w3id.org/crima-ontology/cquak#> .

cquak:MeanAmbientTemperature a qudt:QuantityKind ;
    rdfs:label "mean ambient temperature"@en ;
    skos:definition "The average value is derived from a set of air temperature measurements that were recorded over a specific time period. "@en ;
    rdfs:isDefinedBy <https://w3id.org/crima-ontology/cquak#> .

