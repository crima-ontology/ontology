@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <https://w3id.org/crima-ontology/cbib#> .

<https://w3id.org/crima-ontology/cbib#> rdf:type owl:Ontology ;
                                               owl:imports dcterms: ,
                                                           bibo: ,
                                                           <http://www.w3.org/2004/02/skos/core> ,
                                                           <http://www.w3.org/ns/dcat> ;
                                               vann:preferredNamespacePrefix "cbib" ;
