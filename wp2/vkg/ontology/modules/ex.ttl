@prefix : <http://example.org/ontology/> .
@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix ccore: <http://www.semanticweb.org/crima/crima-core#> .
@base <http://example.org/ontology/> .

<http://example.org/ontology/> rdf:type owl:Ontology ;
                                owl:imports dbo: ,
                                            <http://www.w3.org/ns/prov-o#> ;
                                vann:preferredNamespacePrefix "ex" ;
                                vann:preferredNamespaceUri "http://example.org/ontology/"^^xsd:anyURI ;
                                voaf:metadataVoc vann: ,
                                                 <http://purl.org/vocommons/voaf> ;
                                voaf:reliesOn dbo: ,
                                              <http://www.w3.org/ns/prov-o#> .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/vocab/vann/preferredNamespacePrefix
vann:preferredNamespacePrefix rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
vann:preferredNamespaceUri rdf:type owl:AnnotationProperty .


###  http://purl.org/vocommons/voaf#metadataVoc
voaf:metadataVoc rdf:type owl:AnnotationProperty .


###  http://purl.org/vocommons/voaf#reliesOn
voaf:reliesOn rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://example.org/ontology/hasCause
:hasCause rdf:type owl:ObjectProperty ;
          rdfs:domain :IffiLandslide ;
          rdfs:range :IFFICause ;
          rdfs:label "has cause"@en .


#################################################################
#    Data properties
#################################################################

###  http://example.org/ontology/activityStateL1
:activityStateL1 rdf:type owl:DatatypeProperty ;
                 rdfs:domain :IFFILandslide ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Landslide state (1st level classification)."@en .


###  http://example.org/ontology/activityStateL2
:activityStateL2 rdf:type owl:DatatypeProperty ;
                 rdfs:domain :IFFILandslide ;
                 rdfs:range xsd:string ;
                 rdfs:comment "More detailed landslide state (2nd level classification)."@en .


###  http://example.org/ontology/areaM2
:areaM2 rdf:type owl:DatatypeProperty ;
        rdfs:domain :IFFILandslide ;
        rdfs:range xsd:double ;
        rdfs:comment "Total area affected by the landslide (m^2); derived from area_calc if available, otherwise from area."@en .


###  http://example.org/ontology/assessmentMethodPrimary
:assessmentMethodPrimary rdf:type owl:DatatypeProperty ;
                         rdfs:domain :IFFILandslide ;
                         rdfs:range xsd:string ;
                         rdfs:comment "Primary methodology used for landslide assessment."@en .


###  http://example.org/ontology/assessmentMethodSecondary
:assessmentMethodSecondary rdf:type owl:DatatypeProperty ;
                           rdfs:domain :IFFILandslide ;
                           rdfs:range xsd:string ;
                           rdfs:comment "Secondary methodology used for landslide assessment."@en .


###  http://example.org/ontology/assessmentMethodTertiary
:assessmentMethodTertiary rdf:type owl:DatatypeProperty ;
                          rdfs:domain :IFFILandslide ;
                          rdfs:range xsd:string ;
                          rdfs:comment "Additional methodology used for landslide assessment."@en .


###  http://example.org/ontology/causeGroup
:causeGroup rdf:type owl:DatatypeProperty ;
            rdfs:domain :IFFICause ;
            rdfs:range xsd:string ;
            rdfs:comment "group this landslide cause belongs to: 'intrinsic', 'physical', 'geomorphological', 'anthropogenic', or 'nd'" ;
            rdfs:label "cause group"@en .


###  http://example.org/ontology/dateReliability
:dateReliability rdf:type owl:DatatypeProperty ;
                 rdfs:domain :IFFILandslide ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Flag indicating reliability of the event date; mostly null and not clearly correlated with completeness of year/month/day."@en .


###  http://example.org/ontology/landUse
:landUse rdf:type owl:DatatypeProperty ;
         rdfs:domain :IFFILandslide ;
         rdfs:range xsd:string ;
         rdfs:comment "Land use of the affected slope area, including agricultural, forestry, or anthropogenic use."@en .


###  http://example.org/ontology/lithology
:lithology rdf:type owl:DatatypeProperty ;
           rdfs:domain :IFFILandslide ;
           rdfs:range xsd:string ;
           rdfs:comment "Dominant lithological composition of the units involved in the landslide."@en .


###  http://example.org/ontology/lithotechnics
:lithotechnics rdf:type owl:DatatypeProperty ;
               rdfs:domain :IFFILandslide ;
               rdfs:range xsd:string ;
               rdfs:comment "Geomechanical behavior of the material involved in the landslide."@en .


###  http://example.org/ontology/materialPrimary
:materialPrimary rdf:type owl:DatatypeProperty ;
                 rdfs:domain :IFFILandslide ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Primary material involved in the landslide, referring to its pre-event condition."@en .


###  http://example.org/ontology/materialSecondary
:materialSecondary rdf:type owl:DatatypeProperty ;
                   rdfs:domain :IFFILandslide ;
                   rdfs:range xsd:string ;
                   rdfs:comment "Secondary material involved in the landslide."@en .


###  http://example.org/ontology/movementTypeL1
:movementTypeL1 rdf:type owl:DatatypeProperty ;
                rdfs:domain :IFFILandslide ;
                rdfs:range xsd:string ;
                rdfs:comment "Primary movement type (1st level classification) describing the landslide mechanism."@en .


###  http://example.org/ontology/movementTypeL2Primary
:movementTypeL2Primary rdf:type owl:DatatypeProperty ;
                       rdfs:domain :IFFILandslide ;
                       rdfs:range xsd:string ;
                       rdfs:comment "Primary value of the second-level movement classification (more detailed mechanism)."@en .


###  http://example.org/ontology/movementTypeL2Secondary
:movementTypeL2Secondary rdf:type owl:DatatypeProperty ;
                         rdfs:domain :IFFILandslide ;
                         rdfs:range xsd:string ;
                         rdfs:comment "Secondary value of the second-level movement classification."@en .


###  http://example.org/ontology/shpCode
:shpCode rdf:type owl:DatatypeProperty ;
         rdfs:domain :IFFICause ;
         rdfs:range xsd:string ;
         rdfs:comment "textual identifier associated to the landslide cause, from the landslide shapefile" ;
         rdfs:label "shapefile code"@en .


###  http://example.org/ontology/structure
:structure rdf:type owl:DatatypeProperty ;
           rdfs:domain :IFFILandslide ;
           rdfs:range xsd:string ;
           rdfs:comment "Internal structural organization of the rock mass."@en .


###  http://example.org/ontology/style
:style rdf:type owl:DatatypeProperty ;
       rdfs:domain :IFFILandslide ;
       rdfs:range xsd:string ;
       rdfs:comment "Style of the landslide, representing combinations or repetitions of movement mechanisms within the same event."@en .


###  http://example.org/ontology/velocityPrimary
:velocityPrimary rdf:type owl:DatatypeProperty ;
                 rdfs:domain :IFFILandslide ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Primary velocity class, based on IUGS/WGL (1995) movement intensity scale."@en .


###  http://example.org/ontology/velocitySecondary
:velocitySecondary rdf:type owl:DatatypeProperty ;
                   rdfs:domain :IFFILandslide ;
                   rdfs:range xsd:string ;
                   rdfs:comment "Secondary velocity class."@en .


###  http://example.org/ontology/volumeM3
:volumeM3 rdf:type owl:DatatypeProperty ;
          rdfs:domain :IFFILandslide ;
          rdfs:range xsd:double ;
          rdfs:comment "Final volume of displaced material (m^3), computed or estimated."@en .


###  http://example.org/ontology/waterContentPrimary
:waterContentPrimary rdf:type owl:DatatypeProperty ;
                     rdfs:domain :IFFILandslide ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Primary water content classification of the material prior to movement."@en .


###  http://example.org/ontology/waterContentSecondary
:waterContentSecondary rdf:type owl:DatatypeProperty ;
                       rdfs:domain :IFFILandslide ;
                       rdfs:range xsd:string ;
                       rdfs:comment "Secondary water content classification."@en .


