@prefix : <http://example.org/ontology/> .
@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix csrc: <http://www.semanticweb.org/crima/crima-source#> .
@prefix ccore: <http://www.semanticweb.org/crima/crima-core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix schema: <http://schema.org/> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@base <http://example.org/ontology/> .

##############################################################
#  Ontology declaration
##############################################################

<http://example.org/ontology/> rdf:type owl:Ontology ;
    vann:preferredNamespacePrefix "ex" ;
    vann:preferredNamespaceUri "http://example.org/ontology/"^^xsd:anyURI ;
    voaf:metadataVoc vann: , <http://purl.org/vocommons/voaf> ;
    voaf:reliesOn
        dbo: ,
        <http://www.w3.org/ns/sosa/> ,
        <http://www.opengis.net/ont/geosparql#> ,
        <http://www.semanticweb.org/crima/crima-core#> ,
        <http://www.semanticweb.org/crima/crima-source#> ;
    owl:imports
        dbo: ,
        <http://www.w3.org/ns/sosa/> .


##############################################################
#  Annotation properties (external, declared for clarity)
##############################################################

vann:preferredNamespacePrefix rdf:type owl:AnnotationProperty .
vann:preferredNamespaceUri    rdf:type owl:AnnotationProperty .
voaf:metadataVoc              rdf:type owl:AnnotationProperty .
voaf:reliesOn                 rdf:type owl:AnnotationProperty .

##############################################################
#  Classes
##############################################################

# --- Administrative / territorial ---

:HealthDistrict rdf:type owl:Class ;
    rdfs:label "Health District"@en ;
    rdfs:comment "An administrative health district within the province of Bolzano/Bozen." .

:HealthRegion rdf:type owl:Class ;
    rdfs:label "Health Region"@en ;
    rdfs:comment "An administrative health region within the province of Bolzano/Bozen." .

:RoadNetwork rdf:type owl:Class ;
    rdfs:label "Road Network"@en ;
    rdfs:comment "A linear road-network infrastructure feature from the BZ infrastructure dataset." .

# --- Hazard causes ---

:IFFICause rdf:type owl:Class ;
    rdfs:subClassOf skos:Concept ;
    rdfs:label "IFFI Cause"@en ;
    rdfs:comment "A landslide cause from the IFFI (Inventario dei Fenomeni Franosi in Italia) cause dictionary." .

# --- Source classes ---

csrc:IFFI-Landslide rdf:type owl:Class ;
    rdfs:subClassOf ccore:Hazard ;
    rdfs:label "IFFI Landslide"@en ;
    rdfs:comment "A landslide recorded in the Italian Landslide Inventory (IFFI), represented as a point at the highest initiation point (PIFF)."@en .

csrc:EffisWildfire rdf:type owl:Class ;
    rdfs:subClassOf ccore:Hazard ;
    rdfs:label "EFFIS Wildfire"@en ;
    rdfs:comment "A wildfire event recorded in the European Forest Fire Information System (EFFIS)." .


##############################################################
#  Object Properties
##############################################################

# --- Administrative location ---

:locatedInMunicipality rdf:type owl:ObjectProperty ;
    rdfs:label "located in municipality"@en ;
    rdfs:range dbo:Municipality ;
    rdfs:comment "Relates a feature to the municipality it is spatially located in." .

:locatedInRegion rdf:type owl:ObjectProperty ;
    rdfs:label "located in region"@en ;
    rdfs:range :HealthRegion ;
    rdfs:comment "Relates a feature to the health region it belongs to." .

:inDistrict rdf:type owl:ObjectProperty ;
    rdfs:label "in district"@en ;
    rdfs:range dbo:District ;
    rdfs:comment "Relates a municipality to its administrative district." .

:inHealthDistrict rdf:type owl:ObjectProperty ;
    rdfs:label "in health district"@en ;
    rdfs:range :HealthDistrict ;
    rdfs:comment "Relates a municipality to its health district." .

:inHealthRegion rdf:type owl:ObjectProperty ;
    rdfs:label "in health region"@en ;
    rdfs:range :HealthRegion ;
    rdfs:comment "Relates a health district to its parent health region." .

# --- Hydrology ---

:isLocatedOnWatercourse rdf:type owl:ObjectProperty ;
    rdfs:label "is located on watercourse"@en ;
    rdfs:range dbo:Watercourse ;
    rdfs:comment "Relates a hydrological station or water derivation point to the watercourse it lies on." .

:isDrainedBy rdf:type owl:ObjectProperty ;
    rdfs:label "is drained by"@en ;
    rdfs:range dbo:Watercourse ;
    rdfs:comment "Relates a drainage basin to the main watercourse draining it." .

:hasParentWatercourse rdf:type owl:ObjectProperty ;
    rdfs:label "has parent watercourse"@en ;
    rdfs:domain dbo:Watercourse ;
    rdfs:range dbo:Watercourse ;
    rdfs:comment "Relates a tributary watercourse to its parent watercourse." .

:isPartOf rdf:type owl:ObjectProperty ;
    rdfs:label "is part of"@en ;
    rdfs:comment "Mereological part-of relation; used to relate watercourses to drainage basins, and lakes to drainage basins." .

# --- Road / infrastructure ---

:roadSegmentFrom rdf:type owl:ObjectProperty ;
    rdfs:label "road segment from"@en ;
    rdfs:comment "Origin OSM node of a road segment." .

:roadSegmentTo rdf:type owl:ObjectProperty ;
    rdfs:label "road segment to"@en ;
    rdfs:comment "Destination OSM node of a road segment." .


##############################################################
#  Datatype Properties
##############################################################

# ---- IFFICause ----

:shpCode rdf:type owl:DatatypeProperty ;
    rdfs:domain :IFFICause ;
    rdfs:range xsd:string ;
    rdfs:label "shapefile code"@en ;
    rdfs:comment "Textual identifier associated to the landslide cause, from the IFFI shapefile." .

:causeGroup rdf:type owl:DatatypeProperty ;
    rdfs:domain :IFFICause ;
    rdfs:range xsd:string ;
    rdfs:label "cause group"@en ;
    rdfs:comment "Group this landslide cause belongs to: 'intrinsic', 'physical', 'geomorphological', 'anthropogenic', or 'nd'." .

# ---- IFFI Landslide ----

:dateReliability rdf:type owl:DatatypeProperty ;
    rdfs:domain csrc:IFFI-Landslide ;
    rdfs:range xsd:string ;
    rdfs:label "date reliability"@en ;
    rdfs:comment "Flag indicating reliability of the event date." .

:movementTypeL1 rdf:type owl:DatatypeProperty ;
    rdfs:domain csrc:IFFI-Landslide ;
    rdfs:range xsd:string ;
    rdfs:comment "Primary movement type (1st level classification)."@en .

:movementTypeL2Primary rdf:type owl:DatatypeProperty ;
    rdfs:domain csrc:IFFI-Landslide ;
    rdfs:range xsd:string ;
    rdfs:comment "Primary value of the second-level movement classification."@en .

:movementTypeL2Secondary rdf:type owl:DatatypeProperty ;
    rdfs:domain csrc:IFFI-Landslide ;
    rdfs:range xsd:string ;
    rdfs:comment "Secondary value of the second-level movement classification."@en .

:style rdf:type owl:DatatypeProperty ;
    rdfs:domain csrc:IFFI-Landslide ;
    rdfs:range xsd:string ;
    rdfs:comment "Style of the landslide (combinations/repetitions of movement mechanisms)."@en .

:volumeM3 rdf:type owl:DatatypeProperty ;
    rdfs:domain csrc:IFFI-Landslide ;
    rdfs:range xsd:double ;
    rdfs:comment "Final volume of displaced material (m³)."@en .

:materialPrimary rdf:type owl:DatatypeProperty ;
    rdfs:domain csrc:IFFI-Landslide ;
    rdfs:range xsd:string ;
    rdfs:comment "Primary material involved in the landslide (pre-event condition)."@en .

:materialSecondary rdf:type owl:DatatypeProperty ;
    rdfs:domain csrc:IFFI-Landslide ;
    rdfs:range xsd:string ;
    rdfs:comment "Secondary material involved in the landslide."@en .

:activityStateL1 rdf:type owl:DatatypeProperty ;
    rdfs:domain csrc:IFFI-Landslide ;
    rdfs:range xsd:string ;
    rdfs:comment "Landslide activity state (1st level classification)."@en .

:activityStateL2 rdf:type owl:DatatypeProperty ;
    rdfs:domain csrc:IFFI-Landslide ;
    rdfs:range xsd:string ;
    rdfs:comment "Landslide activity state (2nd level classification)."@en .

:velocityPrimary rdf:type owl:DatatypeProperty ;
    rdfs:domain csrc:IFFI-Landslide ;
    rdfs:range xsd:string ;
    rdfs:comment "Primary velocity class (IUGS/WGL 1995 scale)."@en .

:velocitySecondary rdf:type owl:DatatypeProperty ;
    rdfs:domain csrc:IFFI-Landslide ;
    rdfs:range xsd:string ;
    rdfs:comment "Secondary velocity class."@en .

:waterContentPrimary rdf:type owl:DatatypeProperty ;
    rdfs:domain csrc:IFFI-Landslide ;
    rdfs:range xsd:string ;
    rdfs:comment "Primary water content classification prior to movement."@en .

:waterContentSecondary rdf:type owl:DatatypeProperty ;
    rdfs:domain csrc:IFFI-Landslide ;
    rdfs:range xsd:string ;
    rdfs:comment "Secondary water content classification."@en .

:landUse rdf:type owl:DatatypeProperty ;
    rdfs:domain csrc:IFFI-Landslide ;
    rdfs:range xsd:string ;
    rdfs:comment "Land use of the affected slope area."@en .

:lithology rdf:type owl:DatatypeProperty ;
    rdfs:domain csrc:IFFI-Landslide ;
    rdfs:range xsd:string ;
    rdfs:comment "Dominant lithological composition of units involved in the landslide."@en .

:lithotechnics rdf:type owl:DatatypeProperty ;
    rdfs:domain csrc:IFFI-Landslide ;
    rdfs:range xsd:string ;
    rdfs:comment "Geomechanical behaviour of material involved in the landslide."@en .

:structure rdf:type owl:DatatypeProperty ;
    rdfs:domain csrc:IFFI-Landslide ;
    rdfs:range xsd:string ;
    rdfs:comment "Internal structural organisation of the rock mass."@en .

:assessmentMethodPrimary rdf:type owl:DatatypeProperty ;
    rdfs:domain csrc:IFFI-Landslide ;
    rdfs:range xsd:string ;
    rdfs:comment "Primary methodology used for landslide assessment."@en .

:assessmentMethodSecondary rdf:type owl:DatatypeProperty ;
    rdfs:domain csrc:IFFI-Landslide ;
    rdfs:range xsd:string ;
    rdfs:comment "Secondary methodology used for landslide assessment."@en .

:assessmentMethodTertiary rdf:type owl:DatatypeProperty ;
    rdfs:domain csrc:IFFI-Landslide ;
    rdfs:range xsd:string ;
    rdfs:comment "Tertiary methodology used for landslide assessment."@en .

# ---- Administrative / geographic ----

:istatCode rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string ;
