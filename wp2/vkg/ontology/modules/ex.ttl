              rdfs:range xsd:double ;
              rdfs:comment "Glacier area as measured in the survey (m²)." ;
              rdfs:label "surveyed area"@en .


###  http://example.org/ontology/temperatureMax
:temperatureMax rdf:type owl:DatatypeProperty ;
                rdfs:range xsd:decimal ;
                rdfs:comment "Maximum temperature (Â°C)." ;
