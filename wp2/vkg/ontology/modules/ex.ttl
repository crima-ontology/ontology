:populationCommuters rdf:type owl:DatatypeProperty ;
                     rdfs:range xsd:double ;
                     rdfs:comment "Estimated commuter population in the area." ;
                     rdfs:label "commuter population"@en .


###  http://example.org/ontology/populationDay
:populationDay rdf:type owl:DatatypeProperty ;
               rdfs:range xsd:double ;
               rdfs:comment "Estimated daytime population present in the area." ;
               rdfs:label "daytime population"@en .


###  http://example.org/ontology/precipitation
:precipitation rdf:type owl:DatatypeProperty ;
               rdfs:range xsd:decimal ;
               rdfs:comment "Precipitation (mm)." ;
               rdfs:label "precipitation"@en .


###  http://example.org/ontology/residentialBuildings
:residentialBuildings rdf:type owl:DatatypeProperty ;
                      rdfs:range xsd:integer ;
                      rdfs:label "residential buildings"@en .


###  http://example.org/ontology/roadType
:roadType rdf:type owl:DatatypeProperty ;
          rdfs:range xsd:string ;
          rdfs:label "road type"@en .


###  http://example.org/ontology/shapeLength
:shapeLength rdf:type owl:DatatypeProperty ;
             rdfs:range xsd:double ;
             rdfs:comment "Length of a linear feature geometry (metres)." ;
             rdfs:label "shape length"@en .


###  http://example.org/ontology/shpCode
:shpCode rdf:type owl:DatatypeProperty ;
