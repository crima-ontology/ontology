@prefix : <http://example.org/ontology/> .
@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix csrc: <http://www.semanticweb.org/crima/crima-source#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix ccore: <http://www.semanticweb.org/crima/crima-core#> .
@prefix schema: <http://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix sosa-common: <http://www.w3.org/ns/sosa/common/> .
@base <http://example.org/ontology/> .

<http://example.org/ontology/> rdf:type owl:Ontology ;
                                owl:imports dbo: ,
                                            dcterms: ,
                                            sosa-common: ;
                                vann:preferredNamespacePrefix "ex" ;
                                vann:preferredNamespaceUri "http://example.org/ontology/"^^xsd:anyURI ;
                                voaf:metadataVoc vann: ,
                                                 <http://purl.org/vocommons/voaf> ;
                                voaf:reliesOn dbo: ,
                                              dcterms: ,
                                              geo: ,
                                              ccore: ,
                                              csrc: ,
                                              sosa-common: .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/vocab/vann/preferredNamespacePrefix
vann:preferredNamespacePrefix rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
vann:preferredNamespaceUri rdf:type owl:AnnotationProperty .


###  http://purl.org/vocommons/voaf#metadataVoc
voaf:metadataVoc rdf:type owl:AnnotationProperty .


###  http://purl.org/vocommons/voaf#reliesOn
voaf:reliesOn rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://example.org/ontology/hasParentWatercourse
:hasParentWatercourse rdf:type owl:ObjectProperty ;
                      rdfs:comment "Relates a tributary watercourse to its parent watercourse." ;
                      rdfs:label "has parent watercourse"@en .


###  http://example.org/ontology/isDrainedBy
:isDrainedBy rdf:type owl:ObjectProperty ;
             rdfs:comment "Relates a drainage basin to the main watercourse draining it." ;
             rdfs:label "is drained by"@en .


###  http://example.org/ontology/roadSegmentFrom
:roadSegmentFrom rdf:type owl:ObjectProperty ;
                 rdfs:comment "Origin OSM node of a road segment." ;
                 rdfs:label "road segment from"@en .


###  http://example.org/ontology/roadSegmentTo
:roadSegmentTo rdf:type owl:ObjectProperty ;
               rdfs:comment "Destination OSM node of a road segment." ;
               rdfs:label "road segment to"@en .


#################################################################
#    Data properties
#################################################################

###  http://example.org/ontology/accessHospitalAvg
:accessHospitalAvg rdf:type owl:DatatypeProperty ;
                   rdfs:range xsd:double ;
                   rdfs:label "average hospital accessibility"@en .


###  http://example.org/ontology/accessHospitalMax
:accessHospitalMax rdf:type owl:DatatypeProperty ;
                   rdfs:range xsd:double ;
                   rdfs:label "maximum hospital accessibility"@en .


###  http://example.org/ontology/activityStateL1
:activityStateL1 rdf:type owl:DatatypeProperty ;
                 rdfs:domain csrc:IFFI-Landslide ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Landslide activity state (1st level classification)."@en .


###  http://example.org/ontology/activityStateL2
:activityStateL2 rdf:type owl:DatatypeProperty ;
                 rdfs:domain csrc:IFFI-Landslide ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Landslide activity state (2nd level classification)."@en .


###  http://example.org/ontology/altitudeMax
:altitudeMax rdf:type owl:DatatypeProperty ;
             rdfs:range xsd:integer ;
             rdfs:label "maximum altitude"@en .


###  http://example.org/ontology/altitudeMedian
:altitudeMedian rdf:type owl:DatatypeProperty ;
                rdfs:range xsd:integer ;
                rdfs:label "median altitude"@en .


###  http://example.org/ontology/altitudeMin
:altitudeMin rdf:type owl:DatatypeProperty ;
             rdfs:range xsd:integer ;
             rdfs:label "minimum altitude"@en .


###  http://example.org/ontology/aspectClass
:aspectClass rdf:type owl:DatatypeProperty ;
             rdfs:range xsd:string ;
             rdfs:comment "Dominant aspect (cardinal direction) of the glacier." ;
             rdfs:label "aspect class"@en .


###  http://example.org/ontology/assessmentMethodPrimary
:assessmentMethodPrimary rdf:type owl:DatatypeProperty ;
                         rdfs:domain csrc:IFFI-Landslide ;
                         rdfs:range xsd:string ;
                         rdfs:comment "Primary methodology used for landslide assessment."@en .


###  http://example.org/ontology/assessmentMethodSecondary
:assessmentMethodSecondary rdf:type owl:DatatypeProperty ;
                           rdfs:domain csrc:IFFI-Landslide ;
                           rdfs:range xsd:string ;
                           rdfs:comment "Secondary methodology used for landslide assessment."@en .


###  http://example.org/ontology/assessmentMethodTertiary
:assessmentMethodTertiary rdf:type owl:DatatypeProperty ;
                          rdfs:domain csrc:IFFI-Landslide ;
                          rdfs:range xsd:string ;
                          rdfs:comment "Tertiary methodology used for landslide assessment."@en .


###  http://example.org/ontology/authorizedAmount
:authorizedAmount rdf:type owl:DatatypeProperty ;
                  rdfs:range xsd:double ;
                  rdfs:comment "Authorized water derivation amount." ;
                  rdfs:label "authorized amount"@en .


###  http://example.org/ontology/basinArea
:basinArea rdf:type owl:DatatypeProperty ;
           rdfs:range xsd:double ;
           rdfs:label "basin area"@en .


###  http://example.org/ontology/bathing
:bathing rdf:type owl:DatatypeProperty ;
         rdfs:range xsd:boolean ;
         rdfs:comment "Whether bathing is permitted in this lake." ;
         rdfs:label "bathing"@en .


###  http://example.org/ontology/businessUnitEmployees
:businessUnitEmployees rdf:type owl:DatatypeProperty ;
                       rdfs:range xsd:integer ;
                       rdfs:label "business unit employees"@en .


###  http://example.org/ontology/businessUnits
:businessUnits rdf:type owl:DatatypeProperty ;
               rdfs:range xsd:integer ;
               rdfs:label "business units"@en .


###  http://example.org/ontology/category
:category rdf:type owl:DatatypeProperty ;
          rdfs:range xsd:integer ;
          rdfs:comment "Infrastructure node category code." ;
          rdfs:label "category"@en .


###  http://example.org/ontology/causeGroup
:causeGroup rdf:type owl:DatatypeProperty ;
            rdfs:domain :IFFICause ;
            rdfs:range xsd:string ;
            rdfs:comment "Group this landslide cause belongs to: 'intrinsic', 'physical', 'geomorphological', 'anthropogenic', or 'nd'." ;
            rdfs:label "cause group"@en .


###  http://example.org/ontology/cgiId
:cgiId rdf:type owl:DatatypeProperty ;
       rdfs:range xsd:string ;
       rdfs:comment "Identifier in the Catasto Ghiacciai Italiani." ;
       rdfs:label "CGI identifier"@en .


###  http://example.org/ontology/companiesCount
:companiesCount rdf:type owl:DatatypeProperty ;
                rdfs:range xsd:integer ;
                rdfs:label "companies count"@en .


###  http://example.org/ontology/companyEmployees
:companyEmployees rdf:type owl:DatatypeProperty ;
                  rdfs:range xsd:integer ;
                  rdfs:label "company employees"@en .


###  http://example.org/ontology/corineCodeLevel1
:corineCodeLevel1 rdf:type owl:DatatypeProperty ;
                  rdfs:range xsd:string ;
                  rdfs:label "CORINE code level 1"@en .


###  http://example.org/ontology/corineCodeLevel2
:corineCodeLevel2 rdf:type owl:DatatypeProperty ;
                  rdfs:range xsd:string ;
                  rdfs:label "CORINE code level 2"@en .


###  http://example.org/ontology/corineCodeLevel3
:corineCodeLevel3 rdf:type owl:DatatypeProperty ;
                  rdfs:range xsd:string ;
                  rdfs:label "CORINE code level 3"@en .


###  http://example.org/ontology/dateReliability
:dateReliability rdf:type owl:DatatypeProperty ;
                 rdfs:domain csrc:IFFI-Landslide ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Flag indicating reliability of the event date." ;
                 rdfs:label "date reliability"@en .


###  http://example.org/ontology/declaration
:declaration rdf:type owl:DatatypeProperty ;
             rdfs:range xsd:string ;
             rdfs:comment "Type of official disaster declaration." ;
             rdfs:label "declaration"@en .


###  http://example.org/ontology/derivationDepth
:derivationDepth rdf:type owl:DatatypeProperty ;
                 rdfs:range xsd:double ;
                 rdfs:label "derivation depth"@en .


###  http://example.org/ontology/derivationType
:derivationType rdf:type owl:DatatypeProperty ;
                rdfs:range xsd:string ;
                rdfs:label "derivation type"@en .


###  http://example.org/ontology/dischargeValue
:dischargeValue rdf:type owl:DatatypeProperty ;
                rdfs:range xsd:double ;
                rdfs:comment "River discharge value (m³/s)." ;
                rdfs:label "discharge value"@en .


###  http://example.org/ontology/distanceMinRoadHospitalAccess
:distanceMinRoadHospitalAccess rdf:type owl:DatatypeProperty ;
                               rdfs:range xsd:double ;
                               rdfs:comment "Minimum distance in metres from a road to the nearest hospital accessibility hexagon." ;
                               rdfs:label "minimum road-to-hospital distance"@en .


###  http://example.org/ontology/districtID
:districtID rdf:type owl:DatatypeProperty ;
            rdfs:label "district ID"@en .


###  http://example.org/ontology/elderlyFacilities
:elderlyFacilities rdf:type owl:DatatypeProperty ;
                   rdfs:range xsd:integer ;
                   rdfs:label "elderly care facilities"@en .


###  http://example.org/ontology/eventOrigin
:eventOrigin rdf:type owl:DatatypeProperty ;
             rdfs:range xsd:string ;
             rdfs:label "event origin"@en .


###  http://example.org/ontology/familiesCount
:familiesCount rdf:type owl:DatatypeProperty ;
               rdfs:range xsd:integer ;
               rdfs:label "families count"@en .


###  http://example.org/ontology/familiesSize1
:familiesSize1 rdf:type owl:DatatypeProperty ;
               rdfs:range xsd:integer ;
               rdfs:label "families of size 1"@en .


###  http://example.org/ontology/familiesSize2
:familiesSize2 rdf:type owl:DatatypeProperty ;
               rdfs:range xsd:integer ;
               rdfs:label "families of size 2"@en .


###  http://example.org/ontology/familiesSize3
:familiesSize3 rdf:type owl:DatatypeProperty ;
               rdfs:range xsd:integer ;
               rdfs:label "families of size 3"@en .


###  http://example.org/ontology/familiesSize4
:familiesSize4 rdf:type owl:DatatypeProperty ;
               rdfs:range xsd:integer ;
               rdfs:label "families of size 4"@en .


###  http://example.org/ontology/familiesSize5
:familiesSize5 rdf:type owl:DatatypeProperty ;
               rdfs:range xsd:integer ;
               rdfs:label "families of size 5"@en .


###  http://example.org/ontology/familiesSize6plus
:familiesSize6plus rdf:type owl:DatatypeProperty ;
                   rdfs:range xsd:integer ;
                   rdfs:label "families of size 6+"@en .


###  http://example.org/ontology/familiesWithChildren
:familiesWithChildren rdf:type owl:DatatypeProperty ;
                      rdfs:range xsd:integer ;
                      rdfs:label "families with children"@en .


###  http://example.org/ontology/hierarchy
:hierarchy rdf:type owl:DatatypeProperty ;
           rdfs:range xsd:integer ;
           rdfs:comment "Hierarchical order of a watercourse in the drainage network." ;
           rdfs:label "hierarchy"@en .


###  http://example.org/ontology/hospitalsCount
:hospitalsCount rdf:type owl:DatatypeProperty ;
                rdfs:range xsd:integer ;
                rdfs:label "hospitals count"@en .


###  http://example.org/ontology/landUse
:landUse rdf:type owl:DatatypeProperty ;
         rdfs:domain csrc:IFFI-Landslide ;
         rdfs:range xsd:string ;
         rdfs:comment "Land use of the affected slope area."@en .


###  http://example.org/ontology/length
:length rdf:type owl:DatatypeProperty ;
        rdfs:range xsd:double ;
        rdfs:comment "Length of a feature (metres)." ;
        rdfs:label "length"@en .


###  http://example.org/ontology/lithology
:lithology rdf:type owl:DatatypeProperty ;
           rdfs:domain csrc:IFFI-Landslide ;
           rdfs:range xsd:string ;
           rdfs:comment "Dominant lithological composition of units involved in the landslide."@en .


###  http://example.org/ontology/lithotechnics
:lithotechnics rdf:type owl:DatatypeProperty ;
               rdfs:domain csrc:IFFI-Landslide ;
               rdfs:range xsd:string ;
               rdfs:comment "Geomechanical behaviour of material involved in the landslide."@en .


###  http://example.org/ontology/magnitude
:magnitude rdf:type owl:DatatypeProperty ;
           rdfs:range xsd:double ;
           rdfs:label "magnitude"@en .


###  http://example.org/ontology/magnitudeScale
:magnitudeScale rdf:type owl:DatatypeProperty ;
                rdfs:range xsd:string ;
                rdfs:label "magnitude scale"@en .


###  http://example.org/ontology/materialPrimary
:materialPrimary rdf:type owl:DatatypeProperty ;
                 rdfs:domain csrc:IFFI-Landslide ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Primary material involved in the landslide (pre-event condition)."@en .


###  http://example.org/ontology/materialSecondary
:materialSecondary rdf:type owl:DatatypeProperty ;
                   rdfs:domain csrc:IFFI-Landslide ;
                   rdfs:range xsd:string ;
                   rdfs:comment "Secondary material involved in the landslide."@en .


###  http://example.org/ontology/month
:month rdf:type owl:DatatypeProperty ;
       rdfs:range xsd:integer ;
       rdfs:label "month"@en .


###  http://example.org/ontology/movementTypeL1
:movementTypeL1 rdf:type owl:DatatypeProperty ;
                rdfs:domain csrc:IFFI-Landslide ;
                rdfs:range xsd:string ;
                rdfs:comment "Primary movement type (1st level classification)."@en .


###  http://example.org/ontology/movementTypeL2Primary
:movementTypeL2Primary rdf:type owl:DatatypeProperty ;
                       rdfs:domain csrc:IFFI-Landslide ;
                       rdfs:range xsd:string ;
                       rdfs:comment "Primary value of the second-level movement classification."@en .


###  http://example.org/ontology/movementTypeL2Secondary
:movementTypeL2Secondary rdf:type owl:DatatypeProperty ;
                         rdfs:domain csrc:IFFI-Landslide ;
                         rdfs:range xsd:string ;
                         rdfs:comment "Secondary value of the second-level movement classification."@en .


###  http://example.org/ontology/nighttimePopulation
:nighttimePopulation rdf:type owl:DatatypeProperty ;
                     rdfs:range xsd:double ;
                     rdfs:comment "Estimated nighttime (resident) population in the area." ;
                     rdfs:label "nighttime population"@en .


###  http://example.org/ontology/oneWay
:oneWay rdf:type owl:DatatypeProperty ;
        rdfs:range xsd:boolean ;
        rdfs:label "one way"@en .


