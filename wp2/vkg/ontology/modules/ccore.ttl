  rdf:rest _:genid29 .

_:genid29 a rdf:List;
  rdf:first ctlo:Process;
  rdf:rest rdf:nil .

:Commitment-based a owl:Class;
  rdfs:subClassOf :EcosystemService;
  dcterms:references "Adamo, G., & Willis, M. (2022, May). Conceptual integration for social-ecological systems: An ontological approach. In International Conference on Research Challenges in Information Science (pp. 321-337). Cham: Springer International Publishing.";
  rdfs:label "CommitmentBasedService" .

:EcosystemService a owl:Class;
  dcterms:references "Adamo, G., & Willis, M. (2022, May). Conceptual integration for social-ecological systems: An ontological approach. In International Conference on Research Challenges in Information Science (pp. 321-337). Cham: Springer International Publishing.",
    "Haines-Young, R., & Potschin, M. (2010). The links between biodiversity, ecosystem services and human well-being. Ecosystem Ecology: a new synthesis, 1, 110-139.",
    "Millennium ecosystem assessment, M. E. A. (2005). Ecosystems and human well-being (Vol. 5, p. 563). Washington, DC: Island press.",
    "Potschin, M., & Haines-Young, R. (2016). Defining and measuring ecosystem services. In Routledge handbook of ecosystem services (pp. 25-44). Routledge.";
  rdfs:comment "EcosystemService is the benefit/outcome that natural ecosystems provide to humans, such as health and well-being, and then is useful for humans due to its value. EcosystemService is included in the ecosystem service (ESs) cascade.";
  rdfs:label "EcosystemService" .

:ElementAtRisk a owl:Class;
  rdfs:subClassOf _:genid31, _:genid32;
  rdfs:comment """ElementAtRisk(O) -->
∃ I, P. impactsOn(I, O), dpo:resultOf(I, P),
threatPerdurant(O, P) .""",
    "We say that an element is 'at risk' with respect to a certain threat perdurant if it is a service or a physical endurant for which an impact has been documented that results from the same threat perdurant and impacts on that element." .

