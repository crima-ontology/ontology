                                                                <http://purl.org/vocommons/voaf> ;
                                               voaf:specializes <http://www.opengis.net/ont/geosparql> ,
                                                                <http://www.w3.org/2004/02/skos/core> ,
                                                                sosa-common: .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/creator
dcterms:creator rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/crima/crima-ecv#isProductOf
:isProductOf rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf sosa:isPropertyOf .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/crima/crima-ecv#ECV-domain
:ECV-domain rdf:type owl:Class ;
            rdfs:subClassOf skos:Concept ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty skos:inScheme ;
                              owl:allValuesFrom :EssentialClimaticVariables
                            ] .


###  http://www.semanticweb.org/crima/crima-ecv#ECV-product
:ECV-product rdf:type owl:Class ;
             rdfs:subClassOf skos:Concept ,
                             sosa:Property ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty qudt:hasUnit ;
                               owl:someValuesFrom cunit:Unit
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :isProductOf ;
                               owl:someValuesFrom :ECV-variable
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty skos:inScheme ;
                               owl:allValuesFrom :EssentialClimaticVariables
                             ] .


###  http://www.semanticweb.org/crima/crima-ecv#ECV-subdomain
:ECV-subdomain rdf:type owl:Class ;
               rdfs:subClassOf skos:Concept ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty skos:broader ;
                                 owl:allValuesFrom :ECV-domain
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty skos:inScheme ;
                                 owl:allValuesFrom :EssentialClimaticVariables
                               ] .


###  http://www.semanticweb.org/crima/crima-ecv#ECV-variable
:ECV-variable rdf:type owl:Class ;
              rdfs:subClassOf geo:Feature ,
                              skos:Concept ,
                              sosa:FeatureOfInterest ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty skos:broader ;
                                owl:allValuesFrom :ECV-subdomain
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty skos:inScheme ;
                                owl:allValuesFrom :EssentialClimaticVariables
                              ] .


###  http://www.semanticweb.org/crima/crima-ecv#EssentialClimaticVariables
:EssentialClimaticVariables rdf:type owl:Class ;
                            rdfs:subClassOf skos:ConceptScheme ;
                            dcterms:creator "World Meteorological Organization (WMO); Intergovernmental Oceanographic Commission of the United Nations Educational, Scientific and Cultural Organization (IOC-UNESCO); International Science Council (ISC); United Nations Environment Programme (UNEP); Copernicus Climate Change Service (C3S)" ;
                            dcterms:source "https://library.wmo.int/records/item/58111-the-2022-gcos-ecvs-requirements?offset=8" ;
                            rdfs:comment "An Essential Climate Variable (ECV) is a physical, chemical or biological variable or a group of linked variables that critically contributes to the characterization of Earth's climate. GCOS currently specifies 55 ECVs. ECV datasets provide the empirical evidence needed to understand and predict the evolution of climate, to guide mitigation and adaptation measures, to assess risks and enable attribution of climate events to underlying causes, and to underpin climate services. They are required to support the work of the UNFCCC and the IPCC." ;
                            rdfs:isDefinedBy """GCOS-245 \"The 2022 GCOS ECVs Requirements\"
2022 edition - Updated in 2025""" .


