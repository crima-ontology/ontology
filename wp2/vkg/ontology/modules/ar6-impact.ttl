<https://w3id.org/crima-ontology/ar6-impact#> rdf:type owl:Ontology ;
                                                      owl:imports cclc: ,
                                                                  <http://www.w3.org/2004/02/skos/core> ;
                                                      vann:preferredNamespacePrefix "ar6-impact" ;
                                                      vann:preferredNamespaceUri "https://w3id.org/crima-ontology/ar6-impact#"^^xsd:anyURI ;
