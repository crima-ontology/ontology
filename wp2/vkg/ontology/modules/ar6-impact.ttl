###  http://purl.org/vocab/vann/preferredNamespacePrefix
vann:preferredNamespacePrefix rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
vann:preferredNamespaceUri rdf:type owl:AnnotationProperty .


###  http://purl.org/vocommons/voaf#extends
voaf:extends rdf:type owl:AnnotationProperty .


###  http://purl.org/vocommons/voaf#specializes
voaf:specializes rdf:type owl:AnnotationProperty .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/crima/ipcc-ar6-impacts#Impact-cluster
:Impact-cluster rdf:type owl:Class ;
                rdfs:subClassOf skos:Concept ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty skos:broader ;
                                  owl:allValuesFrom :Impact-type
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty skos:inScheme ;
                                  owl:allValuesFrom :ObservedImpacts
                                ] .


###  http://www.semanticweb.org/crima/ipcc-ar6-impacts#Impact-specificType
:Impact-specificType rdf:type owl:Class ;
                     rdfs:subClassOf skos:Concept ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty skos:broader ;
                                       owl:allValuesFrom :Impact-cluster
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty skos:inScheme ;
                                       owl:allValuesFrom :ObservedImpacts
                                     ] .


###  http://www.semanticweb.org/crima/ipcc-ar6-impacts#Impact-type
:Impact-type rdf:type owl:Class ;
             rdfs:subClassOf skos:Concept ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty skos:inScheme ;
                               owl:allValuesFrom :ObservedImpacts
                             ] .


###  http://www.semanticweb.org/crima/ipcc-ar6-impacts#ObservedImpacts
:ObservedImpacts rdf:type owl:Class ;
                 rdfs:subClassOf skos:ConceptScheme .


###  http://www.w3.org/2015/03/corine#LandCoverClass
clc:LandCoverClass rdfs:subClassOf [ rdf:type owl:Restriction ;
                                     owl:onProperty skos:inScheme ;
                                     owl:allValuesFrom :ObservedImpacts
                                   ] .


