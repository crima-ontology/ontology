voaf:metadataVoc rdf:type owl:AnnotationProperty .


###  http://purl.org/vocommons/voaf#specializes
voaf:specializes rdf:type owl:AnnotationProperty .


#################################################################
#    Classes
#################################################################

###  https://w3id.org/crima-ontology/ar6-impact#Impact-cluster
:Impact-cluster rdf:type owl:Class ;
                rdfs:subClassOf skos:Concept ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty skos:broader ;
                                  owl:allValuesFrom :Impact-type
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty skos:inScheme ;
                                  owl:allValuesFrom :ObservedImpacts
                                ] .


###  https://w3id.org/crima-ontology/ar6-impact#Impact-specificType
:Impact-specificType rdf:type owl:Class ;
                     rdfs:subClassOf skos:Concept ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty skos:broader ;
                                       owl:allValuesFrom :Impact-cluster
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty skos:inScheme ;
                                       owl:allValuesFrom :ObservedImpacts
                                     ] .


###  https://w3id.org/crima-ontology/ar6-impact#Impact-type
:Impact-type rdf:type owl:Class ;
             rdfs:subClassOf skos:Concept ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty skos:inScheme ;
                               owl:allValuesFrom :ObservedImpacts
                             ] .


###  https://w3id.org/crima-ontology/ar6-impact#ObservedImpacts
:ObservedImpacts rdf:type owl:Class ;
                 rdfs:subClassOf skos:ConceptScheme .


