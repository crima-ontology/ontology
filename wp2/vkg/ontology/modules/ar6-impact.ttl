                                                                  clc: ;
                                                      vann:preferredNamespacePrefix "ar6-impact" ;
                                                      vann:preferredNamespaceUri "http://www.semanticweb.org/crima/ipcc-ar6-impacts#"^^xsd:anyURI ;
