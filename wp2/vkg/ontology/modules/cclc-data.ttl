                                     owl:imports <http://www.w3.org/2004/02/skos/core> ,
                                                 <http://www.semanticweb.org/crima/crima-clc#> ;
                                     vann:preferredNamespacePrefix "cclc" ;
                                     vann:preferredNamespaceUri "http://www.semanticweb.org/crima/crima-clc#"^^xsd:anyURI .


cclc:CorineValue a rdfs:Datatype ;
    rdfs:label "CORINE value"@en ;
    rdfs:comment "A numerical value from the CORINE Land Cover nomenclature" .

