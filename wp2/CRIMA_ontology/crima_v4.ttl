#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( impch:Affects
                impch:ImpactsOn
                impch:LeadsTo
                impch:Mitigates
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( skos:Collection
                skos:Concept
                skos:ConceptScheme
              )
] .


