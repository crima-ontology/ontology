           hip:identifier "BI0010" .


hip:BI0011 rdfs:label "Foodborne Microbial Hazards (including human enteric virus and foodborne parasite)" ;
           hip:identifier "BI0011" .


hip:BI0012 rdfs:label "Bacterial Plant Disease" ;
           hip:identifier "BI0012" .


hip:BI0013 rdfs:label "Fungal Plant Disease" ;
           hip:identifier "BI0013" .


hip:BI0014 rdfs:label "Viral, Mycoplasma and Viroid Plant Disease Epidemics" ;
           skos:definition "Viral, mycoplasma and viroid plant disease epidemics are the occurrence of plant diseases caused by viruses, mycoplasma (syn. phytoplasma, mycoplasma-like organisms ) and viroids over large areas with significant impact on crop productivity or natural habitats (adapted from Nakashima and Murata, 1993; Hammond and Owens, 2006; FAO and IPPC, 2016; Rubio et al., 2020)." .


hip:BI0015 rdfs:label "Anthrax" ;
           hip:identifier "BI0015" .


hip:BI0016 rdfs:label "Airborne Diseases" ;
           hip:identifier "BI0016" .


hip:BI0017 rdfs:label "Blood Borne Viruses" ;
           hip:identifier "BI0017" .


hip:BI0018 rdfs:label "Waterborne Diseases" ;
           skos:definition "Waterborne diseases are those diseases that are transmitted by ingestion of contaminated water (WHO,2012)." .


hip:BI0019 rdfs:label "Foodborne Diseases" ;
           hip:identifier "BI0019" .


hip:BI0020 rdfs:label "Sexually Transmitted Diseases (Human)" ;
           hip:identifier "BI0020" ;
           hip:synonym "STIs" ,
                       "Sexually transmitted infections" .


hip:BI0021 rdfs:label "Neglected Tropical Diseases (Human)" ;
           hip:identifier "BI0021" .


hip:BI0022 rdfs:label "Vaccine-Preventable Diseases" ;
           skos:definition "Vaccine preventable diseases are those infectious diseases that can be prevented by vaccination (WHO, 2012)." .


hip:BI0023 rdfs:label "Vector Borne Diseases (VBD) (Human)" ;
           skos:definition "Vector borne diseases encompass a variety of illnesses that are caused via the spread of pathogens by living organisms known as vectors. These infectious diseases can be transmitted via vectors among humans (e.g., malaria, dengue), among animals (e.g., African swine fever, East Coast fever), or from animals to humans (e.g., Nipah virus disease). Many of these vectors are bloodsucking insects, and mosquitoes are the bestknown disease vector. Other vectors include ticks, flies, sandflies, fleas, triatomine bugs and some species of freshwater aquatic snails (adapted from OIE, 2019; WHO, 2020)." .


hip:BI0024 rdfs:label "Viral Haemorrhagic Fevers (Human)" ;
           skos:definition "Viral haemorrhagic fever is a general term for severe illnesses,sometimes associated with bleeding, that may be caused by a number of viruses. The term is usually applied to diseases caused by viruses that belong to the Arenaviridae, Bunyaviridae, Filoviridae and Flaviviridae families (WHO, no date)." .


hip:BI0025 rdfs:label "Antimicrobial Resistant Microorganisms" ;
           hip:identifier "BI0025" ;
           hip:synonym "Superbugs" .


hip:BI0026 rdfs:label "Animal Diseases (Not Zoonoses)" ;
           hip:identifier "BI0026" .


hip:BI0027 rdfs:label "Zoonotic Diseases" ;
           skos:definition "Zoonotic diseases are a group of communicable diseases that are transmissible from vertebrate animals to humans through direct contact or through food, water, and the environment (WHO, no date)." .


hip:BI0028 rdfs:label "Diarrhoeal Diseases (Human)" ;
           hip:identifier "BI0028" .


hip:BI0029 rdfs:label "Prion Diseases" ;
           hip:identifier "BI0029" .


hip:BI0030 rdfs:label "Hepatitis B (Human)" ;
           hip:identifier "BI0030" ;
           hip:synonym "Acute hepatitis B" ,
                       "Chronic hepatitis B" ,
                       "Hepatitis B related cirrhosis and hepatocellular carcinoma" .


hip:BI0031 rdfs:label "Hepatitis C (human)" ;
           hip:identifier "BI0031" ;
           hip:synonym "Acute hepatitis C" ,
                       "Chronic hepatitis C" ,
                       "Hepatitis C-related cirrhosis and liver cancer" .


hip:BI0032 rdfs:label "HIV and AIDS (Human)" ;
           hip:identifier "BI0032" .


hip:BI0033 rdfs:label "COVID-19 (SARS-CoV-2) (Human)" ;
           hip:identifier "BI0033" ;
           hip:synonym "COVID-19" ,
                       "Coronavirus" ,
                       "SARS-CoV-2" .


hip:BI0034 rdfs:label "Cholera (Human)" ;
           hip:identifier "BI0034" .


hip:BI0035 rdfs:label "Cryptosporidium" ;
           hip:identifier "BI0035" ;
           hip:synonym "Crypto" .


hip:BI0036 rdfs:label "Paratyphoid Fever (Human)" ;
           hip:identifier "BI0036" .


hip:BI0037 rdfs:label "Typhoid Fever (Human)" ;
           skos:definition "Typhoid fever is a life-threatening infection caused by the bacterium Salmonella Typhi. It is usually spread through contaminated food or water. An estimated 11–20 million people get sick from typhoid and between 128,000 and 161,000 people die from it every year (WHO, 2018)." .


hip:BI0038 rdfs:label "Hepatitis A (Human)" ;
           hip:identifier "BI0038" .


