           hip:identifier "BI0051" .


hip:BI0052 rdfs:label "Measles (Human)" ;
           hip:identifier "BI0052" ;
           hip:synonym "Rubeola" .


hip:BI0053 rdfs:label "Meningococcal Meningitis (Human)" ;
           hip:identifier "BI0053" .


hip:BI0054 rdfs:label "Pertussis (Human)" ;
           hip:identifier "BI0054" ;
           hip:synonym "Whooping cough" .


hip:BI0055 rdfs:label "Polio (Human)" ;
           hip:identifier "BI0055" ;
           hip:synonym "Poliomyelitis" .


hip:BI0056 rdfs:label "Smallpox (Human)" ;
           hip:identifier "BI0056" .


hip:BI0057 rdfs:label "Varicella and herpes zoster (Human)" ;
           skos:definition "Varicella is an acute, highly contagious disease caused by varicellazoster virus (WHO, 2014)." .


hip:BI0058 rdfs:label "Yellow Fever (Human)" ;
           skos:definition "Yellow fever is an acute viral haemorrhagic disease transmitted by infected mosquitoes (WHO, 2019)." .


hip:BI0059 rdfs:label "Dengue (Human)" ;
           hip:identifier "BI0059" ;
           hip:synonym "Break Bone Fever" .


hip:BI0060 rdfs:label "Malaria (Human)" ;
           hip:identifier "BI0060" .


hip:BI0061 rdfs:label "Crimean-Congo Haemorrhagic Fever" ;
           hip:identifier "BI0061" .


hip:BI0062 rdfs:label "Ebola (Human)" ;
           hip:identifier "BI0062" ;
           hip:synonym "Ebola haemorrhagic fever" .


hip:BI0063 rdfs:label "Lassa Fever (Human)" ;
           hip:identifier "BI0063" .


hip:BI0064 rdfs:label "Tuberculosis (Human and Animal)" ;
           skos:definition "Tuberculosis (TB) is a curable bacterial infectious disease caused by Mycobacterium tuberculosis that most commonly affects the lungs. It causes national epidemics of varied severity worldwide. Forms of TB that are resistant to treatment – multi-drug resistant TB (MDR-TB) and extensively drug-resistant TB (XDR-TB) – are public health crises and threaten health security worldwide (WHO, 2020)." .


hip:BI0065 rdfs:label "Middle East Respiratory Syndrome (MERS) (Human)" ;
           hip:identifier "BI0065" ;
           hip:synonym "MERS-CoV disease" .


hip:BI0066 rdfs:label "Monkeypox (Human)" ;
           hip:identifier "BI0066" .


hip:BI0067 rdfs:label "Rabies (Animal and Human)" ;
           hip:identifier "BI0067" .


hip:BI0068 rdfs:label "Severe Acute Respiratory Syndrome (SARS) (Human)" ;
           hip:identifier "BI0068" ;
           hip:synonym "SARS-CoV" .


hip:BI0069 rdfs:label "Rotavirus (Human)" ;
           hip:identifier "BI0069" .


hip:BI0070 rdfs:label "African Swine Fever" ;
           hip:identifier "BI0070" ;
           hip:synonym "ASFV" .


hip:BI0071 rdfs:label "Vector-borne diseases (VBD) (Animals)" ;
           skos:definition "Vector-borne diseases are diseases transmitted by a living being, usually an arthropod vector, to a vertebrate host (Verwoerd, 2015)." .


hip:BI0072 rdfs:label "Brucellosis (Animal)" ;
           hip:identifier "BI0072" ;
           hip:synonym "Contagious abortion" ,
                       "Malta fever" ,
                       "Mediterranean fever" ,
                       "Undulant fever" .


hip:BI0073 rdfs:label "Classical Swine Fever (Animal)" ;
