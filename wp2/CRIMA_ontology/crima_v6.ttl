           hip:identifier "BI0039" ;
           hip:synonym "Enterohaemorrhagic E. coli (EHEC)" ,
                       "Shiga-toxin producing E. coli (STEC)" ,
                       "Verocytotoxigenic E. coli (VTEC)" .


