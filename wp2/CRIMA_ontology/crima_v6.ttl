db:NonAgentiveSocialObject rdf:type owl:Class ;
                           rdfs:subClassOf db:SocialObject ;
                           ace_lexicon:CN_pl "non agentive social objects" ;
                           ace_lexicon:CN_sg "non agentive social object" ;
                           rdfs:comment "A Non-Agentive Social Object is a social object to which intentions, believes and desires are not ascribed (examples: a law, an economic system, a currency, an asset)." ;
                           rdfs:label "Non-Agentive Social Object" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:NonAgentiveSocialObject ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget db:SocialObject ;
   rdfs:comment "Every non agentive social object is a social object."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#NonPhysicalEndurant
db:NonPhysicalEndurant rdf:type owl:Class ;
                       rdfs:subClassOf db:Endurant ,
                                       [ rdf:type owl:Class ;
                                         owl:complementOf [ rdf:type owl:Restriction ;
                                                            owl:onProperty db:constantlyOverlaps ;
                                                            owl:someValuesFrom db:PhysicalEndurant
                                                          ]
                                       ] ,
                                       _:genid899 ,
                                       _:genid901 ,
                                       _:genid904 ,
                                       _:genid907 ;
                       owl:disjointWith db:PhysicalEndurant ;
                       ace_lexicon:CN_pl "non physical endurants" ;
                       ace_lexicon:CN_sg "non physical endurant" ;
                       rdfs:comment "A Non-Physical Endurant is an endurant with no direct spatial quality (examples: democracy, the United Nations, the general secretary of Amnesty International)." ;
                       rdfs:label "Non-Physical Endurant" .

_:genid899 rdf:type owl:Restriction ;
            owl:onProperty db:constantConstituentOf ;
            owl:allValuesFrom db:NonPhysicalEndurant .

_:genid901 rdf:type owl:Restriction ;
            owl:onProperty [ owl:inverseOf db:constantConstituentOf
                           ] ;
            owl:allValuesFrom db:NonPhysicalEndurant .

_:genid904 rdf:type owl:Restriction ;
            owl:onProperty [ owl:inverseOf db:constantPartOf
                           ] ;
            owl:allValuesFrom db:NonPhysicalEndurant .

_:genid907 rdf:type owl:Restriction ;
            owl:onProperty [ owl:inverseOf db:directQualityOf
                           ] ;
            owl:allValuesFrom db:AbstractQuality .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:NonPhysicalEndurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget db:Endurant ;
   rdfs:comment "Every non physical endurant is an endurant."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:NonPhysicalEndurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid899 ;
   rdfs:comment "Everything that is constantly constituted by a non physical endurant is a non physical endurant."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:NonPhysicalEndurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid901 ;
   rdfs:comment "Everything that is constant constituent of a non physical endurant is a non physical endurant."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:NonPhysicalEndurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid904 ;
   rdfs:comment "Everything that is constant part of a non physical endurant is a non physical endurant."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:NonPhysicalEndurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid907 ;
   rdfs:comment "Approximation of Ad51" ,
                "Everything that is direct quality of a non physical endurant is an abstract quality."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:NonPhysicalEndurant ;
   owl:annotatedProperty owl:disjointWith ;
   owl:annotatedTarget db:PhysicalEndurant ;
   rdfs:comment "No non physical endurant is a physical endurant."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#NonPhysicalObject
db:NonPhysicalObject rdf:type owl:Class ;
                     rdfs:subClassOf db:NonPhysicalEndurant ;
                     ace_lexicon:CN_pl "non physical objects" ;
                     ace_lexicon:CN_sg "non physical object" ;
                     rdfs:comment "A Non-Physical Object is a non-physical endurant with unity criterion (examples: a theory, a topic, a concept)." ;
                     rdfs:label "Non-Physical Object" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:NonPhysicalObject ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget db:NonPhysicalEndurant ;
   rdfs:comment "Every non physical object is a non physical endurant."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#Particular
db:Particular rdf:type owl:Class ;
              rdfs:subClassOf sosa:FeatureOfInterest ;
              owl:disjointUnionOf _:genid915 ;
              ace_lexicon:CN_pl "particulars" ;
              ace_lexicon:CN_sg "particular" ;
              rdfs:comment "A Particular is an entity that cannot have instances, in this sense it is opposed to universals (examples: a person, a soccer game, a plan, the color red, a feeling, a fact, a theory, number forty-two)." ;
              rdfs:label "Particular" .

_:genid915 rdf:type rdf:List ;
            rdf:first db:Abstract ;
            rdf:rest ( db:Endurant
                       db:Perdurant
                       db:Quality
                     ) .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:Particular ;
   owl:annotatedProperty owl:disjointUnionOf ;
   owl:annotatedTarget _:genid915 ;
   rdfs:comment "A particular is either an abstract, an endurant, a perdurant, or a quality, and the classes Abstract, Endurant, Perdurant and Quality are all disjoint."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#Perdurant
db:Perdurant rdf:type owl:Class ;
             rdfs:subClassOf db:Particular ,
                             _:genid918 ,
                             _:genid920 ,
                             _:genid923 ,
                             _:genid925 ,
                             _:genid927 ,
                             _:genid929 ,
                             _:genid932 ,
                             _:genid935 ,
                             _:genid938 ;
             owl:disjointWith db:Quality ;
             ace_lexicon:CN_pl "perdurants" ;
             ace_lexicon:CN_sg "perdurant" ;
             rdfs:comment "A Perdurant is an entity that happens in time (examples: a person’s life, a soccer game, the reading of a book, the state of feeling happy). Some perdurants are temporally atomic (example: the change of a letter’s state due to the breaking of the seal)." ;
             rdfs:label "Perdurant" .

_:genid918 rdf:type owl:Restriction ;
            owl:onProperty db:temporallyLocatedAt ;
            owl:someValuesFrom db:TimeInterval .

_:genid920 rdf:type owl:Restriction ;
            owl:onProperty [ owl:inverseOf db:directQualityOf
                           ] ;
            owl:someValuesFrom db:TemporalLocation .

_:genid923 rdf:type owl:Restriction ;
            owl:onProperty db:constantConstituentOf ;
            owl:allValuesFrom db:Perdurant .

_:genid925 rdf:type owl:Restriction ;
            owl:onProperty db:overlaps ;
            owl:allValuesFrom db:Perdurant .

_:genid927 rdf:type owl:Restriction ;
            owl:onProperty db:partOf ;
            owl:allValuesFrom db:Perdurant .

_:genid929 rdf:type owl:Restriction ;
            owl:onProperty [ owl:inverseOf db:constantConstituentOf
                           ] ;
            owl:allValuesFrom db:Perdurant .

_:genid932 rdf:type owl:Restriction ;
            owl:onProperty [ owl:inverseOf db:directQualityOf
                           ] ;
            owl:allValuesFrom db:TemporalQuality .

_:genid935 rdf:type owl:Restriction ;
            owl:onProperty [ owl:inverseOf db:overlaps
                           ] ;
            owl:allValuesFrom db:Perdurant .

_:genid938 rdf:type owl:Restriction ;
            owl:onProperty [ owl:inverseOf db:partOf
                           ] ;
            owl:allValuesFrom db:Perdurant .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:Perdurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget db:Particular ;
   rdfs:comment "Every perdurant is a particular."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:Perdurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid918 ;
   rdfs:comment "Every perdurant is temporally located at a time interval."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:Perdurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid920 ;
   rdfs:comment "Ad49 for dQt" ,
                "Every perdurant has a temporal location as direct quality."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:Perdurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid923 ;
   rdfs:comment "Everything that is constantly constituted by a perdurant is a perdurant."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:Perdurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid925 ;
   rdfs:comment "Everything that is overlapped by a perdurant is a perdurant." ,
                "from Dd15, Ad2"
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:Perdurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid927 ;
   rdfs:comment "Ad2  (half)" ,
                "Everything that has a perdurant as part is a perdurant."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:Perdurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid929 ;
   rdfs:comment "Everything that is constant constituent of a perdurant is a perdurant."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:Perdurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid932 ;
   rdfs:comment "Ad49 for dQt" ,
                "Everything that is direct quality of a perdurant is a temporal quality."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:Perdurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid935 ;
   rdfs:comment "Everything that overlaps a perdurant is a perdurant." ,
                "from Dd15, Ad2"
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:Perdurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid938 ;
   rdfs:comment "Ad2 (half)" ,
                "Everything that is part of a perdurant is a perdurant."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:Perdurant ;
   owl:annotatedProperty owl:disjointWith ;
   owl:annotatedTarget db:Quality ;
   rdfs:comment "No perdurant is a quality."
 ] .


