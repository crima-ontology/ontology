           hip:identifier "BI0076" .


hip:BI0077 rdfs:label "Lumpy Skin Disease (Animal)" ;
           hip:identifier "BI0077" .


hip:BI0078 rdfs:label "New World Screwworm (NWS) (Animal)" ;
           hip:identifier "BI0078" .


hip:BI0079 rdfs:label "Newcastle Disease Virus (Animal)" ;
           hip:identifier "BI0079" .


hip:BI0080 rdfs:label "Peste Des Petits Ruminants (Animal)" ;
           hip:identifier "BI0080" ;
           hip:synonym "Sheep and goat plague Ovine rinderpest" .


hip:BI0081 rdfs:label "Q Fever" ;
           hip:identifier "BI0081" ;
           hip:synonym "Query Fever Coxiellosis Abattoir fever" .


hip:BI0082 rdfs:label "Rift Valley Fever (Animal)" ;
           hip:identifier "BI0082" ;
           hip:synonym "Infectious enzootic hepatitis of sheep and cattle" .


hip:BI0083 rdfs:label "Trypanosomosis (Animal)" ;
           skos:definition "Animal trypanosomosis is a lethal parasitic disease caused by unicellular organisms named trypanosomes. The disease is cyclically transmitted by the bite of infected tsetse flies and it affects both humans ‘sleeping sickness’ and livestock ‘nagana’ (FAO, 2020)." .


hip:BI0084 rdfs:label "West Nile Fever (Human)" ;
           skos:definition "West Nile virus disease is a fatal neurological disease caused by a virus transmitted through the bites of infected mosquitoes. The virus is a member of the flavivirus genus and belongs to the Japanese encephalitis antigenic complex of the family Flaviviridae (WHO, 2017)." .


hip:BI0085 rdfs:label "Rinderpest (Animal)" ;
           hip:identifier "BI0085" .


hip:BI00869 rdfs:comment "Trypanosomiasis, human African (sleeping sickness) is caused by protozoan parasites belonging to the genus Trypanosoma transmitted by infected tsetse flies and is endemic in 36 sub-Saharan African countries. Without treatment, the disease is considered fatal, where there are tsetse flies that transmit the disease (WHO, 2020)." ;
            rdfs:label "Trypanosomiasis (Human)" .


hip:BI0087 rdfs:label "Shrimp disease (bacterial) - Acute Hepatic pancreatic necrosis" ;
           hip:identifier "BI0087" ;
           hip:synonym "Early mortality syndrome (EMS)" ,
                       "Hepatopancreas (HP)" ,
                       "Photorhabdus insect-related (Pir)" .


hip:BI0088 rdfs:label "Oyster Disease Aquaculture" ;
           hip:identifier "BI0088" .


hip:CH0001 rdfs:label "Ammonia" ;
           hip:identifier "CH0001" ;
           hip:synonym "Anhydrous ammonia Ammonia gas Spirit of hartshorn Azane" .


hip:CH0002 rdfs:label "Carbon Monoxide" ;
           hip:identifier "CH0002" .


hip:CH0003 rdfs:label "Arsenic" ;
           hip:identifier "CH0003" .


hip:CH0004 rdfs:label "Residue of Pesticides" ;
           skos:definition "Cadmium" ,
                           "Cadmium is a toxic heavy metal which is widely distributed in the Earth’s crust (soil and rocks), air and water; however, human activity has greatly increased levels in environmental media relevant to population exposure. Human exposure to cadmium represents a major public health concern as it has been associated with a range of acute and long-term adverse health effects and diseases (WHO, 2019)." ,
                           "Pesticide residue means any specified substance in food, agricultural commodities, or animal feed resulting from the use of a pesticide. The term includes any derivatives of a pesticide, such as conversion products, metabolites, reaction products, and impurities considered to be of toxicological significance (FAO and WHO, no date, 2019)." .


hip:CH0005 rdfs:label "Lead" ;
           hip:identifier "CH0005" .


hip:CH0006 rdfs:label "Mercury" ;
           hip:identifier "CH0006" ;
           hip:synonym "Quicksilver" .


