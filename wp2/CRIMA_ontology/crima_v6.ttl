 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:PhysicalEndurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid948 ;
   rdfs:comment "Everything that is constant constituent of a physical endurant is a physical endurant."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:PhysicalEndurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid951 ;
   rdfs:comment "Everything that is constant part of a physical endurant is a physical endurant."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:PhysicalEndurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid954 ;
   rdfs:comment "Approximation of Ad50" ,
                "Everything that is direct quality of a physical endurant is a physical quality."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#PhysicalObject
db:PhysicalObject rdf:type owl:Class ;
                  rdfs:subClassOf db:PhysicalEndurant ;
                  owl:disjointUnionOf _:genid959 ;
                  ace_lexicon:CN_pl "physical objects" ;
                  ace_lexicon:CN_sg "physical object" ;
                  rdfs:comment "A Physical Object is a physical endurant with unity criterion (examples: a person, a human body, a house, a computer)." ;
                  rdfs:label "Physical Object" .

_:genid959 rdf:type rdf:List ;
            rdf:first db:AgentivePhysicalObject ;
            rdf:rest ( db:NonAgentivePhysicalObject
                     ) .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:PhysicalObject ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget db:PhysicalEndurant ;
   rdfs:comment "Every physical object is a physical endurant."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:PhysicalObject ;
   owl:annotatedProperty owl:disjointUnionOf ;
   owl:annotatedTarget _:genid959 ;
   rdfs:comment "The classes PhysicalObject, NonAgentivePhysicalObjectare all disjoint."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#PhysicalQuality
db:PhysicalQuality rdf:type owl:Class ;
                   rdfs:subClassOf db:Quality ,
                                   _:genid962 ,
                                   _:genid964 ;
                   owl:disjointWith db:TemporalQuality ;
                   ace_lexicon:CN_pl "physical qualities" ;
                   ace_lexicon:CN_sg "physical quality" ;
                   rdfs:comment "A Physical Quality is a quality that directly inheres to a physical endurant (examples: the weight of a pen, the color of an apple)." ;
                   rdfs:label "Physical Quality" .

_:genid962 rdf:type owl:Restriction ;
            owl:onProperty db:directQualityOf ;
            owl:allValuesFrom db:PhysicalEndurant .

_:genid964 rdf:type owl:Restriction ;
            owl:onProperty [ owl:inverseOf db:constantQualeOf
                           ] ;
            owl:allValuesFrom db:PhysicalRegion .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:PhysicalQuality ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget db:Quality ;
   rdfs:comment "Every physical quality is a quality."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:PhysicalQuality ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid962 ;
   rdfs:comment "Ad47 for dQt (together with the axiom \"Every quality is direct quality of a particular\")" ,
                "Every physical quality is a direct quality of a physical endurant."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:PhysicalQuality ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid964 ;
   rdfs:comment "Everything that is constant quale of a physical quality is a physical region."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:PhysicalQuality ;
   owl:annotatedProperty owl:disjointWith ;
   owl:annotatedTarget db:TemporalQuality ;
   rdfs:comment "No physical quality is a temporal quality."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#PhysicalRegion
db:PhysicalRegion rdf:type owl:Class ;
                  rdfs:subClassOf db:Region ,
                                  _:genid969 ;
                  owl:disjointWith db:TemporalRegion ;
                  ace_lexicon:CN_pl "physical regions" ;
                  ace_lexicon:CN_sg "physical region" ;
                  rdfs:comment "A Physical Region is a region in a quality space for physical qualities (examples: the physical space, an area in the color quality space, 80Kg)." ;
                  rdfs:label "Physical Region" .

_:genid969 rdf:type owl:Restriction ;
            owl:onProperty db:constantQualeOf ;
            owl:allValuesFrom db:PhysicalQuality .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:PhysicalRegion ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget db:Region ;
   rdfs:comment "Every physical region is a region."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:PhysicalRegion ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid969 ;
   rdfs:comment "Everything that has a physical region as constant quale is a physical quality."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:PhysicalRegion ;
   owl:annotatedProperty owl:disjointWith ;
   owl:annotatedTarget db:TemporalRegion ;
   rdfs:comment "No physical region is a temporal region."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#Process
db:Process rdf:type owl:Class ;
           rdfs:subClassOf db:Stative ;
           owl:disjointWith db:State ;
           ace_lexicon:CN_pl "processes" ;
           ace_lexicon:CN_sg "process" ;
           rdfs:comment "A Process is a stative perdurant such that at some temporal scale some parts are of a different type  (examples: running, writing)." ;
           rdfs:label "Process" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:Process ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget db:Stative ;
   rdfs:comment "Every process is a stative."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:Process ;
   owl:annotatedProperty owl:disjointWith ;
   owl:annotatedTarget db:State ;
   rdfs:comment "No process is a state."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#Quality
db:Quality rdf:type owl:Class ;
           rdfs:subClassOf db:Particular ,
                           _:genid975 ,
                           _:genid977 ;
           owl:disjointUnionOf _:genid981 ;
           ace_lexicon:CN_pl "qualities" ;
           ace_lexicon:CN_sg "quality" ;
           rdfs:comment "A Quality is an entity that inheres in an endurant or a perdurant, and that can be perceived or measured (examples: the shape of a book, the color of a car, the size of a t-shirt, the electrical charge of a battery)." ;
           rdfs:label "Quality" .

_:genid975 rdf:type owl:Restriction ;
            owl:onProperty db:directQualityOf ;
            owl:someValuesFrom db:Particular .

_:genid977 rdf:type owl:Restriction ;
            owl:onProperty db:temporallyLocatedAt ;
            owl:someValuesFrom db:TimeInterval .

_:genid981 rdf:type rdf:List ;
            rdf:first db:AbstractQuality ;
            rdf:rest ( db:PhysicalQuality
                       db:TemporalQuality
                     ) .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:Quality ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget db:Particular ;
   rdfs:comment "Every quality is a particular."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:Quality ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid975 ;
   rdfs:comment "Every quality is direct quality of a particular." ,
                "Q(x)→ ∃y DQT(x,y)"
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:Quality ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid977 ;
   rdfs:comment "Every quality is temporally located at a timeinterval."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:Quality ;
   owl:annotatedProperty owl:disjointUnionOf ;
   owl:annotatedTarget _:genid981 ;
   rdfs:comment "A quality is either an abstract quality, a physical quality, or a temporal quality, and the classes AbstractQuality, PhysicalQuality, and TemporalQuality are all disjoint."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#Region
db:Region rdf:type owl:Class ;
          rdfs:subClassOf db:Abstract ;
          owl:disjointUnionOf _:genid986 ;
          ace_lexicon:CN_pl "regions" ;
          ace_lexicon:CN_sg "region" ;
          rdfs:comment "A Region is an abstract entity classified by a quality type and with mereological structure, the sum of all the regions of a quality type is called a quality space (examples: the color red is a region in the quality space of color, the red of a rose is a (sub)region of the red region in the quality space of color, the commercial value of 1 Euro is a region in the quality space of commercial values)." ;
          rdfs:label "Region" .

_:genid986 rdf:type rdf:List ;
            rdf:first db:AbstractRegion ;
            rdf:rest ( db:PhysicalRegion
                       db:TemporalRegion
                     ) .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:Region ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget db:Abstract ;
   rdfs:comment "Every region is an abstract."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:Region ;
   owl:annotatedProperty owl:disjointUnionOf ;
   owl:annotatedTarget _:genid986 ;
   rdfs:comment "The classes Region, AbstractRegion, TemporalRegionare all disjoint."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#SocialAgent
db:SocialAgent rdf:type owl:Class ;
               rdfs:subClassOf db:AgentiveSocialObject ;
               owl:disjointWith db:Society ;
               ace_lexicon:CN_pl "social agents" ;
               ace_lexicon:CN_sg "social agent" ;
               rdfs:comment "A Social Agent is an individual agentive social object (examples: a teacher, a president, a software agent)." ;
               rdfs:label "Social Agent" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:SocialAgent ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget db:AgentiveSocialObject ;
   rdfs:comment "Every social agent is an agentive social object."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:SocialAgent ;
   owl:annotatedProperty owl:disjointWith ;
   owl:annotatedTarget db:Society ;
   rdfs:comment "No social agent is a society."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#SocialObject
db:SocialObject rdf:type owl:Class ;
                rdfs:subClassOf db:NonPhysicalObject ;
                owl:disjointUnionOf _:genid992 ;
                ace_lexicon:CN_pl "social objects" ;
                ace_lexicon:CN_sg "social object" ;
                rdfs:comment "A Social Object is a non-physical object which is generically dependent on a community of agents (examples: a person in the legal sense, a client, a law, an economic system)." ;
                rdfs:label "Social Object" .

_:genid992 rdf:type rdf:List ;
            rdf:first db:AgentiveSocialObject ;
            rdf:rest ( db:NonAgentiveSocialObject
                     ) .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:SocialObject ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget db:NonPhysicalObject ;
   rdfs:comment "Every social object is a non physical object."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:SocialObject ;
   owl:annotatedProperty owl:disjointUnionOf ;
   owl:annotatedTarget _:genid992 ;
   rdfs:comment "The classes SocialObject, NonAgentiveSocialObjectare all disjoint."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#Society
db:Society rdf:type owl:Class ;
           rdfs:subClassOf db:AgentiveSocialObject ;
           ace_lexicon:CN_pl "societies" ;
           ace_lexicon:CN_sg "society" ;
           rdfs:comment "A Society is a collective agentive social object (examples: a nation, the FCA Group, Apple, the European Central Bank)." ;
           rdfs:label "Society" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:Society ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget db:AgentiveSocialObject ;
   rdfs:comment "Every society is an agentive social object."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#SpaceRegion
db:SpaceRegion rdf:type owl:Class ;
               rdfs:subClassOf db:PhysicalRegion ,
                               _:genid996 ,
                               _:genid998 ,
                               _:genid1000 ;
               ace_lexicon:CN_pl "space regions" ;
               ace_lexicon:CN_sg "space region" ;
               rdfs:comment "A Space Region is a physical region, possibly disconnected, for spatial locations (examples: the region occupied by Earth in this moment, the region where it snowed in the year 1900)." ;
               rdfs:label "Space Region" .

_:genid996 rdf:type owl:Restriction ;
            owl:onProperty db:constantQualeOf ;
            owl:allValuesFrom db:SpatialLocation .

_:genid998 rdf:type owl:Restriction ;
            owl:onProperty db:partOf ;
            owl:allValuesFrom db:SpaceRegion .

_:genid1000 rdf:type owl:Restriction ;
             owl:onProperty [ owl:inverseOf db:partOf
                            ] ;
             owl:allValuesFrom db:SpaceRegion .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:SpaceRegion ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid1000 ;
   rdfs:comment "Everything that is part of a space region is a space region."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:SpaceRegion ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget db:PhysicalRegion ;
   rdfs:comment "Every space region is a physical region."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:SpaceRegion ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid996 ;
   rdfs:comment "Everything that has a space region as constant quale is a spatial location."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:SpaceRegion ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid998 ;
   rdfs:comment "Everything that has a space region as part is a space region."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#SpatialLocation
db:SpatialLocation rdf:type owl:Class ;
                   rdfs:subClassOf db:PhysicalQuality ;
                   ace_lexicon:CN_pl "spatial locations" ;
                   ace_lexicon:CN_sg "spatial location" ;
                   rdfs:comment "A Spatial Location is the individual spatial quality of a physical endurant (examples: the spatial quality of the Earth, the spatial quality of a hole, the spatial quality of Adolf Anderssen)." ;
                   rdfs:label "Spatial Location" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:SpatialLocation ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget db:PhysicalQuality ;
   rdfs:comment "Every spatial location is a physical quality."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#State
db:State rdf:type owl:Class ;
         rdfs:subClassOf db:Stative ,
                         _:genid1005 ;
         ace_lexicon:CN_pl "states" ;
         ace_lexicon:CN_sg "state" ;
         rdfs:comment "A State is a stative perdurant such that all its parts are of the same type (examples: being sitting, being open, being happy, being red)." ;
         rdfs:label "State" .

_:genid1005 rdf:type owl:Restriction ;
             owl:onProperty [ owl:inverseOf db:partOf
                            ] ;
             owl:allValuesFrom db:State .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:State ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget db:Stative ;
   rdfs:comment "Every state is a stative."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:State ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid1005 ;
   rdfs:comment "Everything that is part of a state is a state."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#Stative
db:Stative rdf:type owl:Class ;
           rdfs:subClassOf db:Perdurant ;
           ace_lexicon:CN_pl "statives" ;
           ace_lexicon:CN_sg "stative" ;
           rdfs:comment "A Stative is a cumulative perdurant, i.e., a perdurant that when summed to another perdurant of the same type, gives a perdurant of the same type (examples: sitting, walking, waiting)." ;
           rdfs:label "Stative" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:Stative ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget db:Perdurant ;
   rdfs:comment "Every stative is a perdurant."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#TemporalLocation
db:TemporalLocation rdf:type owl:Class ;
                    rdfs:subClassOf db:TemporalQuality ,
                                    _:genid1010 ;
                    ace_lexicon:CN_pl "temporal locations" ;
                    ace_lexicon:CN_sg "temporal location" ;
                    rdfs:comment "A Temporal Location is a temporal quality of a perdurant and is specific to that perdurant, that is, two concurrent perdurants have distinct temporal locations. The temporal location is the temporal quality which has as quale the unique time interval at which the perdurant is exactly located (examples: the temporal location of World War I, the temporal location of the Anderssen-Kieseritzky chess play in 1851, the temporal location of the summers of the 20th century)." ;
                    rdfs:label "Temporal Location" .

_:genid1010 rdf:type owl:Restriction ;
             owl:onProperty [ owl:inverseOf db:qualeOf
                            ] ;
             owl:someValuesFrom db:TimeInterval .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:TemporalLocation ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget db:TemporalQuality ;
   rdfs:comment "Every temporal location is a temporal quality."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:TemporalLocation ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid1010 ;
   rdfs:comment "Ad53" ,
                "Every temporal location has some time interval as quale."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#TemporalQuality
db:TemporalQuality rdf:type owl:Class ;
                   rdfs:subClassOf db:Quality ,
                                   _:genid1014 ,
                                   _:genid1017 ;
                   ace_lexicon:CN_pl "temporal qualities" ;
                   ace_lexicon:CN_sg "temporal quality" ;
                   rdfs:comment "A Temporal Quality is a quality that directly inheres to a perdurant (example: the duration of World War I, the starting time of the 2000 Olympics)." ;
                   rdfs:label "Temporal Quality" .

_:genid1014 rdf:type owl:Restriction ;
             owl:onProperty [ owl:inverseOf db:qualeOf
                            ] ;
             owl:someValuesFrom db:Particular .

_:genid1017 rdf:type owl:Restriction ;
             owl:onProperty db:directQualityOf ;
             owl:allValuesFrom db:Perdurant .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:TemporalQuality ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget db:Quality ;
   rdfs:comment "Every temporal quality is a quality."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:TemporalQuality ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid1014 ;
   rdfs:comment "Ad55" ,
                "Every temporal quality has some particular as quale."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:TemporalQuality ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid1017 ;
   rdfs:comment "Ad46 for dQt (together with the axiom \"Every quality is direct quality of a particular\")" ,
                "Every temporal quality is a direct quality of a perdurant."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#TemporalRegion
db:TemporalRegion rdf:type owl:Class ;
                  rdfs:subClassOf db:Region ;
                  ace_lexicon:CN_pl "temporal regions" ;
                  ace_lexicon:CN_sg "temporal region" ;
                  rdfs:comment "A Temporal Region is a region in a quality space for temporal qualities (examples: a time interval, a historical period, a velocity)." ;
                  rdfs:label "Temporal Region" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:TemporalRegion ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget db:Region ;
   rdfs:comment "Every temporal region is a region."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#TimeInterval
db:TimeInterval rdf:type owl:Class ;
                rdfs:subClassOf db:TemporalRegion ,
                                _:genid1021 ;
                ace_lexicon:CN_pl "time intervals" ;
                ace_lexicon:CN_sg "time interval" ;
                rdfs:comment "A Time Interval is a temporal region which is an interval or a sum of intervals. A Time Interval can be atomic, i.e., instantaneous. (examples: the first second of your life,  the Cretaceous time period, the time interval of all winters of the third millennium)." ;
                rdfs:label "Time Interval" .

_:genid1021 rdf:type owl:Restriction ;
             owl:onProperty [ owl:inverseOf db:partOf
                            ] ;
             owl:allValuesFrom db:TimeInterval .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:TimeInterval ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget db:TemporalRegion ;
   rdfs:comment "Every time interval is a temporal region."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:TimeInterval ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid1021 ;
   rdfs:comment "Everything that is part of a time interval is a time interval."
 ] .


###  https://www.w3.org/ns/activitystreams#Place
as:Place rdf:type owl:Class ;
         rdfs:subClassOf geo:SpatialObject .


