@prefix : <http://www.semanticweb.org/CRIMA#> .
@prefix as: <https://www.w3.org/ns/activitystreams#> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix db: <https://w3id.org/DOLCE/OWL/DOLCEbasic#> .
@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix deo: <http://knowwheregraph/ontology/deo#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix hip: <https://undrr-hip.org/> .
@prefix iao: <http://purl.obolibrary.org/obo/iao.owl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix ssn: <http://www.w3.org/ns/ssn/> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix dtype: <http://www.linkedmodel.org/schema/dtype#> .
@prefix impch: <http://www.semanticweb.org/CRIMA/ImpactChain#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ace_lexicon: <http://attempto.ifi.uzh.ch/ace_lexicon#> .
@base <http://www.semanticweb.org/CRIMA#> .

<http://www.semanticweb.org/CRIMA> rdf:type owl:Ontology ;
                                    owl:versionIRI <http://www.semanticweb.org/CRIMA/1.0> ;
                                    cc:license <http://creativecommons.org/licenses/by-nc-sa/4.0/> ;
                                    dcterms:creator "Alessandro Mosca" ,
                                                    "Greta Adamo" ;
                                    dcterms:description "The CRIMA ontology..." ;
                                    dcterms:license <http://creativecommons.org/licenses/by-nc-sa/4.0/> ;
                                    dcterms:title "Evicedence-Based Management of Climate Risks (CRIMA) ontology" ;
                                    owl:versionInfo 1.0 .

#################################################################
#    Annotation properties
#################################################################

###  http://attempto.ifi.uzh.ch/ace_lexicon#CN_pl
ace_lexicon:CN_pl rdf:type owl:AnnotationProperty .


###  http://attempto.ifi.uzh.ch/ace_lexicon#CN_sg
ace_lexicon:CN_sg rdf:type owl:AnnotationProperty .


###  http://attempto.ifi.uzh.ch/ace_lexicon#TV_pl
ace_lexicon:TV_pl rdf:type owl:AnnotationProperty .


###  http://attempto.ifi.uzh.ch/ace_lexicon#TV_sg
ace_lexicon:TV_sg rdf:type owl:AnnotationProperty .


###  http://attempto.ifi.uzh.ch/ace_lexicon#TV_vbg
ace_lexicon:TV_vbg rdf:type owl:AnnotationProperty .


###  http://creativecommons.org/ns#license
cc:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
dcterms:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/date
dcterms:date rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
dcterms:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/hasVersion
dcterms:hasVersion rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/identifier
dcterms:identifier rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/issued
dcterms:issued rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/modified
dcterms:modified rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/references
dcterms:references rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/source
dcterms:source rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
dcterms:title rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
vann:preferredNamespacePrefix rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
vann:preferredNamespaceUri rdf:type owl:AnnotationProperty .


###  http://schema.org/domainIncludes
<http://schema.org/domainIncludes> rdf:type owl:AnnotationProperty .


###  http://schema.org/rangeIncludes
<http://schema.org/rangeIncludes> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#altLabel
skos:altLabel rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#changeNote
skos:changeNote rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#description
skos:description rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#editorialNote
skos:editorialNote rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#example
skos:example rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#note
skos:note rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#prefLabel
skos:prefLabel rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#scopeNote
skos:scopeNote rdf:type owl:AnnotationProperty .


###  https://undrr-hip.org/identifier
hip:identifier rdf:type owl:AnnotationProperty .


###  https://undrr-hip.org/synonym
hip:synonym rdf:type owl:AnnotationProperty .


###  https://undrr-hip.org/vernacularName
hip:vernacularName rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.linkedmodel.org/schema/dtype#numericUnion
dtype:numericUnion rdf:type rdfs:Datatype ;
                   skos:definition "A datatype that is the union of numeric xsd data types. \"dtype:numericUnion\" is equivalent to the xsd specification that uses an xsd:union of memberTypes=\"xsd:decimal xsd:double xsd:float xsd:integer\"."@en .


###  http://www.opengis.net/ont/geosparql#wktLiteral
geo:wktLiteral rdf:type rdfs:Datatype ;
               skos:definition "A Well-known Text serialization of a Geometry object."@en ;
               skos:prefLabel "Well-known Text literal"@en .


###  http://www.w3.org/2001/XMLSchema#gYear
xsd:gYear rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://knowwheregraph/ontology/deo#hasHazardOfInterest
deo:hasHazardOfInterest rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf sosa:hasFeatureOfInterest ;
                        <http://schema.org/domainIncludes> "'Hazard Observation'" ;
                        <http://schema.org/rangeIncludes> "Hazard" ;
                        rdfs:label "has hazard of interest" .


###  http://knowwheregraph/ontology/deo#hasImpactOfInterest
deo:hasImpactOfInterest rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf sosa:hasFeatureOfInterest ;
                        <http://schema.org/domainIncludes> "'Impact Observation'" ;
                        <http://schema.org/rangeIncludes> "'Disaster Impact'" ;
                        rdfs:label "has impact of Interest" .


###  http://knowwheregraph/ontology/deo#hazardType
deo:hazardType rdf:type owl:ObjectProperty ;
               rdfs:domain :Hazard .


###  http://purl.org/dc/terms/subject
dcterms:subject rdf:type owl:ObjectProperty ;
                rdfs:domain dcat:Resource ;
                dcterms:description "Typically, the subject will be represented using keywords, key phrases, or classification codes. Recommended best practice is to use a controlled vocabulary. To describe the spatial or temporal topic of the resource, use the Coverage element."@en-us ;
                dcterms:hasVersion <http://dublincore.org/usage/terms/history/#subjectT-001> ;
                rdfs:comment "The topic of the resource."@en-us ;
                rdfs:isDefinedBy dcterms: ;
                rdfs:label "Subject"@en-us ;
                skos:note "This term is intended to be used with non-literal values as defined in the DCMI Abstract Model (http://dublincore.org/documents/abstract-model/). As of December 2007, the DCMI Usage Board is seeking a way to express this intention with a formal range declaration."@en-us .


###  http://qudt.org/schema/qudt/hasUnit
qudt:hasUnit rdf:type owl:ObjectProperty ;
             rdfs:range qudt:Unit ;
             rdfs:label "has unit" ,
                        "hasUnit" ;
             skos:definition "This property relates a factor unit to its unit or a system of units with a unit of measure that is either a) defined by the system, or b) accepted for use by the system and is convertible to a unit of equivalent dimension that is defined by the system. Systems of units may distinguish between base and derived units. Base units are the units which measure the base quantities for the corresponding system of quantities. The base units are used to define units for all other quantities as products of powers of the base units. Such units are called derived units for the system."@en .


###  http://www.opengis.net/ont/geosparql#hasGeometry
geo:hasGeometry rdf:type owl:ObjectProperty ;
                rdfs:domain geo:Feature ;
                rdfs:range geo:Geometry ;
                rdfs:isDefinedBy <http://www.opengis.net/spec/geosparql/1.0/req/geometry-extension/feature-properties> ,
                                 <http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/feature-properties> ;
                skos:definition "A spatial representation for a given Feature."@en ;
                skos:prefLabel "has geometry"@en .


###  http://www.opengis.net/ont/geosparql#hasSize
geo:hasSize rdf:type owl:ObjectProperty ;
            rdfs:domain geo:SpatialObject ;
            rdfs:isDefinedBy geo: ,
                             <http://www.opengis.net/spec/geosparql/1.0/req/topology-vocab-extension/spatial-object-properties> ,
                             <http://www.opengis.net/spec/geosparql/1.1/req/topology-vocab-extension/spatial-object-properties> ;
            skos:definition "Subproperties of this property are used to indicate the size of a Spatial Object as a measurement or estimate of one or more dimensions of the Spatial Object's spatial presence."@en ;
            skos:note "The recommended way to specify size is by using a subproperty of hasMetricSize. Subproperties of hasSize can be used if more complex expressions are necessary, for example if the unit of length can not be converted to meter, or if additional data are needed to describe the measurement or estimate."@en ;
            skos:prefLabel "has size"@en .


###  http://www.opengis.net/ont/geosparql#sfContains
geo:sfContains rdf:type owl:ObjectProperty ;
               rdfs:domain geo:SpatialObject ;
               rdfs:range geo:SpatialObject ;
               rdfs:isDefinedBy geo: ,
                                <http://www.opengis.net/spec/geosparql/1.0/req/topology-vocab-extension/rcc8-spatial-relations> ,
                                <http://www.opengis.net/spec/geosparql/1.1/req/topology-vocab-extension/rcc8-spatial-relations> ;
               rdfs:seeAlso <http://dbpedia.org/resource/DE-9IM> ;
               skos:definition "States that the subject SpatialObject spatially contains the object SpatialObject. DE-9IM: T*****FF*"@en ;
               skos:prefLabel "contains"@en .


###  http://www.opengis.net/ont/geosparql#sfCrosses
geo:sfCrosses rdf:type owl:ObjectProperty ;
              rdfs:domain geo:SpatialObject ;
              rdfs:range geo:SpatialObject ;
              rdfs:isDefinedBy geo: ,
                               <http://www.opengis.net/spec/geosparql/1.0/req/topology-vocab-extension/sf-spatial-relations> ,
                               <http://www.opengis.net/spec/geosparql/1.1/req/topology-vocab-extension/sf-spatial-relations> ;
              rdfs:seeAlso <http://dbpedia.org/resource/DE-9IM> ;
              skos:definition "States that the subject SpatialObject spatially crosses the object SpatialObject. DE-9IM: T*T******"@en ;
              skos:prefLabel "crosses"@en .


###  http://www.opengis.net/ont/geosparql#sfDisjoint
geo:sfDisjoint rdf:type owl:ObjectProperty ;
               rdfs:domain geo:SpatialObject ;
               rdfs:range geo:SpatialObject ;
               owl:propertyDisjointWith geo:sfIntersects ;
               rdfs:isDefinedBy geo: ,
                                <http://www.opengis.net/spec/geosparql/1.0/req/topology-vocab-extension/sf-spatial-relations> ,
                                <http://www.opengis.net/spec/geosparql/1.1/req/topology-vocab-extension/sf-spatial-relations> ;
               rdfs:seeAlso <http://dbpedia.org/resource/DE-9IM> ;
               skos:definition "States that the subject SpatialObject is spatially disjoint from the object SpatialObject. DE-9IM: FF*FF****"@en ;
               skos:prefLabel "disjoint"@en .


###  http://www.opengis.net/ont/geosparql#sfEquals
geo:sfEquals rdf:type owl:ObjectProperty ;
             rdfs:domain geo:SpatialObject ;
             rdfs:range geo:SpatialObject ;
             rdfs:isDefinedBy geo: ,
                              <http://www.opengis.net/spec/geosparql/1.0/req/topology-vocab-extension/sf-spatial-relations> ,
                              <http://www.opengis.net/spec/geosparql/1.1/req/topology-vocab-extension/sf-spatial-relations> ;
             rdfs:seeAlso <http://dbpedia.org/resource/DE-9IM> ;
             skos:definition "States that the subject SpatialObject spatially equals the object SpatialObject. DE-9IM: TFFFTFFFT"@en ;
             skos:prefLabel "equals"@en .


###  http://www.opengis.net/ont/geosparql#sfIntersects
geo:sfIntersects rdf:type owl:ObjectProperty ;
                 rdfs:domain geo:SpatialObject ;
                 rdfs:range geo:SpatialObject ;
                 rdfs:isDefinedBy geo: ,
                                  <http://www.opengis.net/spec/geosparql/1.0/req/topology-vocab-extension/sf-spatial-relations> ,
                                  <http://www.opengis.net/spec/geosparql/1.1/req/topology-vocab-extension/sf-spatial-relations> ;
                 rdfs:seeAlso <http://dbpedia.org/resource/DE-9IM> ;
                 skos:definition "States that the subject SpatialObject is not spatially disjoint from the object SpatialObject. DE-9IM: T******** ^ *T******* ^ ***T***** ^ ****T****"@en ;
                 skos:prefLabel "intersects"@en .


###  http://www.opengis.net/ont/geosparql#sfOverlaps
geo:sfOverlaps rdf:type owl:ObjectProperty ;
               rdfs:domain geo:SpatialObject ;
               rdfs:range geo:SpatialObject ;
               rdfs:isDefinedBy geo: ,
                                <http://www.opengis.net/spec/geosparql/1.0/req/topology-vocab-extension/sf-spatial-relations> ,
                                <http://www.opengis.net/spec/geosparql/1.1/req/topology-vocab-extension/sf-spatial-relations> ;
               rdfs:seeAlso <http://dbpedia.org/resource/DE-9IM> ;
               skos:definition "States that the subject SpatialObject spatially overlaps the object SpatialObject. DE-9IM: T*T***T**"@en ;
               skos:prefLabel "overlaps"@en .


###  http://www.opengis.net/ont/geosparql#sfTouches
geo:sfTouches rdf:type owl:ObjectProperty ;
              rdfs:domain geo:SpatialObject ;
              rdfs:range geo:SpatialObject ;
              rdfs:isDefinedBy geo: ,
                               <http://www.opengis.net/spec/geosparql/1.0/req/topology-vocab-extension/sf-spatial-relations> ,
                               <http://www.opengis.net/spec/geosparql/1.1/req/topology-vocab-extension/sf-spatial-relations> ;
              rdfs:seeAlso <http://dbpedia.org/resource/DE-9IM> ;
              skos:definition "States that the subject SpatialObject spatially touches the object SpatialObject. DE-9IM: FT******* ^ F**T***** ^ F***T****"@en ;
              skos:prefLabel "touches"@en .


###  http://www.opengis.net/ont/geosparql#sfWithin
geo:sfWithin rdf:type owl:ObjectProperty ;
             rdfs:domain geo:SpatialObject ;
             rdfs:range geo:SpatialObject ;
             rdfs:isDefinedBy geo: ,
                              <http://www.opengis.net/spec/geosparql/1.0/req/topology-vocab-extension/sf-spatial-relations> ,
                              <http://www.opengis.net/spec/geosparql/1.1/req/topology-vocab-extension/sf-spatial-relations> ;
             rdfs:seeAlso <http://dbpedia.org/resource/DE-9IM> ;
             skos:definition "States that the subject SpatialObject is spatially within the object SpatialObject. DE-9IM: T*F**F***"@en ;
             skos:prefLabel "within"@en .


###  http://www.semanticweb.org/CRIMA#hasSpatialExtent
:hasSpatialExtent rdf:type owl:ObjectProperty ;
                  rdfs:range geo:SpatialObject .


###  http://www.semanticweb.org/CRIMA#hasTemporalExtent
:hasTemporalExtent rdf:type owl:ObjectProperty ;
                   owl:equivalentProperty time:hasTime .


###  http://www.semanticweb.org/CRIMA#notDisjoint
:notDisjoint rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/CRIMA#source
:source rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/CRIMA#target
:target rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/CRIMA#usedForObservation
:usedForObservation rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf sosa:usedForExecution ;
                    owl:inverseOf sosa:hasResult .


###  http://www.semanticweb.org/CRIMA/ImpactChain#isAbout
impch:isAbout rdf:type owl:ObjectProperty ;
              rdfs:range impch:ImpactChainConnection ,
                         impch:ImpactChainFactor ;
              rdfs:isDefinedBy <https://repository.ifla.org/rest/api/core/bitstreams/3016edd2-d431-4d27-84f9-33d6821f5203/content> ,
                               """\"Definition of FRBROO A Conceptual Model for Bibliographic Information in Object-Oriented Formalism\"

Prepared by: Working Group on FRBR/CRM Dialogue (also referred to as: International Working Group on
FRBR and CIDOC CRM Harmonisation), affiliated to the IFLA FRBR Review Group, reporting to the IFLA Cataloguing Section

Edited by:
Chryssoula Bekiari, Martin Doerr, Patrick Le Bœuf, Pat Riva

With contributions from:
Trond Aalberg, Jérôme Barthélémy, Chryssoula Bekiari, Guillaume Boutard, Martin Doerr, Günther Görz, Dolores Iorizzo, Max Jacob, Carlos Lamsfus, Patrick Le Bœuf, Mika Nyman, João Oliveira, Christian Emil Ore, Allen H. Renear, Pat Riva, Richard Smiraglia, Stephen Stead, Maja Žumer, and others"""@en .


###  http://www.semanticweb.org/CRIMA/ImpactChain#source
impch:source rdf:type owl:ObjectProperty ,
                      owl:FunctionalProperty ;
             rdfs:comment "[ICconnection --source--> ICFactor]: This property is meant to be used to link the reification of an impact chain binary connection with its first argument."@en .


###  http://www.semanticweb.org/CRIMA/ImpactChain#target
impch:target rdf:type owl:ObjectProperty ,
                      owl:FunctionalProperty ;
             rdfs:comment "[ICconnections --target--> ICFactor]: This property is meant to be used to link the reification of an impact chain binary connection with its secoond argument."@en .


###  http://www.w3.org/2004/02/skos/core#broader
skos:broader rdf:type owl:ObjectProperty ;
             rdfs:comment skos:broader .


###  http://www.w3.org/2004/02/skos/core#inScheme
skos:inScheme rdf:type owl:ObjectProperty ;
              rdfs:range skos:ConceptScheme .


###  http://www.w3.org/2004/02/skos/core#mappingRelation
skos:mappingRelation rdf:type owl:ObjectProperty ;
                     rdfs:comment skos:mappingRelation .


###  http://www.w3.org/2004/02/skos/core#member
skos:member rdf:type owl:ObjectProperty .


###  http://www.w3.org/2004/02/skos/core#narrower
skos:narrower rdf:type owl:ObjectProperty .


###  http://www.w3.org/2006/time#hasBeginning
time:hasBeginning rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf time:hasTime ;
                  rdfs:domain time:TemporalEntity ;
                  rdfs:range time:Instant ;
                  rdfs:label "has beginning"@en ;
                  skos:definition "Beginning of a temporal entity."@en .


###  http://www.w3.org/2006/time#hasEnd
time:hasEnd rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf time:hasTime ;
            rdfs:domain time:TemporalEntity ;
            rdfs:range time:Instant ;
            rdfs:label "has end"@en ;
            skos:definition "End of a temporal entity."@en .


###  http://www.w3.org/2006/time#hasTime
time:hasTime rdf:type owl:ObjectProperty ;
             rdfs:range time:TemporalEntity ;
             rdfs:label "has time"@en ;
             skos:definition "Supports the association of a temporal entity (instant or interval) to any thing"@en .


###  http://www.w3.org/ns/prov#hadPrimarySource
prov:hadPrimarySource rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/sosa/hasFeatureOfInterest
sosa:hasFeatureOfInterest rdf:type owl:ObjectProperty ;
                          owl:inverseOf sosa:isFeatureOfInterestOf ;
                          rdfs:label "has feature of interest"@en ;
                          skos:definition "relation from an Execution or Deployment to its subject entity i.e., from an Actuation to the entity whose property was modified; from an Observation to the entity whose quality was observed; from an act of Sampling to the entity that was sampled; or from a Deployment to its target"@en ;
                          skos:example "For example, in an Observation of the weight of a person, the FeatureOfInterest is the person and the property is its weight."@en ;
                          skos:scopeNote "This is the _proximate_ feature of interest, which may be a proxy entity such as a sample of the _ultimate_ feature of interest. Use `hasUltimateFeatureOfInterest` if the intention is to link to the _ultimate_ feature of interest. " .


###  http://www.w3.org/ns/sosa/hasInput
sosa:hasInput rdf:type owl:ObjectProperty ;
              owl:inverseOf sosa:inputFor ;
              rdfs:domain sosa:Procedure ;
              rdfs:label "has input"@en ;
              skos:definition "relation from a Procedure to an input required for its execution"@en ;
              skos:note "This property will typically describe the type of the inputs required to execute the Procedure."@en ;
              skos:scopeNote "An input might be a calibration or conditioning parameter, or the output of a previous procedure within an extended processing chain."@en .


###  http://www.w3.org/ns/sosa/hasOutput
sosa:hasOutput rdf:type owl:ObjectProperty ;
               owl:inverseOf sosa:outputFor ;
               rdfs:domain sosa:Procedure ;
               rdfs:label "has output"@en ;
               skos:definition "relation from a Procedure to an output of its execution"@en ;
               skos:note "This property will typically describe the type of the result from executing the Procedure."@en .


###  http://www.w3.org/ns/sosa/hasProcedure
sosa:hasProcedure rdf:type owl:ObjectProperty ;
                  rdfs:label "has procedure"@en ;
                  skos:definition "relation from a Property to a Procedure that can observe or act on it"@en .


###  http://www.w3.org/ns/sosa/hasProperty
sosa:hasProperty rdf:type owl:ObjectProperty ;
                 owl:inverseOf sosa:isPropertyOf ;
                 rdfs:label "has property"@en ;
                 skos:definition "relation from an entity to a Property of that entity"@en .


###  http://www.w3.org/ns/sosa/hasResult
sosa:hasResult rdf:type owl:ObjectProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain sosa:Observation ;
               rdfs:range sosa:Result ;
               rdfs:comment sosa:hasResult ,
                            "Relation linking an Observation or Actuation or act of Sampling and a Result or Sample."@en ;
               rdfs:label "has result"@en ,
                          "hasResult"@en ;
               skos:definition "Relation linking an Observation or Actuation or act of Sampling and a Result or Sample."@en .


###  http://www.w3.org/ns/sosa/hosts
sosa:hosts rdf:type owl:ObjectProperty ;
           owl:inverseOf sosa:isHostedBy ;
           rdfs:domain sosa:Platform ;
           rdfs:range [ rdf:type owl:Class ;
                        owl:unionOf ( sosa:Platform
                                      sosa:System
                                    )
                      ] .


###  http://www.w3.org/ns/sosa/inputFor
sosa:inputFor rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/sosa/isFeatureOfInterestOf
sosa:isFeatureOfInterestOf rdf:type owl:ObjectProperty ;
                           rdfs:domain sosa:FeatureOfInterest ;
                           rdfs:range sosa:Observation ;
                           rdfs:comment sosa:isFeatureOfInterestOf ;
                           rdfs:label "is feature of interest of"@en ;
                           skos:definition "relation from a FeatureOfInterest to an Execution, Execution Collection, or Deployment, operating on it i.e., to an Observation about it, to an Actuation acting on it, to an act of Sampling that sampled it, or to a Deployment for which it is the subject."@en .


###  http://www.w3.org/ns/sosa/isHostedBy
sosa:isHostedBy rdf:type owl:ObjectProperty ;
                rdfs:domain [ rdf:type owl:Class ;
                              owl:unionOf ( sosa:Platform
                                            sosa:System
                                          )
                            ] ;
                rdfs:range sosa:Platform ;
                rdfs:label "is hosted by"@en ;
                skos:definition "relation from an asset (System or Platform), to a Platform that it is mounted on or hosted by"@en .


###  http://www.w3.org/ns/sosa/isObservedBy
sosa:isObservedBy rdf:type owl:ObjectProperty ;
                  owl:inverseOf sosa:observes ;
                  rdfs:domain sosa:ObservableProperty ;
                  rdfs:range sosa:Sensor ;
                  rdfs:label "is observed by"@en ;
                  skos:definition "relation from a Property to a Sensor that is able to observe it"@en .


###  http://www.w3.org/ns/sosa/isPropertyOf
sosa:isPropertyOf rdf:type owl:ObjectProperty ;
                  rdfs:domain sosa:Property ;
                  rdfs:range sosa:FeatureOfInterest ;
                  rdfs:comment sosa:isPropertyOf ;
                  rdfs:label "is property of"@en ;
                  skos:definition "relation from a Property to a FeatureOfInterest that it is a quality of"@en .


###  http://www.w3.org/ns/sosa/madeBySensor
sosa:madeBySensor rdf:type owl:ObjectProperty ;
                  owl:inverseOf sosa:madeObservation ;
                  rdfs:domain sosa:Observation ;
                  rdfs:range sosa:Sensor ;
                  rdfs:label "made by sensor or observer"@en ;
                  skos:definition "relation from an Observation or ObservationCollection to the Sensor that made it"@en .


###  http://www.w3.org/ns/sosa/madeObservation
sosa:madeObservation rdf:type owl:ObjectProperty ;
                     rdfs:domain sosa:Sensor ;
                     rdfs:range sosa:Observation ;
                     rdfs:label "made observation"@en ;
                     skos:definition "relation from a Sensor to an Observation or ObservationCollection it has made"@en .


###  http://www.w3.org/ns/sosa/observedProperty
sosa:observedProperty rdf:type owl:ObjectProperty ;
                      rdfs:domain sosa:Observation ;
                      rdfs:range sosa:ObservableProperty ;
                      rdfs:comment sosa:observedProperty .


###  http://www.w3.org/ns/sosa/observes
sosa:observes rdf:type owl:ObjectProperty ;
              rdfs:domain sosa:Sensor ;
              rdfs:range sosa:ObservableProperty ;
              rdfs:label "observes"@en ;
              skos:definition "relation from a Sensor to a Property that it is capable of sensing"@en .


###  http://www.w3.org/ns/sosa/outputFor
sosa:outputFor rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/sosa/usedForExecution
sosa:usedForExecution rdf:type owl:ObjectProperty ;
                      rdfs:domain sosa:Procedure ;
                      rdfs:range sosa:Observation ;
                      rdfs:label "used for execution"@en ;
                      skos:definition "relation from a Procedure to an Execution or ExecutionCollection made using it"@en .


###  http://www.w3.org/ns/sosa/usedProcedure
sosa:usedProcedure rdf:type owl:ObjectProperty ;
                   rdfs:domain sosa:Observation ;
                   rdfs:range sosa:Procedure ;
                   rdfs:label "used procedure"@en ;
                   skos:definition "relation from an Execution or ExecutionCollection to a Procedure used to make it"@en .


###  https://undrr-hip.org/broader
hip:broader rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf skos:broader ;
            owl:inverseOf hip:narrower ;
            rdfs:label "broader" .


###  https://undrr-hip.org/coordinationOrganization
hip:coordinationOrganization rdf:type owl:ObjectProperty ;
                             rdfs:subPropertyOf prov:hadPrimarySource .


###  https://undrr-hip.org/definedAs
hip:definedAs rdf:type owl:ObjectProperty ;
              rdfs:label "defined as" .


###  https://undrr-hip.org/definitionSource
hip:definitionSource rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf prov:hadPrimarySource .


###  https://undrr-hip.org/describedAs
hip:describedAs rdf:type owl:ObjectProperty ;
                rdfs:label "described as" .


###  https://undrr-hip.org/hasMember
hip:hasMember rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf skos:member ;
              owl:inverseOf hip:isMemberOf ;
              rdfs:label "has member" .


###  https://undrr-hip.org/isMemberOf
hip:isMemberOf rdf:type owl:ObjectProperty ;
               rdfs:label "is member of" .


###  https://undrr-hip.org/narrower
hip:narrower rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf skos:narrower ;
             rdfs:label "narrower" .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#atomicPartOf
db:atomicPartOf rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf db:partOf ;
                rdfs:domain db:Atom ;
                rdfs:range [ rdf:type owl:Class ;
                             owl:unionOf ( db:Abstract
                                           db:Perdurant
                                         )
                           ] ;
                ace_lexicon:TV_pl "atomic parts of" ;
                ace_lexicon:TV_sg "atomic part of" ;
                rdfs:comment "atomicPartOf is the specialization of the PartOf relation to the case that the part argument is a mereological atom" ;
                rdfs:label "atomic part of" .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#constantAtomicPartOf
db:constantAtomicPartOf rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf db:constantPartOf ;
                        rdfs:domain db:ConstantAtom ;
                        rdfs:range db:Endurant ;
                        ace_lexicon:TV_pl "constant atomic parts of" ;
                        ace_lexicon:TV_sg "constant atomic part of" ;
                        rdfs:comment "constantAtomicPartOf is the specialization of the ConstantPartOf relation to the case that the part argument is a mereological atom" ;
                        rdfs:label "constant atomic part of" .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#constantConstituentOf
db:constantConstituentOf rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf _:genid10 ;
                         rdf:type owl:TransitiveProperty ;
                         rdfs:domain _:genid13 ;
                         rdfs:range _:genid18 ;
                         ace_lexicon:TV_pl "are constant constituent of" ;
                         ace_lexicon:TV_sg "is constant constituent of" ;
                         ace_lexicon:TV_vbg "constantly constituted" ;
                         rdfs:comment """constantConstituentOf is the constant version of Constitution which is a ternary relation between two endurants x, y and time interval t or between two perdurants x, y and time interval t. The intended interpretation is that x constitutes y over the time interval t.
In this constant version, the entity x constitutes y during the whole existence of y.""" ;
                         rdfs:label "constant constituent of" .

_:genid10 owl:inverseOf db:specificallyDependsOn .

_:genid13 rdf:type owl:Class ;
           owl:unionOf ( db:NonPhysicalEndurant
                         db:Perdurant
                         db:PhysicalEndurant
                       ) .

_:genid18 rdf:type owl:Class ;
           owl:unionOf ( db:NonPhysicalEndurant
                         db:Perdurant
                         db:PhysicalEndurant
                       ) .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:constantConstituentOf ;
   owl:annotatedProperty rdfs:subPropertyOf ;
   owl:annotatedTarget _:genid10 ;
   rdfs:comment "If X is constant constituent of Y then Y specifically depends on X."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:constantConstituentOf ;
   owl:annotatedProperty rdf:type ;
   owl:annotatedTarget owl:TransitiveProperty ;
   rdfs:comment "If X is constant constituent of something that is constant constituent of Y then X is constant constituent of Y."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:constantConstituentOf ;
   owl:annotatedProperty rdfs:domain ;
   owl:annotatedTarget _:genid13 ;
   rdfs:comment "Everything that is constant constituent of something is something that is a non physical endurant or that is a perdurant or that is a physical endurant."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:constantConstituentOf ;
   owl:annotatedProperty rdfs:range ;
   owl:annotatedTarget _:genid18 ;
   rdfs:comment "Everything that is constantly constituted by something is something that is a non physical endurant or that is a perdurant or that is a physical endurant."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#constantPartOf
db:constantPartOf rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf db:constantlyOverlaps ;
                  rdf:type owl:TransitiveProperty ;
                  rdfs:domain db:Endurant ;
                  rdfs:range db:Endurant ;
                  ace_lexicon:TV_pl "are constant part of" ;
                  ace_lexicon:TV_sg "is constant part of" ;
                  ace_lexicon:TV_vbg "constantly divided into parts" ;
                  rdfs:comment """ConstantPartOf is the constant version of Temporary Parthood which is a ternary relation between two endurants x, y and a time interval t. The intended interpretation is that the endurant x is a part of the endurant y over the time interval t.
In this constant version, the endurant x is part of the endurant y during the whole existence of y.""" ;
                  rdfs:label "constant part of" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:constantPartOf ;
   owl:annotatedProperty rdfs:subPropertyOf ;
   owl:annotatedTarget db:constantlyOverlaps ;
   rdfs:comment "If X is constant part of Y then X constantly overlaps Y."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:constantPartOf ;
   owl:annotatedProperty rdf:type ;
   owl:annotatedTarget owl:TransitiveProperty ;
   rdfs:comment "If X is constant part of something that is constant part of Y then X is constant part of Y."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:constantPartOf ;
   owl:annotatedProperty rdfs:domain ;
   owl:annotatedTarget db:Endurant ;
   rdfs:comment "Everything that is constant part of something is an endurant." ,
                "From Dd25, Ad10"
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:constantPartOf ;
   owl:annotatedProperty rdfs:range ;
   owl:annotatedTarget db:Endurant ;
   rdfs:comment "Everything that has something as constant part is an endurant." ,
                "From Dd25, Ad10"
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#constantParticipantOf
db:constantParticipantOf rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf _:genid27 ;
                         rdfs:domain db:Endurant ;
                         rdfs:range db:Perdurant ;
                         ace_lexicon:TV_pl "are constant participants of" ;
                         ace_lexicon:TV_sg "is constant participant of" ;
                         ace_lexicon:TV_vbg "constantly participated" ;
                         rdfs:comment """constantParticipantOf is the constant version of Participation which is a ternary relation between an endurant x, a perdurant y, and a time interval t. The intended interpretation is that x participates in y at time t. Every perdurant has at least an endurant that participates in it, and every endurant participates in some perdurant. 
In this constant version, the endurant x participates in the perdurant y during the whole existence of y.""" ;
                         rdfs:label "constant participation of" .

_:genid27 owl:inverseOf db:specificallyDependsOn .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:constantParticipantOf ;
   owl:annotatedProperty rdfs:subPropertyOf ;
   owl:annotatedTarget _:genid27 ;
   rdfs:comment "If X is constant participant of Y then Y specifically depends on X."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:constantParticipantOf ;
   owl:annotatedProperty rdfs:domain ;
   owl:annotatedTarget db:Endurant ;
   rdfs:comment "Everything that is constant participant of something is an endurant."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:constantParticipantOf ;
   owl:annotatedProperty rdfs:range ;
   owl:annotatedTarget db:Perdurant ;
   rdfs:comment "Everything that is constantly participated by something is a perdurant."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#constantProperPartOf
db:constantProperPartOf rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf db:constantPartOf ;
                        rdf:type owl:TransitiveProperty ;
                        rdfs:domain db:Endurant ;
                        rdfs:range db:Endurant ;
                        ace_lexicon:TV_pl "are constant proper part of" ;
                        ace_lexicon:TV_sg "is constant proper part of" ;
                        ace_lexicon:TV_vbg "constantly divided into proper parts" ;
                        rdfs:comment "constantProperPartOf is the irreflexive specialization of the constantPartOf relation." ;
                        rdfs:label "constant proper part of" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:constantProperPartOf ;
   owl:annotatedProperty rdfs:subPropertyOf ;
   owl:annotatedTarget db:constantPartOf ;
   rdfs:comment "If X is constant proper part of Y then X is constant part of Y."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:constantProperPartOf ;
   owl:annotatedProperty rdf:type ;
   owl:annotatedTarget owl:TransitiveProperty ;
   rdfs:comment "If X is constant proper part of something that is constant proper part of Y then X is constant proper part of Y."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:constantProperPartOf ;
   owl:annotatedProperty rdfs:domain ;
   owl:annotatedTarget db:Endurant ;
   rdfs:comment "Everything that is constant proper part of something is an endurant."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:constantProperPartOf ;
   owl:annotatedProperty rdfs:range ;
   owl:annotatedTarget db:Endurant ;
   rdfs:comment "Everything that has something as a constant proper part is an endurant."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#constantQualeOf
db:constantQualeOf rdf:type owl:ObjectProperty ;
                   rdfs:domain _:genid35 ;
                   rdfs:range _:genid39 ;
                   ace_lexicon:TV_pl "are constant quale of" ;
                   ace_lexicon:TV_sg "is constant quale of" ;
                   ace_lexicon:TV_vbg "the value of the constant quale relation taken" ;
                   rdfs:comment """constantQualeOf is the constant version of Temporary Quale Of which is a ternary relation among a physical region x, a physical quality y and a time interval t or among an abstract region x, an abstract quality y and a time interval t. It relates the quality to its quale (position) at a certain time.
In this constant version, the region x is the quale of the quality y during the whole existence of y.""" ;
                   rdfs:label "constant quale of" .

_:genid35 rdf:type owl:Class ;
           owl:unionOf ( db:AbstractRegion
                         db:PhysicalRegion
                       ) .

_:genid39 rdf:type owl:Class ;
           owl:unionOf ( db:AbstractQuality
                         db:PhysicalQuality
                       ) .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:constantQualeOf ;
   owl:annotatedProperty rdfs:domain ;
   owl:annotatedTarget _:genid35 ;
   rdfs:comment "Everything that is constant quale of something is something that is an abstract region or that is a physical region."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:constantQualeOf ;
   owl:annotatedProperty rdfs:range ;
   owl:annotatedTarget _:genid39 ;
   rdfs:comment "Everything that has something as constant quale is something that is an abstract quality or that is a physical quality."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#constantlyOverlaps
db:constantlyOverlaps rdf:type owl:ObjectProperty ,
                               owl:SymmetricProperty ;
                      rdfs:domain db:Endurant ;
                      rdfs:range db:Endurant ;
                      owl:propertyChainAxiom _:genid47 ;
                      ace_lexicon:TV_pl "constantly overlaps" ;
                      ace_lexicon:TV_sg "constantly overlaps" ;
                      ace_lexicon:TV_vbg "constantly overlapped" ;
                      rdfs:comment "constantlyOverlaps holds between two endurants that share a constant part, and are such that the time intervals at which they are temporally located overlap." ;
                      rdfs:label "constantly overlaps" .

_:genid47 rdf:type rdf:List ;
           rdf:first [ owl:inverseOf db:constantPartOf
                     ] ;
           rdf:rest ( db:constantPartOf
                    ) .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:constantlyOverlaps ;
   owl:annotatedProperty rdf:type ;
   owl:annotatedTarget owl:SymmetricProperty ;
   rdfs:comment "If X constantly overlaps Y then Y constantly overlaps X."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:constantlyOverlaps ;
   owl:annotatedProperty rdfs:domain ;
   owl:annotatedTarget db:Endurant ;
   rdfs:comment "Everything that constantly overlaps something is an endurant."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:constantlyOverlaps ;
   owl:annotatedProperty rdfs:range ;
   owl:annotatedTarget db:Endurant ;
   rdfs:comment "Everything that is constantly overlapped by something is an endurant."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:constantlyOverlaps ;
   owl:annotatedProperty owl:propertyChainAxiom ;
   owl:annotatedTarget _:genid47 ;
   rdfs:comment "If X has something that is a constant part of Y as constant part then X constantly overlaps Y."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#directQualityOf
db:directQualityOf rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf db:specificallyDependsOn ;
                   rdf:type owl:FunctionalProperty ;
                   rdfs:domain db:Quality ;
                   rdfs:range _:genid53 ;
                   ace_lexicon:TV_pl "are direct quality of" ;
                   ace_lexicon:TV_sg "is direct quality of" ;
                   ace_lexicon:TV_vbg "qualified" ;
                   rdfs:comment "directQualityOf is a binary relation between a quality and the unique entity it inheres in, which is an endurant or a perdurant. It implies specific constant dependence." ;
                   rdfs:label "direct quality of" .

_:genid53 rdf:type owl:Class ;
           owl:unionOf ( db:Endurant
                         db:Perdurant
                       ) .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:directQualityOf ;
   owl:annotatedProperty rdfs:subPropertyOf ;
   owl:annotatedTarget db:specificallyDependsOn ;
   rdfs:comment "If X is direct quality of Y then X specifically depends on Y."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:directQualityOf ;
   owl:annotatedProperty rdf:type ;
   owl:annotatedTarget owl:FunctionalProperty ;
   rdfs:comment "Everything is direct quality of at most 1 thing."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:directQualityOf ;
   owl:annotatedProperty rdfs:domain ;
   owl:annotatedTarget db:Quality ;
   rdfs:comment "Dd28, Ad38" ,
                "Everything that is direct quality of something is a quality."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:directQualityOf ;
   owl:annotatedProperty rdfs:range ;
   owl:annotatedTarget _:genid53 ;
   rdfs:comment "Everything that has something as direct quality is something that is an endurant or that is a perdurant." ,
                "From Dd28, Ad38, Ad43, Ad46, Ad47, Ad48"
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#overlaps
db:overlaps rdf:type owl:ObjectProperty ,
                     owl:SymmetricProperty ;
            rdfs:domain _:genid58 ;
            rdfs:range _:genid62 ;
            owl:propertyChainAxiom _:genid67 ,
                                   _:genid71 ;
            ace_lexicon:TV_pl "overlap" ;
            ace_lexicon:TV_sg "overlaps" ;
            ace_lexicon:TV_vbg "overlapped" ;
            rdfs:comment "overlaps holds between two abstracts or two perdurants when they both share a part." ;
            rdfs:label "overlaps" .

_:genid58 rdf:type owl:Class ;
           owl:unionOf ( db:Abstract
                         db:Perdurant
                       ) .

_:genid62 rdf:type owl:Class ;
           owl:unionOf ( db:Abstract
                         db:Perdurant
                       ) .

_:genid67 rdf:type rdf:List ;
           rdf:first [ owl:inverseOf db:partOf
                     ] ;
           rdf:rest ( db:partOf
                    ) .

_:genid71 rdf:type rdf:List ;
           rdf:first [ owl:inverseOf db:presentAt
                     ] ;
           rdf:rest ( db:temporallyLocatedAt
                    ) .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:overlaps ;
   owl:annotatedProperty rdf:type ;
   owl:annotatedTarget owl:SymmetricProperty ;
   rdfs:comment "If X overlaps Y then Y overlaps X."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:overlaps ;
   owl:annotatedProperty rdfs:domain ;
   owl:annotatedTarget _:genid58 ;
   rdfs:comment "Everything that overlaps something is something that is an abstract or that is a perdurant." ,
                "From Ad1 and Dd15"
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:overlaps ;
   owl:annotatedProperty rdfs:range ;
   owl:annotatedTarget _:genid62 ;
   rdfs:comment "Everything that is overlapped by something is something that is an abstract or that is a perdurant." ,
                "From Ad1 and Dd15"
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:overlaps ;
   owl:annotatedProperty owl:propertyChainAxiom ;
   owl:annotatedTarget _:genid67 ;
   rdfs:comment "D15 (half)" ,
                "If X has something that is part of Y as part then X overlaps Y."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:overlaps ;
   owl:annotatedProperty owl:propertyChainAxiom ;
   owl:annotatedTarget _:genid71 ;
   rdfs:comment "Approximation of half of Dd40" ,
                "If X is a time of presence of something which is temporally located at Y then X overlaps Y."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#partOf
db:partOf rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf db:overlaps ;
          rdf:type owl:TransitiveProperty ;
          rdfs:domain _:genid76 ;
          rdfs:range _:genid80 ;
          ace_lexicon:TV_pl "are part of" ;
          ace_lexicon:TV_sg "is part of" ;
          ace_lexicon:TV_vbg "divided into parts" ;
          rdfs:comment "PartOf is a binary relation that is a partial ordering between abstract entities or between perdurants. It founds an extensional mereology on each of these two categories." ;
          rdfs:label "part of" .

_:genid76 rdf:type owl:Class ;
           owl:unionOf ( db:Abstract
                         db:Perdurant
                       ) .

_:genid80 rdf:type owl:Class ;
           owl:unionOf ( db:Abstract
                         db:Perdurant
                       ) .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:partOf ;
   owl:annotatedProperty rdfs:subPropertyOf ;
   owl:annotatedTarget db:overlaps ;
   rdfs:comment "From Ad5 and Dd15" ,
                "If X is part of Y then X overlaps Y."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:partOf ;
   owl:annotatedProperty rdf:type ;
   owl:annotatedTarget owl:TransitiveProperty ;
   rdfs:comment "If X is part of something that is part of Y then X is part of Y."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:partOf ;
   owl:annotatedProperty rdfs:domain ;
   owl:annotatedTarget _:genid76 ;
   rdfs:comment "Ad1 (half)" ,
                "Everything that is part of something is something that is an abstract or that is a perdurant."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:partOf ;
   owl:annotatedProperty rdfs:range ;
   owl:annotatedTarget _:genid80 ;
   rdfs:comment "Ad1 (half)" ,
                "Everything that is has something as part is something that is an abstract or that is a perdurant."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#presentAt
db:presentAt rdf:type owl:ObjectProperty ;
             rdfs:domain _:genid84 ;
             rdfs:range db:TimeInterval ;
             owl:propertyChainAxiom _:genid91 ,
                                    _:genid94 ,
                                    _:genid97 ,
                                    _:genid100 ,
                                    _:genid103 ,
                                    _:genid106 ,
                                    _:genid110 ,
                                    _:genid113 ,
                                    _:genid117 ,
                                    _:genid121 ;
             ace_lexicon:TV_pl "are present at" ;
             ace_lexicon:TV_sg "is present at" ;
             ace_lexicon:TV_vbg "the value of the present at relation taken" ;
             rdfs:comment "presentAt is a binary relation between an endurant or a perdurant or a quality x and a time interval t which is part of x's temporal location." ;
             rdfs:label "present at" .

_:genid84 rdf:type owl:Class ;
           owl:unionOf ( db:Endurant
                         db:Perdurant
                         db:Quality
                       ) .

_:genid91 rdf:type rdf:List ;
           rdf:first db:constantAtomicPartOf ;
           rdf:rest ( db:presentAt
                    ) .

_:genid94 rdf:type rdf:List ;
           rdf:first db:constantConstituentOf ;
           rdf:rest ( db:presentAt
                    ) .

_:genid97 rdf:type rdf:List ;
           rdf:first db:constantPartOf ;
           rdf:rest ( db:presentAt
                    ) .

_:genid100 rdf:type rdf:List ;
            rdf:first db:constantParticipantOf ;
            rdf:rest ( db:presentAt
                     ) .

_:genid103 rdf:type rdf:List ;
            rdf:first db:constantProperPartOf ;
            rdf:rest ( db:presentAt
                     ) .

_:genid106 rdf:type rdf:List ;
            rdf:first db:directQualityOf ;
            rdf:rest ( db:presentAt
                     ) .

_:genid110 rdf:type rdf:List ;
            rdf:first db:presentAt ;
            rdf:rest ( [ owl:inverseOf db:partOf
                       ]
                     ) .

_:genid113 rdf:type rdf:List ;
            rdf:first [ owl:inverseOf db:directQualityOf
                      ] ;
            rdf:rest ( db:presentAt
                     ) .

_:genid117 rdf:type rdf:List ;
            rdf:first [ owl:inverseOf db:partOf
                      ] ;
            rdf:rest ( db:presentAt
                     ) .

_:genid121 rdf:type rdf:List ;
            rdf:first [ owl:inverseOf db:specificallyDependsOn
                      ] ;
            rdf:rest ( db:presentAt
                     ) .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:presentAt ;
   owl:annotatedProperty owl:propertyChainAxiom ;
   owl:annotatedTarget _:genid100 ;
   rdfs:comment "If X is constant participant of something that is present at Y then X is present at Y."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:presentAt ;
   owl:annotatedProperty owl:propertyChainAxiom ;
   owl:annotatedTarget _:genid103 ;
   rdfs:comment "If X is constant proper part of something that is present at Y then X is present at Y."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:presentAt ;
   owl:annotatedProperty owl:propertyChainAxiom ;
   owl:annotatedTarget _:genid106 ;
   rdfs:comment "Dd28, Dd32, Dd33, Dd34, Dd40" ,
                "If X is a direct quality of something that is present at Y then X is present at Y."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:presentAt ;
   owl:annotatedProperty owl:propertyChainAxiom ;
   owl:annotatedTarget _:genid110 ;
   rdfs:comment "If X is present at something that has Y as part then X is present at Y." ,
                "Td17"
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:presentAt ;
   owl:annotatedProperty owl:propertyChainAxiom ;
   owl:annotatedTarget _:genid113 ;
   rdfs:comment "Dd28, Dd32, Dd33, Dd34, Dd40" ,
                "If X has something that is present at Y as direct quality then X is present at Y."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:presentAt ;
   owl:annotatedProperty owl:propertyChainAxiom ;
   owl:annotatedTarget _:genid117 ;
   rdfs:comment "If X has something that is present at Y as part then X is present at Y."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:presentAt ;
   owl:annotatedProperty owl:propertyChainAxiom ;
   owl:annotatedTarget _:genid121 ;
   rdfs:comment "Approximation of Dd69" ,
                "If X is specifically depended on by something that is present at Y then X is present at Y."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:presentAt ;
   owl:annotatedProperty rdfs:domain ;
   owl:annotatedTarget _:genid84 ;
   rdfs:comment "Everything that is present at something is something that is an endurant or that is a perdurant or that is a quality." ,
                "From Dd40, Dd30, Dd31, Dd32, Dd33"
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:presentAt ;
   owl:annotatedProperty rdfs:range ;
   owl:annotatedTarget db:TimeInterval ;
   rdfs:comment "Everything that is the value of the present at relation is a time interval." ,
                "From Dd40, Dd30, Dd31, Dd32, Dd33"
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:presentAt ;
   owl:annotatedProperty owl:propertyChainAxiom ;
   owl:annotatedTarget _:genid91 ;
   rdfs:comment "If X is constant atomic part of something that is present at Y then X is present at Y."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:presentAt ;
   owl:annotatedProperty owl:propertyChainAxiom ;
   owl:annotatedTarget _:genid94 ;
   rdfs:comment "If X is constant constituent of something that is present at Y then X is present at Y."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:presentAt ;
   owl:annotatedProperty owl:propertyChainAxiom ;
   owl:annotatedTarget _:genid97 ;
   rdfs:comment "If X is constant part of something that is present at Y then X is present at Y."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#properPartOf
db:properPartOf rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf db:partOf ;
                rdf:type owl:TransitiveProperty ;
                rdfs:domain _:genid126 ;
                rdfs:range _:genid130 ;
                ace_lexicon:TV_pl "are proper part of" ;
                ace_lexicon:TV_sg "is proper part of" ;
                ace_lexicon:TV_vbg "divided into proper parts" ;
                rdfs:comment "properPartOf is the irreflexive specialization of the partOf relation. (Irreflexivity not captured here, as transitivity is favored)" ;
                rdfs:label "proper part of" .

_:genid126 rdf:type owl:Class ;
            owl:unionOf ( db:Abstract
                          db:Perdurant
                        ) .

_:genid130 rdf:type owl:Class ;
            owl:unionOf ( db:Abstract
                          db:Perdurant
                        ) .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:properPartOf ;
   owl:annotatedProperty rdfs:subPropertyOf ;
   owl:annotatedTarget db:partOf ;
   rdfs:comment """D14 (half)
irreflexivity impossible (property implies domain=Thing, and use of Self incompatible with transitivity)""" ,
                "If X is proper part of Y then X is part of Y."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:properPartOf ;
   owl:annotatedProperty rdf:type ;
   owl:annotatedTarget owl:TransitiveProperty ;
   rdfs:comment "If X is proper part of something that is proper part of Y then X is proper part of Y."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:properPartOf ;
   owl:annotatedProperty rdfs:domain ;
   owl:annotatedTarget _:genid126 ;
   rdfs:comment "Everything that is proper part of something is something that is an abstract or that is a perdurant."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:properPartOf ;
   owl:annotatedProperty rdfs:range ;
   owl:annotatedTarget _:genid130 ;
   rdfs:comment "Everything that has something as proper part is something that is an abstract or that is a perdurant."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#qualeOf
db:qualeOf rdf:type owl:ObjectProperty ,
                    owl:InverseFunctionalProperty ;
           rdfs:domain db:TemporalRegion ;
           rdfs:range db:TemporalQuality ;
           ace_lexicon:TV_pl "are quale of" ;
           ace_lexicon:TV_sg "is quale of" ;
           ace_lexicon:TV_vbg "valorized through the is quale of relation" ;
           rdfs:comment "aka immediate quale" ,
                        "qualeOf is a binary relation between a temporal region and a temporal quality, relating the quality to its quale (position in the quality space)." ;
           rdfs:label "quale of" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:qualeOf ;
   owl:annotatedProperty rdfs:domain ;
   owl:annotatedTarget db:TemporalRegion ;
   rdfs:comment "Ad52" ,
                "Everything that is quale of something is a temporal region."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:qualeOf ;
   owl:annotatedProperty rdfs:range ;
   owl:annotatedTarget db:TemporalQuality ;
   rdfs:comment "Ad52" ,
                "Everything has something as a quale is a temporal quality."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#specificallyDependsOn
db:specificallyDependsOn rdf:type owl:ObjectProperty ,
                                  owl:TransitiveProperty ;
                         rdfs:domain _:genid137 ;
                         rdfs:range _:genid142 ;
                         ace_lexicon:TV_pl "specifically depends on" ;
                         ace_lexicon:TV_sg "specifically depends on" ;
                         ace_lexicon:TV_vbg "specifically depended on" ;
                         rdfs:comment "Specific Constant Dependence" ,
                                      "specificallyDependsOn is a binary relation between two entities x, y present in time, i.e., endurants, perdurants or qualities, with the intended interpretation that the existence of x specifically and constantly depends on the existence of y." ;
                         rdfs:label "specifically depends on" .

_:genid137 rdf:type owl:Class ;
            owl:unionOf ( db:Endurant
                          db:Perdurant
                          db:Quality
                        ) .

_:genid142 rdf:type owl:Class ;
            owl:unionOf ( db:Endurant
                          db:Perdurant
                          db:Quality
                        ) .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:specificallyDependsOn ;
   owl:annotatedProperty rdf:type ;
   owl:annotatedTarget owl:TransitiveProperty ;
   rdfs:comment "If X specifically depends on something that specifically depends on Y then X specifically depends on Y."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:specificallyDependsOn ;
   owl:annotatedProperty rdfs:domain ;
   owl:annotatedTarget _:genid137 ;
   rdfs:comment "Everything that specifically depends on something is something that is an endurant or that is a perdurant or that is a quality." ,
                "From Dd69"
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:specificallyDependsOn ;
   owl:annotatedProperty rdfs:range ;
   owl:annotatedTarget _:genid142 ;
   rdfs:comment "Everything that is specifically depended on by something is something that is an endurant or that is a perdurant or that is a quality." ,
                "From Dd69"
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#temporalPartOf
db:temporalPartOf rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf db:partOf ;
                  rdf:type owl:TransitiveProperty ;
                  rdfs:domain db:Perdurant ;
                  rdfs:range db:Perdurant ;
                  ace_lexicon:TV_pl "are temporal parts of" ;
                  ace_lexicon:TV_sg "is temporal part of" ;
                  ace_lexicon:TV_vbg "divided into temporal parts" ;
                  rdfs:comment "temporalPartOf is the specialisation of the partOf relation between two perdurants x and y, x being a temporal slice of y, that is, a maximal part of y during some time interval." ;
                  rdfs:label "temporal part of" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:temporalPartOf ;
   owl:annotatedProperty rdfs:subPropertyOf ;
   owl:annotatedTarget db:partOf ;
   rdfs:comment "Dd54 (third)" ,
                "If X is temporal part of Y then X is part of Y."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:temporalPartOf ;
   owl:annotatedProperty rdf:type ;
   owl:annotatedTarget owl:TransitiveProperty ;
   rdfs:comment "If X is temporal part of something that is temporal part of Y then X is temporal part of Y."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:temporalPartOf ;
   owl:annotatedProperty rdfs:domain ;
   owl:annotatedTarget db:Perdurant ;
   rdfs:comment "Dd54 (third)" ,
                "Everything that is temporal part of something is a perdurant."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:temporalPartOf ;
   owl:annotatedProperty rdfs:range ;
   owl:annotatedTarget db:Perdurant ;
   rdfs:comment "Everything that has something as temporal part is a perdurant." ,
                "From Dd54 and Ad2"
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#temporallyLocatedAt
db:temporallyLocatedAt rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf db:presentAt ;
                       rdf:type owl:FunctionalProperty ;
                       rdfs:domain _:genid153 ;
                       rdfs:range db:TimeInterval ;
                       ace_lexicon:TV_pl "are temporally located at" ;
                       ace_lexicon:TV_sg "is temporally located at" ;
                       ace_lexicon:TV_vbg "the value of the temporal location relation taken" ;
                       rdfs:comment "temporallyLocatedAt is a binary relation between an endurant or a perdurant or a quality and the unique time interval it is exactly located in." ;
                       rdfs:label "temporally located at" .

_:genid153 rdf:type owl:Class ;
            owl:unionOf ( db:Endurant
                          db:Perdurant
                          db:Quality
                        ) .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:temporallyLocatedAt ;
   owl:annotatedProperty rdfs:subPropertyOf ;
   owl:annotatedTarget db:presentAt ;
   rdfs:comment "Dd40 + Ad5" ,
                "If X is temporally located at Y then X is present at Y."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:temporallyLocatedAt ;
   owl:annotatedProperty rdf:type ;
   owl:annotatedTarget owl:FunctionalProperty ;
   rdfs:comment "Everything is temporally located at at most 1 thing."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:temporallyLocatedAt ;
   owl:annotatedProperty rdfs:domain ;
   owl:annotatedTarget _:genid153 ;
   rdfs:comment "Everything that is temporally located at something is something that is an endurant or that is a perdurant or that is a quality."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource db:temporallyLocatedAt ;
   owl:annotatedProperty rdfs:range ;
   owl:annotatedTarget db:TimeInterval ;
   rdfs:comment "Everything that is the value of the temporal location relation is a time interval."
 ] .


#################################################################
#    Data properties
#################################################################

###  http://purl.org/dc/terms/bibliographicCitation
dcterms:bibliographicCitation rdf:type owl:DatatypeProperty .


###  http://purl.org/dc/terms/identifier
dcterms:identifier rdf:type owl:DatatypeProperty .


###  http://qudt.org/schema/qudt/numericValue
qudt:numericValue rdf:type owl:DatatypeProperty ;
                  rdfs:range dtype:numericUnion ;
                  rdfs:label "numeric value" .


###  http://www.opengis.net/ont/geosparql#asWKT
geo:asWKT rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf geo:hasSerialization ;
          rdfs:domain geo:Geometry ;
          rdfs:range geo:wktLiteral ;
          skos:definition "The WKT serialization of a Geometry."@en ;
          skos:prefLabel "as WKT"@en .


###  http://www.opengis.net/ont/geosparql#hasSerialization
geo:hasSerialization rdf:type owl:DatatypeProperty ;
                     rdfs:domain geo:Geometry ;
                     rdfs:range rdfs:Literal ;
                     skos:definition "Connects a Geometry object with its text-based serialization."@en ;
                     skos:prefLabel "has serialization"@en .


###  https://undrr-hip.org/identifier
hip:identifier rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf dcterms:identifier .


###  https://www.w3.org/ns/activitystreams#latitude
as:latitude rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf geo:hasSerialization ;
            rdf:type owl:FunctionalProperty ;
            rdfs:domain as:Place ;
            rdfs:range xsd:float ;
            rdfs:comment "The latitude"@en ;
            rdfs:label "latitude"@en .


###  https://www.w3.org/ns/activitystreams#longitude
as:longitude rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf geo:hasSerialization ;
             rdf:type owl:FunctionalProperty ;
             rdfs:domain as:Place ;
             rdfs:range xsd:float ;
             rdfs:comment "The longitude"@en ;
             rdfs:label "longitude"@en .


