           hip:identifier "BI0040" .


hip:BI0041 rdfs:label "Shigellosis (Human)" ;
           hip:identifier "BI0041" .


hip:BI0042 rdfs:label "Avian Influenza (Human and Animal)" ;
           hip:identifier "BI0042" ;
           hip:synonym "Avian Flu" ,
                       "Bird Flu" .


