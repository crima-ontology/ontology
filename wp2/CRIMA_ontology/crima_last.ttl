#    Annotations
#################################################################

hip:BI0001 rdfs:label "Harmful Algal Blooms" ;
            hip:identifier "BI0001" ;
            hip:synonym "HABs" .


hip:BI0002 rdfs:label "Insect Pest Infestations" ;
           hip:identifier "BI0002" ;
           hip:synonym "Invasion Swarm Plague" ,
                       "Outbreak" .


hip:BI0003 rdfs:label "Locust" ;
           hip:identifier "BI0003" ;
           hip:synonym "Locust outbreaks" ,
                       "Locust plagues" ,
                       "Locust upsurges" .


hip:BI0004 rdfs:label "Invasive Weeds" ;
           hip:identifier "BI0004" ;
           hip:synonym "Noxious plants" .


hip:BI0005 rdfs:label "Invasive Species" ;
           hip:identifier "BI0005" ;
           hip:synonym "Alien invasive species" ,
                       "Alien species" ,
                       "Invasive alien species" .


hip:BI0006 rdfs:label "Snake Envenomation" ;
           hip:identifier "BI0006" .


hip:BI0007 rdfs:label "Human-Wildlife Conflict" ;
           hip:identifier "BI0007" ;
           hip:synonym "Animal-human interaction" ,
                       "Human-wildlife interaction" .


hip:BI0008 rdfs:label "Biological Agents" ;
           hip:identifier "BI0008" .


hip:BI0009 rdfs:label "Suicide Cluster" ;
           hip:identifier "BI0009" ;
           hip:synonym "Group suicide" ,
                       "Mass suicide" ,
                       "Suicide contagion" ,
                       "Suicide imitation" ,
                       "Suicide pact" .


hip:BI0010 rdfs:label "Antimicrobial Resistance" ;
           hip:identifier "BI0010" .


hip:BI0011 rdfs:label "Foodborne Microbial Hazards (including human enteric virus and foodborne parasite)" ;
           hip:identifier "BI0011" .


hip:BI0012 rdfs:label "Bacterial Plant Disease" ;
           hip:identifier "BI0012" .


hip:BI0013 rdfs:label "Fungal Plant Disease" ;
           hip:identifier "BI0013" .


hip:BI0014 rdfs:label "Viral, Mycoplasma and Viroid Plant Disease Epidemics" ;
           skos:definition "Viral, mycoplasma and viroid plant disease epidemics are the occurrence of plant diseases caused by viruses, mycoplasma (syn. phytoplasma, mycoplasma-like organisms ) and viroids over large areas with significant impact on crop productivity or natural habitats (adapted from Nakashima and Murata, 1993; Hammond and Owens, 2006; FAO and IPPC, 2016; Rubio et al., 2020)." .


hip:BI0015 rdfs:label "Anthrax" ;
           hip:identifier "BI0015" .


hip:BI0016 rdfs:label "Airborne Diseases" ;
           hip:identifier "BI0016" .


hip:BI0017 rdfs:label "Blood Borne Viruses" ;
           hip:identifier "BI0017" .


hip:BI0018 rdfs:label "Waterborne Diseases" ;
           skos:definition "Waterborne diseases are those diseases that are transmitted by ingestion of contaminated water (WHO,2012)." .


hip:BI0019 rdfs:label "Foodborne Diseases" ;
           hip:identifier "BI0019" .


hip:BI0020 rdfs:label "Sexually Transmitted Diseases (Human)" ;
           hip:identifier "BI0020" ;
           hip:synonym "STIs" ,
                       "Sexually transmitted infections" .


hip:BI0021 rdfs:label "Neglected Tropical Diseases (Human)" ;
           hip:identifier "BI0021" .


hip:BI0022 rdfs:label "Vaccine-Preventable Diseases" ;
           skos:definition "Vaccine preventable diseases are those infectious diseases that can be prevented by vaccination (WHO, 2012)." .


hip:BI0023 rdfs:label "Vector Borne Diseases (VBD) (Human)" ;
           skos:definition "Vector borne diseases encompass a variety of illnesses that are caused via the spread of pathogens by living organisms known as vectors. These infectious diseases can be transmitted via vectors among humans (e.g., malaria, dengue), among animals (e.g., African swine fever, East Coast fever), or from animals to humans (e.g., Nipah virus disease). Many of these vectors are bloodsucking insects, and mosquitoes are the bestknown disease vector. Other vectors include ticks, flies, sandflies, fleas, triatomine bugs and some species of freshwater aquatic snails (adapted from OIE, 2019; WHO, 2020)." .


hip:BI0024 rdfs:label "Viral Haemorrhagic Fevers (Human)" ;
           skos:definition "Viral haemorrhagic fever is a general term for severe illnesses,sometimes associated with bleeding, that may be caused by a number of viruses. The term is usually applied to diseases caused by viruses that belong to the Arenaviridae, Bunyaviridae, Filoviridae and Flaviviridae families (WHO, no date)." .


hip:BI0025 rdfs:label "Antimicrobial Resistant Microorganisms" ;
           hip:identifier "BI0025" ;
           hip:synonym "Superbugs" .


hip:BI0026 rdfs:label "Animal Diseases (Not Zoonoses)" ;
           hip:identifier "BI0026" .


hip:BI0027 rdfs:label "Zoonotic Diseases" ;
           skos:definition "Zoonotic diseases are a group of communicable diseases that are transmissible from vertebrate animals to humans through direct contact or through food, water, and the environment (WHO, no date)." .


hip:BI0028 rdfs:label "Diarrhoeal Diseases (Human)" ;
           hip:identifier "BI0028" .


hip:BI0029 rdfs:label "Prion Diseases" ;
           hip:identifier "BI0029" .


hip:BI0030 rdfs:label "Hepatitis B (Human)" ;
           hip:identifier "BI0030" ;
           hip:synonym "Acute hepatitis B" ,
                       "Chronic hepatitis B" ,
                       "Hepatitis B related cirrhosis and hepatocellular carcinoma" .


hip:BI0031 rdfs:label "Hepatitis C (human)" ;
           hip:identifier "BI0031" ;
           hip:synonym "Acute hepatitis C" ,
                       "Chronic hepatitis C" ,
                       "Hepatitis C-related cirrhosis and liver cancer" .


hip:BI0032 rdfs:label "HIV and AIDS (Human)" ;
           hip:identifier "BI0032" .


hip:BI0033 rdfs:label "COVID-19 (SARS-CoV-2) (Human)" ;
           hip:identifier "BI0033" ;
           hip:synonym "COVID-19" ,
                       "Coronavirus" ,
                       "SARS-CoV-2" .


hip:BI0034 rdfs:label "Cholera (Human)" ;
           hip:identifier "BI0034" .


hip:BI0035 rdfs:label "Cryptosporidium" ;
           hip:identifier "BI0035" ;
           hip:synonym "Crypto" .


hip:BI0036 rdfs:label "Paratyphoid Fever (Human)" ;
           hip:identifier "BI0036" .


hip:BI0037 rdfs:label "Typhoid Fever (Human)" ;
           skos:definition "Typhoid fever is a life-threatening infection caused by the bacterium Salmonella Typhi. It is usually spread through contaminated food or water. An estimated 11–20 million people get sick from typhoid and between 128,000 and 161,000 people die from it every year (WHO, 2018)." .


hip:BI0038 rdfs:label "Hepatitis A (Human)" ;
           hip:identifier "BI0038" .


hip:BI0039 rdfs:label "Escherichia Coli (STEC) (Human)" ;
           hip:identifier "BI0039" ;
           hip:synonym "Enterohaemorrhagic E. coli (EHEC)" ,
                       "Shiga-toxin producing E. coli (STEC)" ,
                       "Verocytotoxigenic E. coli (VTEC)" .


hip:BI0040 rdfs:label "Listeriosis (Human)" ;
           hip:identifier "BI0040" .


hip:BI0041 rdfs:label "Shigellosis (Human)" ;
           hip:identifier "BI0041" .


hip:BI0042 rdfs:label "Avian Influenza (Human and Animal)" ;
           hip:identifier "BI0042" ;
           hip:synonym "Avian Flu" ,
                       "Bird Flu" .


hip:BI0043 rdfs:label "Pandemic Influenza (Human)" ;
           hip:identifier "BI0043" ;
           hip:synonym "Pan flu" .


hip:BI0044 rdfs:label "Seasonal Influenza" ;
           hip:identifier "BI0044" ;
           hip:synonym "Flu" .


hip:BI0045 rdfs:label "Cysticercosis" ;
           hip:identifier "BI0045" ;
           hip:synonym "Taeniasis" .


hip:BI0046 rdfs:label "Leptospirosis (Human)" ;
           hip:identifier "BI0046" .


hip:BI0047 rdfs:label "Plague (Human)" ;
           hip:identifier "BI0047" .


hip:BI0048 rdfs:label "Leprosy" ;
           hip:identifier "BI0048" ;
           hip:synonym "Hansen’s disease" .


hip:BI0049 rdfs:label "Chikungunya" ;
           hip:identifier "BI0049" .


hip:BI0050 rdfs:label "Zika Virus (human)" ;
           skos:definition "Zika virus disease is a disease transmitted primarily by Aedes mosquitoes which can lead to complications (WHO, 2018)." .


hip:BI0051 rdfs:label "Diphtheria (Human)" ;
           hip:identifier "BI0051" .


hip:BI0052 rdfs:label "Measles (Human)" ;
           hip:identifier "BI0052" ;
           hip:synonym "Rubeola" .


hip:BI0053 rdfs:label "Meningococcal Meningitis (Human)" ;
           hip:identifier "BI0053" .


hip:BI0054 rdfs:label "Pertussis (Human)" ;
           hip:identifier "BI0054" ;
           hip:synonym "Whooping cough" .


hip:BI0055 rdfs:label "Polio (Human)" ;
           hip:identifier "BI0055" ;
           hip:synonym "Poliomyelitis" .


hip:BI0056 rdfs:label "Smallpox (Human)" ;
           hip:identifier "BI0056" .


hip:BI0057 rdfs:label "Varicella and herpes zoster (Human)" ;
           skos:definition "Varicella is an acute, highly contagious disease caused by varicellazoster virus (WHO, 2014)." .


hip:BI0058 rdfs:label "Yellow Fever (Human)" ;
           skos:definition "Yellow fever is an acute viral haemorrhagic disease transmitted by infected mosquitoes (WHO, 2019)." .


hip:BI0059 rdfs:label "Dengue (Human)" ;
           hip:identifier "BI0059" ;
           hip:synonym "Break Bone Fever" .


hip:BI0060 rdfs:label "Malaria (Human)" ;
           hip:identifier "BI0060" .


hip:BI0061 rdfs:label "Crimean-Congo Haemorrhagic Fever" ;
           hip:identifier "BI0061" .


hip:BI0062 rdfs:label "Ebola (Human)" ;
           hip:identifier "BI0062" ;
           hip:synonym "Ebola haemorrhagic fever" .


hip:BI0063 rdfs:label "Lassa Fever (Human)" ;
           hip:identifier "BI0063" .


hip:BI0064 rdfs:label "Tuberculosis (Human and Animal)" ;
           skos:definition "Tuberculosis (TB) is a curable bacterial infectious disease caused by Mycobacterium tuberculosis that most commonly affects the lungs. It causes national epidemics of varied severity worldwide. Forms of TB that are resistant to treatment – multi-drug resistant TB (MDR-TB) and extensively drug-resistant TB (XDR-TB) – are public health crises and threaten health security worldwide (WHO, 2020)." .


hip:BI0065 rdfs:label "Middle East Respiratory Syndrome (MERS) (Human)" ;
           hip:identifier "BI0065" ;
           hip:synonym "MERS-CoV disease" .


hip:BI0066 rdfs:label "Monkeypox (Human)" ;
           hip:identifier "BI0066" .


hip:BI0067 rdfs:label "Rabies (Animal and Human)" ;
           hip:identifier "BI0067" .


hip:BI0068 rdfs:label "Severe Acute Respiratory Syndrome (SARS) (Human)" ;
           hip:identifier "BI0068" ;
           hip:synonym "SARS-CoV" .


hip:BI0069 rdfs:label "Rotavirus (Human)" ;
           hip:identifier "BI0069" .


hip:BI0070 rdfs:label "African Swine Fever" ;
           hip:identifier "BI0070" ;
           hip:synonym "ASFV" .


hip:BI0071 rdfs:label "Vector-borne diseases (VBD) (Animals)" ;
           skos:definition "Vector-borne diseases are diseases transmitted by a living being, usually an arthropod vector, to a vertebrate host (Verwoerd, 2015)." .


hip:BI0072 rdfs:label "Brucellosis (Animal)" ;
           hip:identifier "BI0072" ;
           hip:synonym "Contagious abortion" ,
                       "Malta fever" ,
                       "Mediterranean fever" ,
                       "Undulant fever" .


hip:BI0073 rdfs:label "Classical Swine Fever (Animal)" ;
           hip:identifier "BI0073" ;
           hip:synonym "Hog cholera" .


hip:BI0074 rdfs:label "Contagious Bovine Pleuropneumonia (CBPP) (Animal)" ;
           hip:identifier "BI0074" ;
           hip:synonym "Perineumonía contagiosa bovina" ,
                       "Pleuropneumonie contagieuse bovine" .


hip:BI0075 rdfs:label "Contagious Caprine Pleuropneumonia (CCPP) (Animal)" ;
           hip:identifier "BI0075" ;
           hip:synonym "Pleuroneumonía contagiosa caprina" ,
                       "Pleuropneumonie Contagieuse Caprine" .


hip:BI0076 rdfs:label "Foot and Mouth Disease Virus (Animal)" ;
           hip:identifier "BI0076" .


hip:BI0077 rdfs:label "Lumpy Skin Disease (Animal)" ;
           hip:identifier "BI0077" .


hip:BI0078 rdfs:label "New World Screwworm (NWS) (Animal)" ;
           hip:identifier "BI0078" .


hip:BI0079 rdfs:label "Newcastle Disease Virus (Animal)" ;
           hip:identifier "BI0079" .


hip:BI0080 rdfs:label "Peste Des Petits Ruminants (Animal)" ;
           hip:identifier "BI0080" ;
           hip:synonym "Sheep and goat plague Ovine rinderpest" .


hip:BI0081 rdfs:label "Q Fever" ;
           hip:identifier "BI0081" ;
           hip:synonym "Query Fever Coxiellosis Abattoir fever" .


hip:BI0082 rdfs:label "Rift Valley Fever (Animal)" ;
           hip:identifier "BI0082" ;
