###  http://www.semanticweb.org/crima/ipcc-ar6-impacts#HealthMalnutritionAndOther
ar6-impact:HealthMalnutritionAndOther rdf:type owl:Class ;
                                      rdfs:subClassOf ar6-impact:ImpactOnHealthAndWellbeing .


###  http://www.semanticweb.org/crima/ipcc-ar6-impacts#ImpactOnCitiesSettlementsInfrastructres
ar6-impact:ImpactOnCitiesSettlementsInfrastructres rdf:type owl:Class ;
                                                   rdfs:subClassOf ar6-impact:ImpactOnHumanSystems .


###  http://www.semanticweb.org/crima/ipcc-ar6-impacts#ImpactOnEcosystems
ar6-impact:ImpactOnEcosystems rdf:type owl:Class ;
                              rdfs:subClassOf ar6-impact:ImpactType .


###  http://www.semanticweb.org/crima/ipcc-ar6-impacts#ImpactOnHealthAndWellbeing
ar6-impact:ImpactOnHealthAndWellbeing rdf:type owl:Class ;
                                      rdfs:subClassOf ar6-impact:ImpactOnHumanSystems .


###  http://www.semanticweb.org/crima/ipcc-ar6-impacts#ImpactOnHumanSystems
ar6-impact:ImpactOnHumanSystems rdf:type owl:Class ;
                                rdfs:subClassOf ar6-impact:ImpactType .


###  http://www.semanticweb.org/crima/ipcc-ar6-impacts#ImpactOnWaterAndFoodProduction
ar6-impact:ImpactOnWaterAndFoodProduction rdf:type owl:Class ;
                                          rdfs:subClassOf ar6-impact:ImpactOnHumanSystems .


###  http://www.semanticweb.org/crima/ipcc-ar6-impacts#ImpactType
ar6-impact:ImpactType rdf:type owl:Class ;
                      rdfs:subClassOf skos:Concept ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty skos:inScheme ;
                                        owl:allValuesFrom ar6-impact:ObservedImpacts
                                      ] .


###  http://www.semanticweb.org/crima/ipcc-ar6-impacts#InfectiousDiseases
ar6-impact:InfectiousDiseases rdf:type owl:Class ;
