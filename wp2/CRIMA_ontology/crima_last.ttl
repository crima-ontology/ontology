###  http://www.semanticweb.org/crima/crima-ecv#Surface
ecv:Surface rdf:type owl:NamedIndividual ,
                     ecv:ecv-subdomain ;
            skos:member ecv:Atmosphere .


###  http://www.semanticweb.org/crima/crima-ecv#SurfaceCurrents
ecv:SurfaceCurrents rdf:type owl:NamedIndividual ,
                             ecv:ecv-variable ;
                    skos:broader ecv:Physical .


###  http://www.semanticweb.org/crima/crima-ecv#SurfaceElevationChange
ecv:SurfaceElevationChange rdf:type owl:NamedIndividual ,
                                    ecv:ecv-product ;
                           qudt:hasUnit unit:M ;
                           ecv:isProductOf ecv:IceSheetsAndIceShelves ;
                           skos:definition "Measurements of the change height above a reference (geoid or ellipsoid) of the snow-air surface or uppermost firn layers." ;
                           skos:note "Annual change in elevations above sea level measured in meters (m y-1)." .


###  http://www.semanticweb.org/crima/crima-ecv#SurfaceGeostrophicCurrent
ecv:SurfaceGeostrophicCurrent rdf:type owl:NamedIndividual ,
                                       ecv:ecv-product ;
                              qudt:hasUnit unit:M-PER-SEC ;
                              ecv:isProductOf ecv:SurfaceCurrents ;
                              skos:definition "Ocean vector motion measured at or near the surface (at stated depth)." .


###  http://www.semanticweb.org/crima/crima-ecv#SurfaceInundation
ecv:SurfaceInundation rdf:type owl:NamedIndividual ,
                               ecv:ecv-product ;
                      ecv:isProductOf ecv:SoilMoisture ;
                      skos:definition "Flag indicating whether the land surface is inundated or not." ;
                      skos:note "Surface inundation is subsidiary variable of the ECV soil moisture. It is needed because most measurement techniques do not allow to measure soil moisture when the soil surface is inundated. Also, land-surface processes fundamentally change when the soil is inundated. Instead of binary values probabilities (i.e. probability that the soil is inundated) may be used." ,
                                "Unitless" .


###  http://www.semanticweb.org/crima/crima-ecv#SurfacePressure
ecv:SurfacePressure rdf:type owl:NamedIndividual ,
                             ecv:ecv-variable ;
                    skos:broader ecv:Surface .


###  http://www.semanticweb.org/crima/crima-ecv#SurfaceRadiationBudget
ecv:SurfaceRadiationBudget rdf:type owl:NamedIndividual ,
                                    ecv:ecv-variable ;
                           skos:broader ecv:Surface .


###  http://www.semanticweb.org/crima/crima-ecv#SurfaceSoilMoisture
ecv:SurfaceSoilMoisture rdf:type owl:NamedIndividual ,
                                 ecv:ecv-product ;
                        qudt:hasUnit unit:M3-PER-M3 ;
                        ecv:isProductOf ecv:SoilMoisture ;
                        skos:definition "Soil Moisture refers to the average water content in the soil, which can be expressed in volumetric, gravimetric or relative (e.g. degree of saturation) units. Surface Soil Moisture is sometimes referred to as topsoil moisture, surface wetness, surface humidity." ;
                        skos:note "The depth of the topmost soil layer is often only qualitatively defined as the actual sensing depth varies with measurement technique, water content, and soil properties and usually cannot be specified with any accuracy. All units can be inter-converted given the availability of soil property information (bulk density, porosity etc.), yet the use of the volumetric soil moisture content as the standard measurement unit is encouraged." .


###  http://www.semanticweb.org/crima/crima-ecv#SurfaceStress
ecv:SurfaceStress rdf:type owl:NamedIndividual ,
                           ecv:ecv-variable ;
                  skos:broader ecv:Physical .


###  http://www.semanticweb.org/crima/crima-ecv#SurfaceTemperature
ecv:SurfaceTemperature rdf:type owl:NamedIndividual ,
                                ecv:ecv-variable ;
                       skos:broader ecv:Surface .


###  http://www.semanticweb.org/crima/crima-ecv#SurfaceWaterVapour
ecv:SurfaceWaterVapour rdf:type owl:NamedIndividual ,
                                ecv:ecv-variable ;
                       skos:broader ecv:Surface .


###  http://www.semanticweb.org/crima/crima-ecv#SurfaceWindSpeedAndDirection
ecv:SurfaceWindSpeedAndDirection rdf:type owl:NamedIndividual ,
                                          ecv:ecv-variable ;
                                 skos:broader ecv:Surface ;
                                 skos:definition """Wind Speed (near surface): Speed of air at a known height above the surface which is to be specified in the metadata.
Wind Direction (near surface): Direction from which wind is blowing at a known height above the surface which is to be specified in the metadata.""" .


###  http://www.semanticweb.org/crima/crima-ecv#TerrestrialWaterStorage-TWS
ecv:TerrestrialWaterStorage-TWS rdf:type owl:NamedIndividual ,
                                         ecv:ecv-variable ;
                                skos:broader ecv:Hydrology .


###  http://www.semanticweb.org/crima/crima-ecv#TerrestrialWaterStorageAnomaly
ecv:TerrestrialWaterStorageAnomaly rdf:type owl:NamedIndividual ,
                                            ecv:ecv-product ;
                                   qudt:hasUnit unit:KiloGM-PER-M2 ;
                                   ecv:isProductOf ecv:TerrestrialWaterStorage-TWS ;
                                   skos:definition "TWS is the total amount of water stored in all continental storage compartments (ice caps, glaciers, snow cover, soil moisture, groundwater, surface water bodies, water in biomass). The change of TWS over time balances the budget of the water fluxes precipitation, evapotranspiration and runoff, i.e., it closes the continental water balance." .


###  http://www.semanticweb.org/crima/crima-ecv#TotalAlkalinity-TA
ecv:TotalAlkalinity-TA rdf:type owl:NamedIndividual ,
                                ecv:ecv-product ;
                       qudt:hasUnit unit:MicroMOL-PER-KiloGM ;
                       ecv:isProductOf ecv:InorganicCarbon ;
                       skos:definition "Total concentration of alkaline substances." .


###  http://www.semanticweb.org/crima/crima-ecv#TotalLightningStrokeDensity
ecv:TotalLightningStrokeDensity rdf:type owl:NamedIndividual ,
                                         ecv:ecv-product ;
                                qudt:hasUnit cunit:StrokesPerSquareKilometerPerYear ;
                                ecv:isProductOf ecv:Lightning ;
                                skos:definition "Total number of detected strokes in the corresponding time interval and the space unit. The space unit (grid box) should be on the order of the horizontal resolution and the accumulation time to the observing cycle." ;
                                skos:note "Data sets at the 1-map-per-month level require limited data storage, and thus should be simply posted on a publicly accessible website. The larger data sets reaching down to global resolutions of 0.1 degree with time resolution of a few hours should be maintained by the network managers and provided to the user community as needed. Metadata should include sufficient information to validate the detection efficiency at the maximum spatial and temporal scales." .


###  http://www.semanticweb.org/crima/crima-ecv#TransientTracers
ecv:TransientTracers rdf:type owl:NamedIndividual ,
                              ecv:ecv-variable ;
                     skos:broader ecv:Biogeochemical .


###  http://www.semanticweb.org/crima/crima-ecv#Transpiration
ecv:Transpiration rdf:type owl:NamedIndividual ,
                           ecv:ecv-product ;
                  qudt:hasUnit unit:W-PER-M2 ;
                  ecv:isProductOf ecv:EvaporationFromLand ;
                  skos:definition "The component of the total latent heat flux that corresponds to the vegetation consumption of water." ;
                  skos:note "The requirements are analogous to those of the total latent heat flux, because the applications are the same. Several studies have shown, however, that the accuracy of the latent heat flux can still be adequate despite a higher uncertainty in the evaporation components (i.e. bare soil evaporation, transpiration and interception loss) – see e.g. Miralles et al. (2016), Talsma et al. (2018). For that reason, the uncertainty goals have been subjectively relaxed based on expert judgement." .


