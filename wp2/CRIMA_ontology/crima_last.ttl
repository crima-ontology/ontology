#################################################################
#    Individuals
#################################################################

###  http://codes.wmo.int/wmdr/unit/V2-m-2-Hz-1
wmdr-unit:V2-m-2-Hz-1 rdf:type owl:NamedIndividual ,
                               wmdr-unit:Unit ;
                      dcterms:description "SI derived unit for electric field spectral density commonly used to describe Schumann Resonances. SI base unit equivalent: kg2.m2.s-5.A-2"@en ;
                      rdfs:label "Volt squared per metre squared per Hertz" ;
                      skos:notation "V2.m-2.Hz-1" .


###  http://codes.wmo.int/wmdr/unit/nmol-mol-1
wmdr-unit:nmol-mol-1 rdf:type owl:NamedIndividual ,
                              wmdr-unit:Unit ;
                     dcterms:description "SI derived unit of mole fraction; SI base unit equivalent: 1E-9"@en ;
                     rdfs:label "nanomole per mole" ;
                     skos:notation "nmol.mol-1" .


###  http://codes.wmo.int/wmdr/unit/pT2-Hz-1
wmdr-unit:pT2-Hz-1 rdf:type owl:NamedIndividual ,
                            wmdr-unit:Unit ;
                   dcterms:description "SI derived unit for magnetic power spectrum commonly used to describe Schumann Resonances. SI base unit equivalent: 1E-12 A.m-1.s"@en ;
                   rdfs:label "picoTesla squared per Hertz" ;
                   skos:notation "pT2.Hz-1" .


###  http://qudt.org/vocab/unit/ATM
unit:ATM rdf:type owl:NamedIndividual ,
                  qudt:Unit ;
         dcterms:description """
  The unit for $\\textit{Standard Atmosphere}$, symbol: $atm$, is an international reference pressure defined as $101.325 \\,kPa$ and formerly used as unit of pressure.
  For practical purposes it has been replaced by the bar which is $100 kPa$. 
  The difference of about 1% is not significant for many applications, and is within the error range of common pressure gauges.
  """^^qudt:LatexString ;
         rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/vocab/unit> ;
         rdfs:label "Standard Atmosphere"@en ,
                    "Standard Atmosphere" .


###  http://qudt.org/vocab/unit/CentiM
unit:CentiM rdf:type owl:NamedIndividual ,
                     qudt:Unit ;
            dcterms:description "A centimetre is a unit of length in the metric system, equal to one hundredth of a metre, which is the SI base unit of length. Centi is the SI prefix for a factor of $10^{-2}$.  The centimetre is the base unit of length in the now deprecated centimetre-gram-second (CGS) system of units."^^qudt:LatexString ;
            rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/vocab/unit> ;
            rdfs:label "Centimetre"@en ,
                       "Centimetro"@it ,
                       "Centimetre" .


###  http://qudt.org/vocab/unit/CentiM-PER-SEC
unit:CentiM-PER-SEC rdf:type owl:NamedIndividual ,
                             qudt:Unit ;
                    dcterms:description "\"Centimeter per Second\" is a C.G.S System unit for  'Linear Velocity' expressed as $cm/s$."^^qudt:LatexString ;
                    rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/vocab/unit> ;
                    rdfs:label "Centimetre per Second"@en ,
                               "Centimetro per Secondo"@it ,
                               "Centimetre per Second" .


###  http://qudt.org/vocab/unit/DAY
unit:DAY rdf:type owl:NamedIndividual ,
                  qudt:Unit ;
         dcterms:description "Mean solar day"^^rdf:HTML ;
         rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/vocab/unit> ;
         rdfs:label "Day"@en ,
                    "Day" .


###  http://qudt.org/vocab/unit/DEG
unit:DEG rdf:type owl:NamedIndividual ,
                  qudt:Unit ;
         dcterms:description "A degree (in full, a degree of arc, arc degree, or arcdegree), usually denoted by $^\\circ$ (the degree symbol), is a measurement of plane angle, representing 1/360 of a full rotation; one degree is equivalent to  $2\\pi /360 rad$, $0.017453 rad$. It is not an SI unit, as the SI unit for angles is radian, but is an accepted SI unit."^^qudt:LatexString ;
         rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/vocab/unit> ;
         rdfs:label "Degree"@en ,
                    "Degree" .


###  http://qudt.org/vocab/unit/DEG_C
unit:DEG_C rdf:type owl:NamedIndividual ,
                    qudt:Unit ;
           dcterms:description "The unit Celsius, also known as centigrade, is a scale and unit of measurement for temperature. It can refer to a specific temperature on the Celsius scale as well as a unit to indicate a temperature interval, a difference between two temperatures or an uncertainty. This definition fixes the magnitude of both the degree Celsius and the kelvin as precisely 1 part in 273.16 (approximately 0.00366) of the difference between absolute zero and the triple point of water. Thus, it sets the magnitude of one degree Celsius and that of one kelvin as exactly the same." ;
           rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/vocab/unit> ;
           rdfs:label "Degree Celsius"@en ,
                      "Grado Celsius"@it .


###  http://qudt.org/vocab/unit/FemtoMOL-PER-KiloGM
unit:FemtoMOL-PER-KiloGM rdf:type owl:NamedIndividual ,
                                  qudt:Unit ;
                         dcterms:description "A 10**15 part quantity of substance of the measurand per kilogram mass of matrix."@en ;
                         rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/vocab/unit> ;
                         rdfs:label "Femtomole per Chilogrammo"@it ,
                                    "Femtomole per Kilogram"@en ,
                                    "Femtomole per Kilogram" .


###  http://qudt.org/vocab/unit/GM-PER-KiloGM
unit:GM-PER-KiloGM rdf:type owl:NamedIndividual ,
                            qudt:Unit ;
                   dcterms:description "0,001 fold of the SI base unit kilogram divided by the SI base unit kilogram"^^rdf:HTML ;
                   rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/vocab/unit> ;
                   rdfs:label "Gram per Kilogram"@en ,
                              "Grammo per Chilogrammo"@it ,
                              "Gram per Kilogram" .


###  http://qudt.org/vocab/unit/HectoPA
unit:HectoPA rdf:type owl:NamedIndividual ,
                      qudt:Unit ;
             dcterms:description "Hectopascal is a unit of pressure. 1 Pa is approximately the pressure exerted by a 10-g mass resting on a 1-cm2 area. 1013 hPa = 1 atm. There are 100 pascals in 1 hectopascal."^^rdf:HTML ;
             rdfs:comment "Hectopascal is commonly used in meteorology to report values for atmospheric pressure. It is equivalent to millibar." ;
             rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/vocab/unit> ;
             rdfs:label "Ettopascal"@it ,
                        "Hectopascal"@en .


###  http://qudt.org/vocab/unit/K
unit:K rdf:type owl:NamedIndividual ,
                qudt:Unit ;
       dcterms:description "The unit $\\textit{Kelvin}$ is the SI base unit of temperature, previously called the degree Kelvin. One kelvin represents the same temperature difference as one degree Celsius. In 1967 the General Conference on Weights and Measures defined the temperature of the triple point of water (the temperature at which water exists simultaneously in the gaseous, liquid, and solid states) to be exactly 273.16 kelvins. Since this temperature is also equal to 0.01 u00b0C, the temperature in kelvins is always equal to 273.15 plus the temperature in degrees Celsius. The kelvin equals exactly 1.8 degrees Fahrenheit. The unit is named for the British mathematician and physicist William Thomson (1824-1907), later known as Lord Kelvin after he was named Baron Kelvin of Largs."^^qudt:LatexString ;
       rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/vocab/unit> ;
       rdfs:label "Kelvin"@en ,
                  "Kelvin"@it ,
                  "Kelvin" .


###  http://qudt.org/vocab/unit/KiloGM-PER-M2
unit:KiloGM-PER-M2 rdf:type owl:NamedIndividual ,
                            qudt:Unit ;
                   dcterms:description "Kilogram Per Square Meter (kg/m2) is a unit in the category of Surface density. It is also known as kilograms per square meter, kilogram per square metre, kilograms per square metre, kilogram/square meter, kilogram/square metre. This unit is commonly used in the SI unit system. Kilogram Per Square Meter (kg/m2) has a dimension of ML-2 where $M$ is mass, and $L$ is length. This unit is the standard SI unit in this category."^^rdf:HTML ;
                   rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/vocab/unit> ;
                   rdfs:label "Chiliogramma per Metrum Quadratum"@la ,
                              "Chilogrammo per Metro Quadrato"@it ,
                              "Kilogram per Square Metre"@en ,
                              "Kilogram per Square Metre" .


###  http://qudt.org/vocab/unit/KiloGM-PER-M3
unit:KiloGM-PER-M3 rdf:type owl:NamedIndividual ,
                            qudt:Unit ;
                   dcterms:description "Kilogram per cubic metre is an SI derived unit of density, defined by mass in kilograms divided by volume in cubic metres. The official SI symbolic abbreviation is $kg \\cdot m^{-3}$, or equivalently either $kg/m^3$."^^qudt:LatexString ;
                   rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/vocab/unit> ;
                   rdfs:label "Chilogrammo per Metro Cubo"@it ,
                              "Kilogram per Cubic Metre"@en ,
                              "Kilogram per Cubic Metre" .


###  http://qudt.org/vocab/unit/KiloM
unit:KiloM rdf:type owl:NamedIndividual ,
                    qudt:Unit ;
           dcterms:description "A common metric unit of length or distance. One kilometer equals exactly 1000 meters, about 0.621 371 19 mile, 1093.6133 yards, or 3280.8399 feet. Oddly, higher multiples of the meter are rarely used; even the distances to the farthest galaxies are usually measured in kilometers. "^^rdf:HTML ;
           rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/vocab/unit> ;
           rdfs:label "Chilometro"@it ,
                      "Kilometre"@en ,
                      "Kilometre" .


###  http://qudt.org/vocab/unit/KiloM-PER-DAY
unit:KiloM-PER-DAY rdf:type owl:NamedIndividual ,
                            qudt:Unit ;
                   dcterms:description "A change in location of a distance of one thousand metres in an elapsed time of one day (86400 seconds)."@en ;
                   rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/vocab/unit> ;
                   rdfs:label "Kilometre per Day"@en ,
                              "Kilometre per Day" .


###  http://qudt.org/vocab/unit/KiloM2
unit:KiloM2 rdf:type owl:NamedIndividual ,
                     qudt:Unit ;
            dcterms:description "1,000,000-fold of the power of the SI base unit metre with the exponent 2" ;
            rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/vocab/unit> ;
            rdfs:label "Chilometro Quadrato"@it ,
                       "Square Kilometre"@en ,
                       "Square Kilometre" .


###  http://qudt.org/vocab/unit/M
unit:M rdf:type owl:NamedIndividual ,
                qudt:Unit ;
       dcterms:description "The metric and SI base unit of distance.  The 17th General Conference on Weights and Measures in 1983 defined the meter as that distance that makes the speed of light in a vacuum equal to exactly 299 792 458 meters per second. The speed of light in a vacuum, $c$, is one of the fundamental constants of nature. The meter is equal to approximately 1.093 613 3 yards, 3.280 840 feet, or 39.370 079 inches."^^qudt:LatexString ;
       rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/vocab/unit> ;
       rdfs:label "Metre"@en ,
                  "Metro"@it ,
                  "Metre" .


###  http://qudt.org/vocab/unit/M-PER-SEC
unit:M-PER-SEC rdf:type owl:NamedIndividual ,
                        qudt:Unit ;
               dcterms:description """Metre per second is an SI derived unit of both speed (scalar) and velocity (vector quantity which specifies both magnitude and a specific direction), defined by distance in metres divided by time in seconds.
The official SI symbolic abbreviation is mu00b7s-1, or equivalently either m/s."""^^rdf:HTML ;
               rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/vocab/unit> ;
               rdfs:label "Metre per Second"@en ,
                          "Metro per Secondo"@it ,
                          "Metre per Second" .


###  http://qudt.org/vocab/unit/M-PER-YR
unit:M-PER-YR rdf:type owl:NamedIndividual ,
                       qudt:Unit ;
              dcterms:description "A rate of change of SI standard unit length over a period of an average calendar year (365.25 days)."@en ;
              rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/vocab/unit> ;
              rdfs:label "Metre per Year"@en ,
                         "Metre per Year" .


###  http://qudt.org/vocab/unit/M2
unit:M2 rdf:type owl:NamedIndividual ,
                 qudt:Unit ;
        dcterms:description "The S I unit of area is the square metre."^^rdf:HTML ;
        rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/vocab/unit> ;
        rdfs:label "Metro Quadrato"@it ,
                   "Square Metre"@en ,
                   "Square Metre" .


###  http://qudt.org/vocab/unit/M2-PER-M2
unit:M2-PER-M2 rdf:type owl:NamedIndividual ,
                        qudt:Unit ;
               dcterms:description "A square metre unit of area per square metre"^^rdf:HTML ;
               rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/vocab/unit> ;
               rdfs:label "Metro Quadrato per Metro Quadrato"@it ,
                          "Square Metre per Square Metre"@en ,
                          "Square Metre per Square Metre" .


###  http://qudt.org/vocab/unit/M3-PER-M3
unit:M3-PER-M3 rdf:type owl:NamedIndividual ,
                        qudt:Unit ;
               dcterms:description "power of the SI base unit metre with the exponent 3 divided by the power of the SI base unit metre with the exponent 3"^^rdf:HTML ;
               rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/vocab/unit> ;
               rdfs:label "Cubic Metre per Cubic Metre"@en ,
                          "Metro Cubo per Metro Cubo"@it ,
                          "Cubic Metre per Cubic Metre" .


###  http://qudt.org/vocab/unit/M3-PER-SEC
unit:M3-PER-SEC rdf:type owl:NamedIndividual ,
                         qudt:Unit ;
                dcterms:description "A cubic metre per second ($m^{3}s^{-1}, m^{3}/s$), cumecs or cubic meter per second in American English) is a derived SI unit of flow rate equal to that of a stere or cube with sides of one metre ( u0303 39.37 in) in length exchanged or moving each second. It is popularly used for water flow, especially in rivers and streams, and fractions for HVAC values measuring air flow."^^qudt:LatexString ;
                rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/vocab/unit> ;
                rdfs:label "Cubic Metre per Second"@en ,
                           "Metro Cubo per Secondo"@it ,
                           "Cubic Metre per Second" .


###  http://qudt.org/vocab/unit/MegaGM-PER-HA
unit:MegaGM-PER-HA rdf:type owl:NamedIndividual ,
                            qudt:Unit ;
                   dcterms:description "1 000-fold of the SI base unit kilogram divided by the 10,000-fold of the power of the SI base unit metre with the exponent 2"^^rdf:HTML ;
                   rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/vocab/unit> ;
                   rdfs:label "Megagram per Hectare"@en ,
                              "Megagram per Hectare" .


###  http://qudt.org/vocab/unit/MicroGM-PER-L
unit:MicroGM-PER-L rdf:type owl:NamedIndividual ,
                            qudt:Unit ;
                   dcterms:description "0.000000001-fold of the SI base unit kilogram divided by the unit litre"^^rdf:HTML ;
                   rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/vocab/unit> ;
                   rdfs:label "Microgram per Litre"@en ,
                              "Microgram per Litre" .


###  http://qudt.org/vocab/unit/MicroGM-PER-M3
unit:MicroGM-PER-M3 rdf:type owl:NamedIndividual ,
                             qudt:Unit ;
                    dcterms:description "0.000000001-fold of the SI base unit kilogram divided by the power of the SI base unit metre with the exponent 3"^^rdf:HTML ;
                    rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/vocab/unit> ;
                    rdfs:label "Microgram per Cubic Metre"@en ,
                               "Microgrammo per Metro Cubo"@it ,
                               "Microgram per Cubic Metre" .


###  http://qudt.org/vocab/unit/MicroM
unit:MicroM rdf:type owl:NamedIndividual ,
                     qudt:Unit ;
            dcterms:description "\"Micrometer\" is a unit for  'Length' expressed as $microm$."^^qudt:LatexString ;
            rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/vocab/unit> ;
            rdfs:label "Micrometre"@en ,
                       "Micrometro"@it ,
                       "Micrometre" .


