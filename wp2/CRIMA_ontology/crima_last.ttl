#################################################################
#    Datatypes
#################################################################

###  http://qudt.org/schema/qudt/LatexString
qudt:LatexString rdf:type rdfs:Datatype .


###  http://www.linkedmodel.org/schema/dtype#numericUnion
dtype:numericUnion rdf:type rdfs:Datatype ;
                   skos:definition "A datatype that is the union of numeric xsd data types. \"dtype:numericUnion\" is equivalent to the xsd specification that uses an xsd:union of memberTypes=\"xsd:decimal xsd:double xsd:float xsd:integer\"."@en .


###  http://www.opengis.net/ont/geosparql#wktLiteral
geo:wktLiteral rdf:type rdfs:Datatype ;
               skos:definition "A Well-known Text serialization of a Geometry object."@en ;
               skos:prefLabel "Well-known Text literal"@en .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML
rdf:HTML rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#gYear
xsd:gYear rdf:type rdfs:Datatype .


###  http://www.w3.org/2015/03/corine#CorineValue
corine:CorineValue rdf:type rdfs:Datatype ;
                   rdfs:comment "A numerical value from the CORINE Land Cover nomenclature" ;
                   rdfs:label "CORINE value"@en .


#################################################################
#    Object Properties
#################################################################

###  http://knowwheregraph/ontology/deo#hazardType
deo:hazardType rdf:type owl:ObjectProperty .


###  http://purl.org/dc/terms/subject
dcterms:subject rdf:type owl:ObjectProperty ;
                rdfs:domain dcat:Resource ;
                dcterms:description "Typically, the subject will be represented using keywords, key phrases, or classification codes. Recommended best practice is to use a controlled vocabulary. To describe the spatial or temporal topic of the resource, use the Coverage element."@en-us ;
                dcterms:hasVersion <http://dublincore.org/usage/terms/history/#subjectT-001> ;
                rdfs:comment "The topic of the resource."@en-us ;
                rdfs:isDefinedBy dcterms: ;
                rdfs:label "Subject"@en-us ;
                skos:note "This term is intended to be used with non-literal values as defined in the DCMI Abstract Model (http://dublincore.org/documents/abstract-model/). As of December 2007, the DCMI Usage Board is seeking a way to express this intention with a formal range declaration."@en-us .


###  http://qudt.org/schema/qudt/hasUnit
qudt:hasUnit rdf:type owl:ObjectProperty ;
             rdfs:range qudt:Unit ;
             rdfs:label "has unit" ,
                        "hasUnit" ;
             skos:definition "This property relates a factor unit to its unit or a system of units with a unit of measure that is either a) defined by the system, or b) accepted for use by the system and is convertible to a unit of equivalent dimension that is defined by the system. Systems of units may distinguish between base and derived units. Base units are the units which measure the base quantities for the corresponding system of quantities. The base units are used to define units for all other quantities as products of powers of the base units. Such units are called derived units for the system."@en .


###  http://www.opengis.net/ont/geosparql#hasGeometry
geo:hasGeometry rdf:type owl:ObjectProperty ;
                rdfs:range geo:Geometry ;
                rdfs:isDefinedBy <http://www.opengis.net/spec/geosparql/1.0/req/geometry-extension/feature-properties> ,
                                 <http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/feature-properties> ;
                skos:definition "A spatial representation for a given Feature."@en ;
                skos:prefLabel "has geometry"@en .


###  http://www.opengis.net/ont/geosparql#hasSize
geo:hasSize rdf:type owl:ObjectProperty ;
            rdfs:domain geo:SpatialObject ;
            rdfs:isDefinedBy geo: ,
                             <http://www.opengis.net/spec/geosparql/1.0/req/topology-vocab-extension/spatial-object-properties> ,
                             <http://www.opengis.net/spec/geosparql/1.1/req/topology-vocab-extension/spatial-object-properties> ;
            skos:definition "Subproperties of this property are used to indicate the size of a Spatial Object as a measurement or estimate of one or more dimensions of the Spatial Object's spatial presence."@en ;
            skos:note "The recommended way to specify size is by using a subproperty of hasMetricSize. Subproperties of hasSize can be used if more complex expressions are necessary, for example if the unit of length can not be converted to meter, or if additional data are needed to describe the measurement or estimate."@en ;
            skos:prefLabel "has size"@en .


###  http://www.opengis.net/ont/geosparql#sfContains
geo:sfContains rdf:type owl:ObjectProperty ;
               rdfs:domain geo:SpatialObject ;
               rdfs:range geo:SpatialObject ;
               rdfs:isDefinedBy geo: ,
                                <http://www.opengis.net/spec/geosparql/1.0/req/topology-vocab-extension/rcc8-spatial-relations> ,
                                <http://www.opengis.net/spec/geosparql/1.1/req/topology-vocab-extension/rcc8-spatial-relations> ;
               rdfs:seeAlso <http://dbpedia.org/resource/DE-9IM> ;
               skos:definition "States that the subject SpatialObject spatially contains the object SpatialObject. DE-9IM: T*****FF*"@en ;
               skos:prefLabel "contains"@en .


###  http://www.opengis.net/ont/geosparql#sfCrosses
geo:sfCrosses rdf:type owl:ObjectProperty ;
              rdfs:domain geo:SpatialObject ;
              rdfs:range geo:SpatialObject ;
              rdfs:isDefinedBy geo: ,
                               <http://www.opengis.net/spec/geosparql/1.0/req/topology-vocab-extension/sf-spatial-relations> ,
                               <http://www.opengis.net/spec/geosparql/1.1/req/topology-vocab-extension/sf-spatial-relations> ;
              rdfs:seeAlso <http://dbpedia.org/resource/DE-9IM> ;
              skos:definition "States that the subject SpatialObject spatially crosses the object SpatialObject. DE-9IM: T*T******"@en ;
              skos:prefLabel "crosses"@en .


###  http://www.opengis.net/ont/geosparql#sfDisjoint
geo:sfDisjoint rdf:type owl:ObjectProperty ;
               rdfs:domain geo:SpatialObject ;
               rdfs:range geo:SpatialObject ;
               owl:propertyDisjointWith geo:sfIntersects ;
               rdfs:isDefinedBy geo: ,
                                <http://www.opengis.net/spec/geosparql/1.0/req/topology-vocab-extension/sf-spatial-relations> ,
                                <http://www.opengis.net/spec/geosparql/1.1/req/topology-vocab-extension/sf-spatial-relations> ;
               rdfs:seeAlso <http://dbpedia.org/resource/DE-9IM> ;
               skos:definition "States that the subject SpatialObject is spatially disjoint from the object SpatialObject. DE-9IM: FF*FF****"@en ;
               skos:prefLabel "disjoint"@en .


###  http://www.opengis.net/ont/geosparql#sfEquals
geo:sfEquals rdf:type owl:ObjectProperty ;
             rdfs:domain geo:SpatialObject ;
             rdfs:range geo:SpatialObject ;
             rdfs:isDefinedBy geo: ,
                              <http://www.opengis.net/spec/geosparql/1.0/req/topology-vocab-extension/sf-spatial-relations> ,
                              <http://www.opengis.net/spec/geosparql/1.1/req/topology-vocab-extension/sf-spatial-relations> ;
             rdfs:seeAlso <http://dbpedia.org/resource/DE-9IM> ;
             skos:definition "States that the subject SpatialObject spatially equals the object SpatialObject. DE-9IM: TFFFTFFFT"@en ;
             skos:prefLabel "equals"@en .


###  http://www.opengis.net/ont/geosparql#sfIntersects
geo:sfIntersects rdf:type owl:ObjectProperty ;
                 rdfs:domain geo:SpatialObject ;
                 rdfs:range geo:SpatialObject ;
                 rdfs:isDefinedBy geo: ,
                                  <http://www.opengis.net/spec/geosparql/1.0/req/topology-vocab-extension/sf-spatial-relations> ,
                                  <http://www.opengis.net/spec/geosparql/1.1/req/topology-vocab-extension/sf-spatial-relations> ;
                 rdfs:seeAlso <http://dbpedia.org/resource/DE-9IM> ;
                 skos:definition "States that the subject SpatialObject is not spatially disjoint from the object SpatialObject. DE-9IM: T******** ^ *T******* ^ ***T***** ^ ****T****"@en ;
                 skos:prefLabel "intersects"@en .


###  http://www.opengis.net/ont/geosparql#sfOverlaps
geo:sfOverlaps rdf:type owl:ObjectProperty ;
               rdfs:domain geo:SpatialObject ;
               rdfs:range geo:SpatialObject ;
               rdfs:isDefinedBy geo: ,
                                <http://www.opengis.net/spec/geosparql/1.0/req/topology-vocab-extension/sf-spatial-relations> ,
                                <http://www.opengis.net/spec/geosparql/1.1/req/topology-vocab-extension/sf-spatial-relations> ;
               rdfs:seeAlso <http://dbpedia.org/resource/DE-9IM> ;
               skos:definition "States that the subject SpatialObject spatially overlaps the object SpatialObject. DE-9IM: T*T***T**"@en ;
               skos:prefLabel "overlaps"@en .


###  http://www.opengis.net/ont/geosparql#sfTouches
geo:sfTouches rdf:type owl:ObjectProperty ;
              rdfs:domain geo:SpatialObject ;
              rdfs:range geo:SpatialObject ;
              rdfs:isDefinedBy geo: ,
                               <http://www.opengis.net/spec/geosparql/1.0/req/topology-vocab-extension/sf-spatial-relations> ,
                               <http://www.opengis.net/spec/geosparql/1.1/req/topology-vocab-extension/sf-spatial-relations> ;
              rdfs:seeAlso <http://dbpedia.org/resource/DE-9IM> ;
              skos:definition "States that the subject SpatialObject spatially touches the object SpatialObject. DE-9IM: FT******* ^ F**T***** ^ F***T****"@en ;
              skos:prefLabel "touches"@en .


###  http://www.opengis.net/ont/geosparql#sfWithin
geo:sfWithin rdf:type owl:ObjectProperty ;
             rdfs:domain geo:SpatialObject ;
             rdfs:range geo:SpatialObject ;
             rdfs:isDefinedBy geo: ,
                              <http://www.opengis.net/spec/geosparql/1.0/req/topology-vocab-extension/sf-spatial-relations> ,
                              <http://www.opengis.net/spec/geosparql/1.1/req/topology-vocab-extension/sf-spatial-relations> ;
             rdfs:seeAlso <http://dbpedia.org/resource/DE-9IM> ;
             skos:definition "States that the subject SpatialObject is spatially within the object SpatialObject. DE-9IM: T*F**F***"@en ;
             skos:prefLabel "within"@en .


###  http://www.semanticweb.org/crima/crima-core#classifies
ccore:classifies rdf:type owl:ObjectProperty ;
                 rdfs:domain hip:SpecificHazard ;
                 rdfs:range ccore:Hazard .


###  http://www.semanticweb.org/crima/crima-core#externallyDependOn
ccore:externallyDependOn rdf:type owl:ObjectProperty ;
                         rdfs:domain ccore:ExtrinsicVulnerability ;
                         rdfs:range sosa:FeatureOfInterest .


###  http://www.semanticweb.org/crima/crima-core#hasExtrinsicVulnerability
ccore:hasExtrinsicVulnerability rdf:type owl:ObjectProperty ;
                                rdfs:subPropertyOf ccore:hasVulnerability ;
                                rdfs:range ccore:ExtrinsicVulnerability .


###  http://www.semanticweb.org/crima/crima-core#hasIntrinsicVulnerability
ccore:hasIntrinsicVulnerability rdf:type owl:ObjectProperty ;
                                rdfs:subPropertyOf ccore:hasVulnerability ;
                                rdfs:range ccore:IntrinsicVulnerability .


###  http://www.semanticweb.org/crima/crima-core#hasSpatialExtent
ccore:hasSpatialExtent rdf:type owl:ObjectProperty ;
                       rdfs:range geo:SpatialObject .


###  http://www.semanticweb.org/crima/crima-core#hasVulnerability
ccore:hasVulnerability rdf:type owl:ObjectProperty ;
                       rdfs:domain sosa:FeatureOfInterest ;
                       rdfs:range ccore:Vulnerability .


###  http://www.semanticweb.org/crima/crima-core#inheresIn
ccore:inheresIn rdf:type owl:ObjectProperty ;
                rdfs:domain ccore:IntrinsicVulnerability ;
                rdfs:range sosa:FeatureOfInterest .


###  http://www.semanticweb.org/crima/crima-core#manifestedBy
ccore:manifestedBy rdf:type owl:ObjectProperty ;
                   rdfs:domain ccore:Vulnerability ;
                   rdfs:range ccore:Impact .


###  http://www.semanticweb.org/crima/crima-core#notDisjoint
ccore:notDisjoint rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/crima/crima-core#proxyContentOf
ccore:proxyContentOf rdf:type owl:ObjectProperty ;
                     rdfs:domain sosa:Property ;
                     rdfs:range ccore:Vulnerability .


###  http://www.semanticweb.org/crima/crima-ecv#isProductOf
ecv:isProductOf rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf sosa:isPropertyOf .


###  http://www.semanticweb.org/crima/crima-impactchain#isAbout
ich:isAbout rdf:type owl:ObjectProperty ;
            rdfs:range ich:ImpactChainConnection ,
                       ich:ImpactChainFactor ;
            rdfs:isDefinedBy <https://repository.ifla.org/rest/api/core/bitstreams/3016edd2-d431-4d27-84f9-33d6821f5203/content> ,
                             """\"Definition of FRBROO A Conceptual Model for Bibliographic Information in Object-Oriented Formalism\"

Prepared by: Working Group on FRBR/CRM Dialogue (also referred to as: International Working Group on
FRBR and CIDOC CRM Harmonisation), affiliated to the IFLA FRBR Review Group, reporting to the IFLA Cataloguing Section

Edited by:
Chryssoula Bekiari, Martin Doerr, Patrick Le Bœuf, Pat Riva

With contributions from:
Trond Aalberg, Jérôme Barthélémy, Chryssoula Bekiari, Guillaume Boutard, Martin Doerr, Günther Görz, Dolores Iorizzo, Max Jacob, Carlos Lamsfus, Patrick Le Bœuf, Mika Nyman, João Oliveira, Christian Emil Ore, Allen H. Renear, Pat Riva, Richard Smiraglia, Stephen Stead, Maja Žumer, and others"""@en .


###  http://www.semanticweb.org/crima/crima-impactchain#source
ich:source rdf:type owl:ObjectProperty ,
                    owl:FunctionalProperty ;
           rdfs:comment "[ICconnection --source--> ICFactor]: This property is meant to be used to link the reification of an impact chain binary connection with its first argument."@en .


###  http://www.semanticweb.org/crima/crima-impactchain#target
ich:target rdf:type owl:ObjectProperty ,
                    owl:FunctionalProperty ;
           rdfs:comment "[ICconnections --target--> ICFactor]: This property is meant to be used to link the reification of an impact chain binary connection with its secoond argument."@en .


###  http://www.semanticweb.org/crima/crima-impactchain#timeLag
ich:timeLag rdf:type owl:ObjectProperty ;
            rdfs:domain ich:ImpactChainConnection ;
            rdfs:range ich:ConnectionTimeLag .


###  http://www.w3.org/2004/02/skos/core#broader
skos:broader rdf:type owl:ObjectProperty .


###  http://www.w3.org/2004/02/skos/core#inScheme
skos:inScheme rdf:type owl:ObjectProperty ;
              rdfs:range skos:ConceptScheme .


###  http://www.w3.org/2004/02/skos/core#mappingRelation
skos:mappingRelation rdf:type owl:ObjectProperty .


###  http://www.w3.org/2004/02/skos/core#member
skos:member rdf:type owl:ObjectProperty .


###  http://www.w3.org/2004/02/skos/core#narrower
skos:narrower rdf:type owl:ObjectProperty .


###  http://www.w3.org/2006/time#after
time:after rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf time:disjoint ;
           owl:inverseOf time:before ;
           rdf:type owl:TransitiveProperty ;
           rdfs:domain time:TemporalEntity ;
           rdfs:range time:TemporalEntity ;
           rdfs:label "después"@es ,
                      "is after"@en ;
           skos:definition "Asume una dirección en el tiempo. Si una entidad temporal T1 está después de otra entidad temporal T2, entonces el principio de T1 está después del final de T2."@es ,
                           "Gives directionality to time. If a temporal entity T1 is after another temporal entity T2, then the beginning of T1 is after the end of T2."@en .


###  http://www.w3.org/2006/time#before
time:before rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf time:disjoint ;
            rdf:type owl:TransitiveProperty ;
            rdfs:domain time:TemporalEntity ;
            rdfs:range time:TemporalEntity ;
            rdfs:label "antes"@es ,
                       "is before"@en ;
            skos:definition "Asume una dirección en el tiempo. Si una entidad temporal T1 está antes que otra entidad temporal T2, entonces el final de T1 está antes que el principio de T2. Así, \"antes\" se puede considerar básica para instantes y derivada para intervalos."@es ,
                            "Gives directionality to time. If a temporal entity T1 is before another temporal entity T2, then the end of T1 is before the beginning of T2. Thus, \"before\" can be considered to be basic to instants and derived for intervals."@en .


###  http://www.w3.org/2006/time#disjoint
time:disjoint rdf:type owl:ObjectProperty ;
              rdfs:domain time:TemporalEntity ;
              rdfs:range time:TemporalEntity ;
              rdfs:label "disjoint time entity" ;
              skos:definition "If a temporal entity T1 is disjoint with another temporal entity T2, then the beginning of T1 is after the end of T2, or the end of T1 is before the beginning of T2, i.e. the two entities do not overlap or coincide in any way, but their ordering relationship is not known."@en ;
              skos:example """
ex:LunchTime :disjoint ex:NapTime .
""" .


###  http://www.w3.org/2006/time#equals
time:equals rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf time:notDisjoint ;
            rdfs:domain time:TemporalEntity ;
            rdfs:range time:TemporalEntity ;
            rdfs:label "equal time entity" ;
            skos:definition "If a temporal entity T1 equals another temporal entity T2, then the beginning of T1 is coincident with the beginning of T2, and the end of T1 is coincident with the end of T2, and the beginning of T1 may be coincident with the end of T1."@en ;
            skos:example """
ex:JackWeddingDay :equals ex:AbbyBirthday2020 .
""" .


###  http://www.w3.org/2006/time#hasBeginning
time:hasBeginning rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf time:hasTime ;
                  rdfs:domain time:TemporalEntity ;
                  rdfs:range time:Instant ;
                  rdfs:label "has beginning"@en ;
                  skos:definition "Beginning of a temporal entity."@en .


###  http://www.w3.org/2006/time#hasEnd
time:hasEnd rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf time:hasTime ;
            rdfs:domain time:TemporalEntity ;
            rdfs:range time:Instant ;
            rdfs:label "has end"@en ;
            skos:definition "End of a temporal entity."@en .


###  http://www.w3.org/2006/time#hasInside
time:hasInside rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf time:notDisjoint ;
               rdfs:domain time:TemporalEntity ;
               rdfs:range time:TemporalEntity ;
               rdfs:label "has time entity inside" ;
               skos:definition "If a temporal entity T1 hasInside it another temporal entity T2, then the beginning of T1 is coincident with or before the beginning of T2, and the end of T1 is concident with or after the end of T2, except that end of T1 may not be coincident with the end of T2 if the beginning of T1 is coincident with the beginning of T2."@en ;
               skos:example """
ex:Class :hasInside ex:Quiz .
""" .


###  http://www.w3.org/2006/time#hasTime
time:hasTime rdf:type owl:ObjectProperty ;
             rdfs:range time:TemporalEntity ;
             rdfs:label "has time"@en ;
             skos:definition "Supports the association of a temporal entity (instant or interval) to any thing"@en .


###  http://www.w3.org/2006/time#intervalAfter
time:intervalAfter rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf time:after ,
                                      time:intervalDisjoint ;
                   owl:inverseOf time:intervalBefore ;
                   rdfs:domain time:ProperInterval ;
                   rdfs:range time:ProperInterval ;
                   rdfs:label "interval after"@en ,
                              "intervalo posterior"@es ;
                   skos:definition "If a proper interval T1 is intervalAfter another proper interval T2, then the beginning of T1 is after the end of T2."@en ,
                                   "Si un intervalo propio T1 es posterior a otro intervalo propio T2, entonces el principio de T1 está después que el final de T2."@es .


###  http://www.w3.org/2006/time#intervalBefore
time:intervalBefore rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf time:before ,
                                       time:intervalDisjoint ;
                    rdfs:domain time:ProperInterval ;
                    rdfs:range time:ProperInterval ;
                    rdfs:label "interval before"@en ,
                               "intervalo anterior"@es ;
                    skos:definition "If a proper interval T1 is intervalBefore another proper interval T2, then the end of T1 is before the beginning of T2."@en ,
                                    "Si un intervalo propio T1 está antes que otro intervalo propio T2, entonces el final de T1 está antes que el principio de T2."@es .


###  http://www.w3.org/2006/time#intervalContains
time:intervalContains rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf time:hasInside ;
                      owl:inverseOf time:intervalDuring ;
                      rdfs:domain time:ProperInterval ;
                      rdfs:range time:ProperInterval ;
                      rdfs:label "interval contains"@en ,
                                 "intervalo contiene"@es ;
                      skos:definition "If a proper interval T1 is intervalContains another proper interval T2, then the beginning of T1 is before the beginning of T2, and the end of T1 is after the end of T2."@en ,
                                      "Si un intervalo propio T1 contiene otro intervalo propio T2, entonces el principio de T1 está antes que el principio de T2, y el final de T1 está después del final de T2."@es .


###  http://www.w3.org/2006/time#intervalDisjoint
time:intervalDisjoint rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf time:disjoint ;
                      rdfs:domain time:ProperInterval ;
                      rdfs:range time:ProperInterval ;
                      rdfs:label "interval disjoint"@en ,
                                 "intervalo disjunto"@es ;
                      skos:definition "If a proper interval T1 is intervalDisjoint another proper interval T2, then the beginning of T1 is after the end of T2, or the end of T1 is before the beginning of T2, i.e., the intervals do not overlap in any way, but their ordering relationship is not known."@en ,
                                      "Si un intervalo propio T1 es disjunto con otro intervalo propio T2, entonces el principio de T1 está después del final de T2, o el final de T1 está antes que el principio de T2, es decir, los intervalos no se solapan de ninguna forma, aunque su relación de orden no se conozca."@es ;
                      skos:note "Esta relación entre intervalos no estaba incluida en las 13 relaciones básicas definidas por Allen (1984), pero está definida en T.3 como la unión de 'intervalo anterior' con 'intervalo posterior'. Sin embargo, esto está fuera de la expresividad de OWL2, por tanto, está implementado como una propiedad explícita, con 'intervalo anterior' e 'intervalo posterior' como sub-propiedades."@es ,
                                "This interval relation is not included in the 13 basic relationships defined in Allen (1984), but is defined in (T.3) as the union of :intervalBefore v :intervalAfter . However, that is outside OWL2 expressivity, so is implemented as an explicit property, with :intervalBefore , :intervalAfter as sub-properties"@en .


###  http://www.w3.org/2006/time#intervalDuring
time:intervalDuring rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf time:intervalIn ;
                    rdfs:domain time:ProperInterval ;
                    rdfs:range time:ProperInterval ;
                    rdfs:label "interval during"@en ,
                               "intervalo durante"@es ;
                    skos:definition "If a proper interval T1 is intervalDuring another proper interval T2, then the beginning of T1 is after the beginning of T2, and the end of T1 is before the end of T2."@en ,
                                    "Si un intervalo propio T1 está durante otro intervalo propio T2, entonces del principio de T1 está después del principio de T2, y el final de T1 está antes que el final de T2."@es .


###  http://www.w3.org/2006/time#intervalEquals
time:intervalEquals rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf time:equals ;
                    rdfs:domain time:ProperInterval ;
                    rdfs:range time:ProperInterval ;
                    rdfs:label "interval equals"@en ,
                               "intervalo igual"@es ;
                    skos:definition "If a proper interval T1 is intervalEquals another proper interval T2, then the beginning of T1 is coincident with the beginning of T2, and the end of T1 is coincident with the end of T2."@en ,
                                    "Si un intervalo propio T1 es igual a otro intervalo propio T2, entonces el principio de T1 coincide con el principio de T2, y el final de T1 coincide con el final de T2."@es .


###  http://www.w3.org/2006/time#intervalFinishedBy
time:intervalFinishedBy rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf time:hasInside ;
                        owl:inverseOf time:intervalFinishes ;
                        rdfs:domain time:ProperInterval ;
                        rdfs:range time:ProperInterval ;
                        rdfs:label "interval finished by"@en ,
                                   "intervalo terminado por"@es ;
                        skos:definition "If a proper interval T1 is intervalFinishedBy another proper interval T2, then the beginning of T1 is before the beginning of T2, and the end of T1 is coincident with the end of T2."@en ,
                                        "Si un intervalo propio T1 está terminado por otro intervalo propio T2, entonces el principio de T1 está antes que el principio de T2, y el final de T1 coincide con el final de T2."@es .


###  http://www.w3.org/2006/time#intervalFinishes
time:intervalFinishes rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf time:intervalIn ;
                      rdfs:domain time:ProperInterval ;
                      rdfs:range time:ProperInterval ;
                      rdfs:label "interval finishes"@en ,
                                 "intervalo termina"@es ;
                      skos:definition "If a proper interval T1 is intervalFinishes another proper interval T2, then the beginning of T1 is after the beginning of T2, and the end of T1 is coincident with the end of T2."@en ,
                                      "Si un intervalo propio T1 termina otro intervalo propio T2, entonces del principio de T1 está después del principio de T2, y el final de T1 coincide con el final de T2."@es .


###  http://www.w3.org/2006/time#intervalIn
time:intervalIn rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf time:notDisjoint ;
                rdfs:domain time:ProperInterval ;
                rdfs:range time:ProperInterval ;
                rdfs:label "interval in"@en ,
                           "intervalo interior"@es ;
                skos:definition "If a proper interval T1 is intervalIn another proper interval T2, then the beginning of T1 is after the beginning of T2 or is coincident with the beginning of T2, and the end of T1 is before the end of T2, or is coincident with the end of T2, except that end of T1 may not be coincident with the end of T2 if the beginning of T1 is coincident with the beginning of T2."@en ,
                                "Si un intervalo propio T1 es un intervalo interior a otro intervalo propio T2, entonces el principio de T1 está después del principio de T2 o coincide con el principio de T2, y el final de T1 está antes que el final de T2, o coincide con el final de T2, excepto que el final de T1 puede no coincidir con el final de T2 si el principio de T1 coincide con el principio de T2."@es ;
                skos:note "Esta relación entre intervalos no estaba incluida en las 13 relaciones básicas definidas por Allen (1984), pero se hace referencia a ella como \"una relación importante\" en Allen y Ferguson (1997). Es la unión disjunta de 'intervalo empieza', 'intervalo durante' y con 'intervalo termina'. Sin embargo, esto está fuera de la expresividad de OWL2, por tanto, se implementa como una propiedad explícita, con 'intervalo empieza', 'intervalo durante' e 'intervalo termina' como sub-propiedades."@es ,
                          "This interval relation is not included in the 13 basic relationships defined in Allen (1984), but is referred to as 'an important relationship' in Allen and Ferguson (1997). It is the disjoint union of :intervalStarts v :intervalDuring v :intervalFinishes . However, that is outside OWL2 expressivity, so is implemented as an explicit property, with :intervalStarts , :intervalDuring , :intervalFinishes as sub-properties"@en .


###  http://www.w3.org/2006/time#intervalMeets
time:intervalMeets rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf time:notDisjoint ;
                   owl:inverseOf time:intervalMetBy ;
                   rdfs:domain time:ProperInterval ;
                   rdfs:range time:ProperInterval ;
                   rdfs:label "interval meets"@en ,
                              "intervalo se encuentra"@es ;
                   skos:definition "If a proper interval T1 is intervalMeets another proper interval T2, then the end of T1 is coincident with the beginning of T2."@en ,
                                   "Si un intervalo propio T1 se encuentra con otro intervalo propio T2, entonces el final de T1 coincide con el principio de T2."@es .


###  http://www.w3.org/2006/time#intervalMetBy
time:intervalMetBy rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf time:notDisjoint ;
                   rdfs:domain time:ProperInterval ;
                   rdfs:range time:ProperInterval ;
                   rdfs:label "interval met by"@en ,
                              "intervalo encontrado por"@es ;
                   skos:definition "If a proper interval T1 is intervalMetBy another proper interval T2, then the beginning of T1 is coincident with the end of T2."@en ,
                                   "Si un intervalo propio T1 es 'intervalo encontrado por' otro intervalo propio T2, entonces el principio de T1 coincide con el final de T2."@es .


###  http://www.w3.org/2006/time#intervalOverlappedBy
time:intervalOverlappedBy rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf time:notDisjoint ;
                          owl:inverseOf time:intervalOverlaps ;
                          rdfs:domain time:ProperInterval ;
                          rdfs:range time:ProperInterval ;
                          rdfs:label "interval overlapped by"@en ,
                                     "intervalo solapado por"@es ;
                          skos:definition "If a proper interval T1 is intervalOverlappedBy another proper interval T2, then the beginning of T1 is after the beginning of T2, the beginning of T1 is before the end of T2, and the end of T1 is after the end of T2."@en ,
                                          "Si un intervalo propio T1 es 'intervalo solapado por' otro intervalo propio T2, entonces el principio de T1 es posterior al principio de T2, y el principio de T1 es anterior al final de T2, y el final de T1 es posterior al final de T2."@es .


###  http://www.w3.org/2006/time#intervalOverlaps
time:intervalOverlaps rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf time:notDisjoint ;
                      rdfs:domain time:ProperInterval ;
                      rdfs:range time:ProperInterval ;
                      rdfs:label "interval overlaps"@en ,
                                 "intervalo se solapa"@es ;
                      skos:definition "If a proper interval T1 is intervalOverlaps another proper interval T2, then the beginning of T1 is before the beginning of T2, the end of T1 is after the beginning of T2, and the end of T1 is before the end of T2."@en ,
                                      "Si un intervalo propio T1 se solapa con otro intervalo propio T2, entonces el principio de T1 es anterior al principio de T2, el final de T1 es posterior al principio de T2, y el final de T1 es anterior al final de T2."@es .


###  http://www.w3.org/2006/time#intervalStartedBy
time:intervalStartedBy rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf time:hasInside ;
                       owl:inverseOf time:intervalStarts ;
                       rdfs:domain time:ProperInterval ;
                       rdfs:range time:ProperInterval ;
                       rdfs:label "interval started by"@en ;
                       skos:definition "If a proper interval T1 is intervalStarted another proper interval T2, then the beginning of T1 is coincident with the beginning of T2, and the end of T1 is after the end of T2."@en ,
                                       "Si un intervalo propio T1 es empezado por otro intervalo propio T2, entonces el principio de T1 coincide con el principio de T2, y el final de T1 es posterior al final de T2."@es .


###  http://www.w3.org/2006/time#intervalStarts
time:intervalStarts rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf time:intervalIn ;
                    rdfs:domain time:ProperInterval ;
                    rdfs:range time:ProperInterval ;
                    rdfs:label "interval starts"@en ,
                               "intervalo empieza"@es ;
                    skos:definition "If a proper interval T1 is intervalStarts another proper interval T2, then the beginning of T1 is coincident with the beginning of T2, and the end of T1 is before the end of T2."@en ,
                                    "Si un intervalo propio T1 empieza otro intervalo propio T2, entonces del principio de T1 con el final de T2, y el final de T1 es anterior al final de T2."@es .


###  http://www.w3.org/2006/time#notDisjoint
time:notDisjoint rdf:type owl:ObjectProperty ;
                 rdfs:domain time:TemporalEntity ;
                 rdfs:range time:TemporalEntity ;
                 rdfs:label "not disjoint with time entity" ;
                 skos:definition "If a temporal entity T1 is notDisjoint with another temporal entity T2, then the the two entities not overlap or coincide in some way, but their ordering relationship is not known. This relation is the complement of disjoint and the union of equals, hasInside, in, meets, metBy, overlaps, overlappedBy."@en .


###  http://www.w3.org/ns/prov#hadPrimarySource
prov:hadPrimarySource rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/sosa/deployedAsset
sosa:deployedAsset rdf:type owl:ObjectProperty ;
                   owl:inverseOf sosa:hasDeployment ;
                   schema:domainIncludes sosa:Deployment ;
                   schema:rangeIncludes sosa:Platform ,
                                        sosa:Sensor ,
                                        sosa:System ;
                   rdfs:isDefinedBy sosa-common: ;
                   rdfs:label "deployed asset"@en ;
                   skos:definition """
  relation from a Deployment to an asset (System or Platform)
  """@en .


###  http://www.w3.org/ns/sosa/deployedOnPlatform
sosa:deployedOnPlatform rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf sosa:deployedAsset ;
                        owl:inverseOf sosa:inDeployment ;
                        schema:domainIncludes sosa:Deployment ;
                        schema:rangeIncludes sosa:Platform ;
                        rdfs:isDefinedBy sosa-common: ;
                        rdfs:label "deployed on platform"@en ;
                        skos:definition """
  relation from a Deployment to a Platform on which Systems are hosted
  """@en .


###  http://www.w3.org/ns/sosa/deployedSystem
sosa:deployedSystem rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf sosa:deployedAsset ;
                    owl:inverseOf sosa:systemDeployment ;
                    schema:domainIncludes sosa:Deployment ;
                    schema:rangeIncludes sosa:Sensor ,
                                         sosa:System ;
                    rdfs:isDefinedBy sosa-common: ;
                    rdfs:label "deployed system"@en ;
                    skos:definition """
  relation from a Deployment to a deployed System
  """@en .


###  http://www.w3.org/ns/sosa/detects
sosa:detects rdf:type owl:ObjectProperty ;
             owl:inverseOf sosa:isDetectedBy ;
             schema:domainIncludes sosa:Sensor ;
             schema:rangeIncludes sosa:Stimulus ;
             rdfs:isDefinedBy sosa-obs: ;
             rdfs:label "detects"@en ;
             skos:definition """
  relation from a Sensor to the Stimulus that it detects

  The Stimulus itself will be serving as a proxy for some Property.
  """@en .


###  http://www.w3.org/ns/sosa/forProperty
sosa:forProperty rdf:type owl:ObjectProperty ;
                 owl:inverseOf sosa:propertyFor ;
                 schema:domainIncludes sosa:Procedure ,
                                       sosa:Sensor ,
                                       sosa:System ;
                 schema:rangeIncludes sosa:Property ;
                 rdfs:isDefinedBy sosa-common: ;
                 rdfs:label "for property"@en ;
                 skos:definition """
  relation from some Procedure or System to a Property it acts on or observes
  """@en ;
                 skos:example "For example, from a Sensor to the properties it can observe; from an Actuator to the properties it can act on; from a SystemCapability to the Property the capability is described for."@en .


###  http://www.w3.org/ns/sosa/hasDeployment
sosa:hasDeployment rdf:type owl:ObjectProperty ;
                   schema:domainIncludes sosa:Platform ,
                                         sosa:Sensor ,
                                         sosa:System ;
                   schema:rangeIncludes sosa:Deployment ;
                   rdfs:isDefinedBy sosa-common: ;
                   rdfs:label "has deployment"@en ;
                   skos:definition """
  relation from an asset (System or Platform) to a Deployment
  """@en .


###  http://www.w3.org/ns/sosa/hasFeatureOfInterest
sosa:hasFeatureOfInterest rdf:type owl:ObjectProperty ;
                          owl:inverseOf sosa:isFeatureOfInterestOf ;
                          schema:domainIncludes sosa:Deployment ,
                                                sosa:Execution ,
                                                sosa:ExecutionCollection ,
                                                sosa:Observation ,
                                                sosa:ObservationCollection ;
                          schema:rangeIncludes sosa:FeatureOfInterest ;
                          rdfs:isDefinedBy sosa-common: ;
                          rdfs:label "has feature of interest"@en ;
                          skos:definition """
  relation from an Execution or Deployment to its subject entity

  i.e., from an Actuation to the entity whose property was modified;
  from an Observation to the entity whose quality was observed;
  from an act of Sampling to the entity that was sampled;
  or from a Deployment to its target
  """@en ;
                          skos:example "For example, in an Observation of the weight of a person, the FeatureOfInterest is the person and the property is its weight."@en ;
                          skos:scopeNote "This is the _proximate_ feature of interest, which may be a proxy entity such as a sample of the _ultimate_ feature of interest. Use `hasUltimateFeatureOfInterest` if the intention is to link to the _ultimate_ feature of interest. " .


###  http://www.w3.org/ns/sosa/hasInput
sosa:hasInput rdf:type owl:ObjectProperty ;
              owl:inverseOf sosa:inputFor ;
              schema:domainIncludes sosa:Procedure ;
              rdfs:isDefinedBy sosa-common: ;
              rdfs:label "has input"@en ;
              skos:definition """
  relation from a Procedure to an input required for its execution
  """@en ;
              skos:note "This property will typically describe the type of the inputs required to execute the Procedure."@en ;
              skos:scopeNote "An input might be a calibration or conditioning parameter, or the output of a previous procedure within an extended processing chain."@en .


###  http://www.w3.org/ns/sosa/hasInputValue
sosa:hasInputValue rdf:type owl:ObjectProperty ;
                   owl:inverseOf sosa:inputValueForExecution ;
                   schema:domainIncludes sosa:Execution ,
                                         sosa:ExecutionCollection ,
                                         sosa:Observation ;
                   rdfs:isDefinedBy sosa-common: ;
                   rdfs:label "has input value"@en ;
                   skos:definition """
  assigns a value to an input defined by the Procedure that is used in an Execution
  """@en ;
                   skos:note "The input value MUST be consistent with a hasInput definition from the corresponding Procedure"@en ;
                   skos:scopeNote "The input might be a calibration or conditioning parameter, or the output of a previous procedure within an extended processing chain."@en .


###  http://www.w3.org/ns/sosa/hasMember
sosa:hasMember rdf:type owl:ObjectProperty ;
               owl:inverseOf sosa:isMemberOf ;
               schema:domainIncludes sosa:ExecutionCollection ,
                                     sosa:ObservationCollection ;
               schema:rangeIncludes sosa:Execution ,
                                    sosa:ExecutionCollection ,
                                    sosa:Observation ,
                                    sosa:ObservationCollection ;
               rdfs:isDefinedBy sosa-common: ;
               rdfs:label "has member of collection" ;
               skos:definition """
  link from a Collection to an Execution or Sample or Collection of these that is part of it
  """ ;
               skos:editorialNote "Note that there is a single `member` property. OWL or SHACL constraints may limit the range depending on the context of different collection types" ;
               skos:scopeNote "rules for the consistency of values of properties of collections and properties of their members are given for each collection type" .


###  http://www.w3.org/ns/sosa/hasOutput
sosa:hasOutput rdf:type owl:ObjectProperty ;
               owl:inverseOf sosa:outputFor ;
               schema:domainIncludes sosa:Procedure ;
               rdfs:isDefinedBy sosa-common: ;
               rdfs:label "has output"@en ;
               skos:definition """
  relation from a Procedure to an output of its execution
  """@en ;
               skos:note "This property will typically describe the type of the result from executing the Procedure."@en .


###  http://www.w3.org/ns/sosa/hasProcedure
sosa:hasProcedure rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf sosa:propertyFor ;
                  owl:inverseOf sosa:isProcedureFor ;
                  schema:domainIncludes sosa:Property ;
                  schema:rangeIncludes sosa:Procedure ;
                  rdfs:isDefinedBy sosa-common: ;
                  rdfs:label "has procedure"@en ;
                  skos:definition """
  relation from a Property to a Procedure that can observe or act on it
  """@en .


###  http://www.w3.org/ns/sosa/hasProperty
sosa:hasProperty rdf:type owl:ObjectProperty ;
                 owl:inverseOf sosa:isPropertyOf ;
                 schema:domainIncludes sosa:FeatureOfInterest ;
                 schema:rangeIncludes sosa:Property ;
                 rdfs:isDefinedBy sosa-common: ;
                 rdfs:label "has property"@en ;
                 skos:definition """
  relation from an entity to a Property of that entity
  """@en .


###  http://www.w3.org/ns/sosa/hasProxy
sosa:hasProxy rdf:type owl:ObjectProperty ;
              owl:inverseOf sosa:isProxyFor ;
              schema:domainIncludes sosa:Property ;
              schema:rangeIncludes sosa:Stimulus ;
              rdfs:isDefinedBy sosa-obs: ;
              rdfs:label "has proxy"@en ;
              skos:definition """
  relation from an Property to a Stimulus that serves as its proxy
  """@en ;
              skos:example """
For example, the expansion of mercury is a Stimulus that serves as a proxy for some temperature Property.
An increase or decrease in the velocity of spinning cups on a wind Sensor is serving as a proxy for the wind speed.
  """@en .


###  http://www.w3.org/ns/sosa/hasResult
sosa:hasResult rdf:type owl:ObjectProperty ;
               owl:inverseOf sosa:isResultOf ;
               rdf:type owl:FunctionalProperty ;
               schema:domainIncludes sosa:Execution ,
                                     sosa:ExecutionCollection ,
                                     sosa:Observation ,
                                     sosa:ObservationCollection ;
               rdfs:isDefinedBy sosa-common: ;
               rdfs:label "has result"@en ;
               skos:definition """
  relation from an Execution to its result

  In the case of an Actuation, the result may be the value of the Property following the execution of the Procedure by the Actuator. 

  In the case of an Observation, the result is the value of the Property produced by the execution of the Procedure by the Sensor. 
  
  In the case of a Sampling, the result is the Sample produced by the execution of the Procedure by the Sampler. 

  An Execution has a single result, therefore sosa:hasResult is Functional.
  """@en ;
               skos:note "The result value MUST be consistent with the hasOutput definition from the corresponding Procedure"@en .


###  http://www.w3.org/ns/sosa/hasSubSystem
sosa:hasSubSystem rdf:type owl:ObjectProperty ;
                  owl:inverseOf sosa:isSubSystemOf ;
                  schema:domainIncludes sosa:Sensor ,
                                        sosa:System ;
                  schema:rangeIncludes sosa:Sensor ,
                                       sosa:System ;
                  rdfs:isDefinedBy sosa-common: ;
                  rdfs:label "has subsystem"@en ;
                  skos:definition """
  relation from a System to its component parts
  """@en .


###  http://www.w3.org/ns/sosa/hasUltimateFeatureOfInterest
sosa:hasUltimateFeatureOfInterest rdf:type owl:ObjectProperty ;
                                  owl:inverseOf sosa:isUltimateFeatureOfInterestOf ;
                                  schema:domainIncludes sosa:Deployment ,
                                                        sosa:Execution ,
                                                        sosa:ExecutionCollection ,
                                                        sosa:Observation ,
                                                        sosa:ObservationCollection ;
                                  schema:rangeIncludes sosa:FeatureOfInterest ;
                                  rdfs:isDefinedBy sosa-common: ;
                                  rdfs:label "has ultimate feature of interest"@en ;
                                  skos:definition """
  relation from a Deployment or Execution to its ultimate subject entity

  i.e., from an Actuation to the ultimate entity whose property was modified;
  from an Observation to the ultimate entity whose property was observed;
  from an act of Sampling to the ultimate entity that was sampled;
  or from a Deployment to its ultimate target
  """@en ;
                                  skos:note """should match a property chain something like this but with sosa:isSampleOf*
      owl:propertyChainAxiom ( sosa:hasFeatureOfInterest sosa:isSampleOf )""" ;
                                  skos:scopeNote "This is useful when the proximate feature of interest is a sample of the ultimate feature of interest, directly or transitively." .


###  http://www.w3.org/ns/sosa/hosts
sosa:hosts rdf:type owl:ObjectProperty ;
           owl:inverseOf sosa:isHostedBy ;
           schema:domainIncludes sosa:Platform ;
           schema:rangeIncludes sosa:Platform ,
                                sosa:Sensor ,
                                sosa:System ;
           rdfs:isDefinedBy sosa-common: ;
           rdfs:label "hosts"@en ;
           skos:definition """
  relation from a Platform to an asset (System or Platform) hosted or mounted on it
  """@en .


###  http://www.w3.org/ns/sosa/implementedBy
sosa:implementedBy rdf:type owl:ObjectProperty ;
                   owl:inverseOf sosa:implements ;
                   schema:domainIncludes sosa:Procedure ;
                   schema:rangeIncludes sosa:Sensor ,
                                        sosa:System ;
                   rdfs:isDefinedBy sosa-common: ;
                   rdfs:label "implemented by"@en ;
                   skos:definition """
  relation from a Procedure to a System that is capable of executing it
  """@en ;
                   skos:example "For example, the relationship between a scientific measuring Procedure and a sensor that senses via that Procedure."@en .


###  http://www.w3.org/ns/sosa/implements
sosa:implements rdf:type owl:ObjectProperty ;
                schema:domainIncludes sosa:Sensor ,
                                      sosa:System ;
                schema:rangeIncludes sosa:ObservingProcedure ,
                                     sosa:Procedure ;
                rdfs:isDefinedBy sosa-common: ;
                rdfs:label "implements"@en ;
                skos:definition """
  relation from a System to the Procedure that it is capable of executing
  """@en ;
                skos:example "For example, the relationship between a sensor and the scientific measuring Procedure via which it senses."@en .


###  http://www.w3.org/ns/sosa/inDeployment
sosa:inDeployment rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf sosa:hasDeployment ;
                  schema:domainIncludes sosa:Platform ;
                  schema:rangeIncludes sosa:Deployment ;
                  rdfs:isDefinedBy sosa-common: ;
                  rdfs:label "in deployment"@en ;
                  skos:definition """
  relation from a Platform to a Deployment
  """@en ;
                  skos:example "For example, a relation between a buoy and a deployment of several Sensors."@en .


###  http://www.w3.org/ns/sosa/inputFor
sosa:inputFor rdf:type owl:ObjectProperty ;
              schema:rangeIncludes sosa:Procedure ;
              rdfs:isDefinedBy sosa-common: ;
              rdfs:label "input for"@en ;
              skos:definition """
  relation from an input to a Procedure that uses it in an Execution
  """@en .


###  http://www.w3.org/ns/sosa/inputValueForExecution
sosa:inputValueForExecution rdf:type owl:ObjectProperty ;
                            schema:rangeIncludes sosa:Execution ,
                                                 sosa:ExecutionCollection ,
                                                 sosa:Observation ;
                            rdfs:isDefinedBy sosa-common: ;
                            rdfs:label "input value for execution"@en ;
                            skos:definition """
  relation from an input value to an Execution that used it
  """@en .


###  http://www.w3.org/ns/sosa/isDetectedBy
sosa:isDetectedBy rdf:type owl:ObjectProperty ;
                  schema:domainIncludes sosa:Stimulus ;
                  schema:rangeIncludes sosa:Sensor ;
                  rdfs:isDefinedBy sosa-obs: ;
                  rdfs:label "is detected by"@en ;
                  skos:definition """
  relation from a Stimulus to a Sensor that may detect it

  The Stimulus itself will be serving as a proxy for some Property.
  """@en .


###  http://www.w3.org/ns/sosa/isFeatureOfInterestOf
sosa:isFeatureOfInterestOf rdf:type owl:ObjectProperty ;
                           schema:domainIncludes sosa:FeatureOfInterest ;
                           schema:rangeIncludes sosa:Deployment ,
                                                sosa:Execution ,
                                                sosa:ExecutionCollection ,
                                                sosa:Observation ,
                                                sosa:ObservationCollection ;
                           rdfs:isDefinedBy sosa-common: ;
                           rdfs:label "is feature of interest of"@en ;
                           skos:definition """
  relation from a FeatureOfInterest to an Execution, Execution Collection, or Deployment, operating on it

  i.e., to an Observation about it, to an Actuation acting on it, to an act of Sampling that sampled it,
  or to a Deployment for which it is the subject.
"""@en .


###  http://www.w3.org/ns/sosa/isHostedBy
sosa:isHostedBy rdf:type owl:ObjectProperty ;
                schema:domainIncludes sosa:Platform ,
                                      sosa:Sensor ,
                                      sosa:System ;
                schema:rangeIncludes sosa:Platform ;
                rdfs:isDefinedBy sosa-common: ;
                rdfs:label "is hosted by"@en ;
                skos:definition """
  relation from an asset (System or Platform), to a Platform that it is mounted on or hosted by
  """@en .


###  http://www.w3.org/ns/sosa/isMemberOf
sosa:isMemberOf rdf:type owl:ObjectProperty ;
                schema:domainIncludes sosa:Execution ,
                                      sosa:ExecutionCollection ,
                                      sosa:Observation ,
                                      sosa:ObservationCollection ;
                schema:rangeIncludes sosa:ExecutionCollection ,
                                     sosa:ObservationCollection ;
                rdfs:isDefinedBy sosa-common: ;
                rdfs:label "is member of collection" ;
                skos:definition """
  link from an Execution or Sample or Collection of these, to a collection that it is part of
  """ ;
                skos:editorialNote "Note that there is a single `member` property. OWL or SHACL constraints may limit the range depending on the context of different collection types" ;
                skos:scopeNote "rules for the consistency of values of properties of collections and properties of their members are given for each collection type" .


###  http://www.w3.org/ns/sosa/isObservedBy
sosa:isObservedBy rdf:type owl:ObjectProperty ;
                  owl:inverseOf sosa:observes ;
                  schema:domainIncludes sosa:Property ;
                  schema:rangeIncludes sosa:Sensor ;
                  rdfs:isDefinedBy sosa-obs: ;
                  rdfs:label "is observed by"@en ;
                  skos:definition """
  relation from a Property to a Sensor that is able to observe it
  """@en .


###  http://www.w3.org/ns/sosa/isProcedureFor
sosa:isProcedureFor rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf sosa:forProperty ;
                    schema:domainIncludes sosa:Procedure ;
                    schema:rangeIncludes sosa:Property ;
                    rdfs:isDefinedBy sosa-common: ;
                    rdfs:label "is procedure for"@en ;
                    skos:definition """
  relation from a Procedure to a Property that it can observe or act on
  """@en .


###  http://www.w3.org/ns/sosa/isPropertyOf
sosa:isPropertyOf rdf:type owl:ObjectProperty ;
                  schema:domainIncludes sosa:Property ;
                  schema:rangeIncludes sosa:FeatureOfInterest ;
                  rdfs:isDefinedBy sosa-common: ;
                  rdfs:label "is property of"@en ;
                  skos:definition """
  relation from a Property to a FeatureOfInterest that it is a quality of
  """@en .


###  http://www.w3.org/ns/sosa/isProxyFor
sosa:isProxyFor rdf:type owl:ObjectProperty ;
                schema:domainIncludes sosa:Stimulus ;
                schema:rangeIncludes sosa:Property ;
                rdfs:isDefinedBy sosa-obs: ;
                rdfs:label "is proxy for"@en ;
                skos:definition """
  relation from a Stimulus to the Property for which it is serving as a proxy
  """@en ;
                skos:example "For example, the expansion of quicksilver is a stimulus that serves as a proxy for some temperature property. An increase or decrease in the velocity of spinning cups on a wind sensor is serving as a proxy for the wind speed."@en .


###  http://www.w3.org/ns/sosa/isResultOf
sosa:isResultOf rdf:type owl:ObjectProperty ;
                schema:rangeIncludes sosa:Execution ,
                                     sosa:ExecutionCollection ,
                                     sosa:Observation ;
                rdfs:isDefinedBy sosa-common: ;
                rdfs:label "is result of"@en ;
                skos:definition """
  relation from a result to the Execution that created or caused it
  """@en .


###  http://www.w3.org/ns/sosa/isSubSystemOf
sosa:isSubSystemOf rdf:type owl:ObjectProperty ;
                   schema:domainIncludes sosa:Sensor ,
                                         sosa:System ;
                   schema:rangeIncludes sosa:Sensor ,
                                        sosa:System ;
                   rdfs:isDefinedBy sosa-common: ;
                   rdfs:label "is subsystem of"@en ;
                   skos:definition """
  relation from a component System to a System that it belongs to
  """@en .


###  http://www.w3.org/ns/sosa/isUltimateFeatureOfInterestOf
sosa:isUltimateFeatureOfInterestOf rdf:type owl:ObjectProperty ;
                                   schema:domainIncludes sosa:FeatureOfInterest ;
                                   schema:rangeIncludes sosa:Deployment ,
                                                        sosa:Execution ,
                                                        sosa:ExecutionCollection ,
                                                        sosa:Observation ,
                                                        sosa:ObservationCollection ;
                                   rdfs:isDefinedBy sosa-common: ;
                                   rdfs:label "is ultimate feature of interest of"@en ;
                                   skos:definition """
  relation from an ultimate FeatureOfInterest to an Execution, Execution Collection, or Deployment, for which it is the ultimate subject
  """@en .


###  http://www.w3.org/ns/sosa/madeBySensor
sosa:madeBySensor rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf sosa:madeBySystem ;
                  owl:inverseOf sosa:madeObservation ;
                  schema:domainIncludes sosa:Observation ,
                                        sosa:ObservationCollection ;
                  schema:rangeIncludes sosa:Sensor ;
                  rdfs:isDefinedBy sosa-obs: ;
                  rdfs:label "made by sensor or observer"@en ;
                  skos:definition """
  relation from an Observation or ObservationCollection to the Sensor that made it
  """@en .


###  http://www.w3.org/ns/sosa/madeBySystem
sosa:madeBySystem rdf:type owl:ObjectProperty ;
                  owl:inverseOf sosa:madeExecution ;
                  schema:domainIncludes sosa:Execution ,
                                        sosa:ExecutionCollection ;
                  schema:rangeIncludes sosa:System ;
                  rdfs:isDefinedBy sosa-common: ;
                  rdfs:label "made by system"@en ;
                  skos:definition """
  relation from an Execution to the System that made it
  """@en ;
                  skos:scopeNote """
  madeBySystem generalizes the madeByActuator, madeBySensor, and madeBySampler properties. 
  It is included in the ontology to support the definition of a common pattern for executions and their properties. 

  madeBySystem MUST be considered to be abstract, so SHOULD NOT appear in data instances. 
  Applications can use concrete sub-properties of madeBySystem.
  """@en .


###  http://www.w3.org/ns/sosa/madeExecution
sosa:madeExecution rdf:type owl:ObjectProperty ;
                   schema:domainIncludes sosa:System ;
                   schema:rangeIncludes sosa:Execution ,
                                        sosa:ExecutionCollection ;
                   rdfs:isDefinedBy sosa-common: ;
                   rdfs:label "made execution"@en ;
                   skos:definition """
  relation from a System to an Execution or ExecutionCollection that it has made
  """@en ;
                   skos:scopeNote """
  madeExecution generalizes the madeActuation, madeObservation, and madeSampling properties. 
  It is included in the ontology to support the definition of a common pattern for executions and their properties. 

  madeExecution MUST be considered to be abstract, so SHOULD NOT appear in data instances. 
  Applications can use concrete sub-properties of madeExecution.
  """@en .


###  http://www.w3.org/ns/sosa/madeObservation
sosa:madeObservation rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf sosa:madeExecution ;
                     schema:domainIncludes sosa:Sensor ;
                     schema:rangeIncludes sosa:Observation ,
                                          sosa:ObservationCollection ;
                     rdfs:isDefinedBy sosa-obs: ;
                     rdfs:label "made observation"@en ;
                     skos:definition """
  relation from a Sensor to an Observation or ObservationCollection it has made
  """@en .


###  http://www.w3.org/ns/sosa/observationRelatedTo
sosa:observationRelatedTo rdf:type owl:ObjectProperty ;
                          owl:inverseOf sosa:relatedObservation ;
                          schema:domainIncludes sosa:Observation ,
                                                sosa:ObservationCollection ;
                          schema:rangeIncludes sosa:Execution ,
                                               sosa:ExecutionCollection ;
                          rdfs:isDefinedBy sosa-obs: ;
                          rdfs:label "observation related to"@en ;
                          skos:definition """
  relation from an Observation or ObservationCollection to another Execution or ExecutionCollection
  """@en ;
                          skos:scopeNote "This general relationship complements the specific predicates outbound from Observation. It is particularly useful to relate Observations (and collections) to other Executions (and collections)" .


###  http://www.w3.org/ns/sosa/observedProperty
sosa:observedProperty rdf:type owl:ObjectProperty ;
                      owl:inverseOf sosa:wasObservedBy ;
                      schema:domainIncludes sosa:Observation ,
                                            sosa:ObservationCollection ;
                      schema:rangeIncludes sosa:Property ;
                      rdfs:isDefinedBy sosa-obs: ;
                      rdfs:label "observed property"@en ;
                      skos:definition """
  relation from an Observation or ObservationCollection to the property that was observed
  """@en ;
                      skos:note """
  'observed property' covers the concepts referred to in [VIM] as 'measurand' (quantitative values) and 'examinand' (categorical and nominal values — [VIM4]), as well as complex and structured properties whose values may be represented as lists, vectors, arrays, rasters, geometries, etc. More specific terms are used in other contexts for related concepts, such as 'analyte' (chemistry) and 'determinand' (water quality).
  """@en .


###  http://www.w3.org/ns/sosa/observes
sosa:observes rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf sosa:forProperty ;
              schema:domainIncludes sosa:Sensor ;
              schema:rangeIncludes sosa:Property ;
              rdfs:isDefinedBy sosa-obs: ;
              rdfs:label "observes"@en ;
              skos:definition """
  relation from a Sensor to a Property that it is capable of sensing
  """@en .


###  http://www.w3.org/ns/sosa/originated
sosa:originated rdf:type owl:ObjectProperty ;
                owl:inverseOf sosa:wasOriginatedBy ;
                schema:domainIncludes sosa:Stimulus ;
                schema:rangeIncludes sosa:Observation ;
                rdfs:isDefinedBy sosa-obs: ;
                rdfs:label "originated"@en ;
                skos:definition """
  relation from a Stimulus to an Observation that was originated by it
  """@en .


###  http://www.w3.org/ns/sosa/outputFor
sosa:outputFor rdf:type owl:ObjectProperty ;
               schema:rangeIncludes sosa:Procedure ;
               rdfs:isDefinedBy sosa-common: ;
               rdfs:label "output for"@en ;
               skos:definition """
  relation from an output to a Procedure that generates it in an Execution
  """@en .


###  http://www.w3.org/ns/sosa/phenomenonOccurred
sosa:phenomenonOccurred rdf:type owl:ObjectProperty ;
                        owl:inverseOf sosa:phenomenonTime ;
                        schema:domainIncludes time:TemporalEntity ;
                        schema:rangeIncludes sosa:Execution ,
                                             sosa:ExecutionCollection ,
                                             sosa:Observation ;
                        rdfs:isDefinedBy sosa-common: ;
                        rdfs:label "phenomenon occurred"@en ;
                        skos:definition """
  result of an Execution that this time applies to
  """@en .


###  http://www.w3.org/ns/sosa/phenomenonTime
sosa:phenomenonTime rdf:type owl:ObjectProperty ;
                    schema:domainIncludes sosa:Execution ,
                                          sosa:ExecutionCollection ,
                                          sosa:Observation ,
                                          sosa:ObservationCollection ;
                    schema:rangeIncludes time:TemporalEntity ;
                    rdfs:isDefinedBy sosa-common: ;
                    rdfs:label "phenomenon time"@en ;
                    skos:definition """
  time that the result of an Execution applies to the subject entity

  It may be an interval or an instant, or some other compound temporal entity [[!owl-time]].
  """@en ;
                    skos:scopeNote """
  The phenomenonTime is not necessarily the same as the resultTime. 
  
  In the case of Actuation, phenomenonTime SHOULD indicate the time during which the actuator was active. 

  In the case of Observation, the phenomenonTime MAY be distant from the resultTime. 
  For example in the case of forecasts the phenomenonTime is after the resultTime. 
  In historical, geological and cosmological investigations the phenomenonTime can be far in the past, while the resultTime is contemporary. 

  In the case of Sampling the phenomenonTime SHOULD indicate the time during which the Sampling Procedure was active.
  The resultTime can indicate when the sample comes into the posession of the operator. 
  """@en .


###  http://www.w3.org/ns/sosa/propertyFor
sosa:propertyFor rdf:type owl:ObjectProperty ;
                 schema:domainIncludes sosa:Property ;
                 schema:rangeIncludes sosa:Procedure ,
                                      sosa:Sensor ,
                                      sosa:System ;
                 rdfs:isDefinedBy sosa-common: ;
                 rdfs:label "property for"@en ;
                 skos:definition """
  relation from a Property to some Procedure or System that acts on it or observes it
  """@en ;
                 skos:example "For example, from a Sensor to the properties it can observe; from an Actuator to the properties it can act on; from a SystemCapability to the Property the capability is described for."@en .


###  http://www.w3.org/ns/sosa/qualityOf
sosa:qualityOf rdf:type owl:ObjectProperty ;
               owl:inverseOf sosa:resultQuality ;
               schema:rangeIncludes sosa:Observation ,
                                    sosa:ObservationCollection ;
               rdfs:isDefinedBy sosa-obs: ;
               rdfs:label "quality of" ;
               skos:definition """
  link from a quality description to an Observation or ObservationCollection that it relates to
  """@en .


###  http://www.w3.org/ns/sosa/relatedObservation
sosa:relatedObservation rdf:type owl:ObjectProperty ;
                        schema:domainIncludes sosa:Execution ,
                                              sosa:ExecutionCollection ;
                        schema:rangeIncludes sosa:Observation ,
                                             sosa:ObservationCollection ;
                        rdfs:isDefinedBy sosa-obs: ;
                        rdfs:label "related observation"@en ;
                        skos:definition """
  relation from an Execution or ExecutionCollection to an Observation or ObservationCollection
  """@en ;
                        skos:scopeNote "This general relationship complements the specific predicates inbound to Observation. It is particularly useful to relate Observations (and collections) to other Executions (and collections)" .


###  http://www.w3.org/ns/sosa/resultQuality
sosa:resultQuality rdf:type owl:ObjectProperty ;
                   schema:domainIncludes sosa:Observation ,
                                         sosa:ObservationCollection ;
                   rdfs:isDefinedBy sosa-obs: ;
                   rdfs:label "observation result quality" ;
                   skos:definition """
  relation from an Observation or ObservationCollection to some information pertaining to the quality of the result
  """@en ;
                   skos:note """
  The quality of a result can be assessed following the procedures in the ISO 19157 series.
  """ ,
                             "dqv:hasQualityMeasurement from the Data Quality Vocabulary is equivalent" ;
                   skos:scopeNote """
  This instance-specific description complements the description of the observation Procedure, which provides information concerning the quality of all observations using this procedure. Multiple measures can be provided.
  """@en .


###  http://www.w3.org/ns/sosa/systemDeployment
sosa:systemDeployment rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf sosa:hasDeployment ;
                      schema:domainIncludes sosa:System ;
                      schema:rangeIncludes sosa:Deployment ;
                      rdfs:isDefinedBy sosa-common: ;
                      rdfs:label "system deployment"@en ;
                      skos:definition """
  relation from a System to a Deployment
  """@en .


###  http://www.w3.org/ns/sosa/usedForExecution
sosa:usedForExecution rdf:type owl:ObjectProperty ;
                      owl:inverseOf sosa:usedProcedure ;
                      schema:domainIncludes sosa:Procedure ;
                      schema:rangeIncludes sosa:Execution ,
                                           sosa:Observation ;
                      rdfs:isDefinedBy sosa-common: ;
                      rdfs:label "used for execution"@en ;
                      skos:definition """
  relation from a Procedure to an Execution or ExecutionCollection made using it
  """@en .


###  http://www.w3.org/ns/sosa/usedProcedure
sosa:usedProcedure rdf:type owl:ObjectProperty ;
                   schema:domainIncludes sosa:Execution ,
                                         sosa:ExecutionCollection ,
                                         sosa:Observation ,
                                         sosa:ObservationCollection ;
                   schema:rangeIncludes sosa:ObservingProcedure ,
                                        sosa:Procedure ;
                   rdfs:isDefinedBy sosa-common: ;
                   rdfs:label "used procedure"@en ;
                   skos:definition """
  relation from an Execution or ExecutionCollection to a Procedure used to make it
  """@en .


###  http://www.w3.org/ns/sosa/wasObservedBy
sosa:wasObservedBy rdf:type owl:ObjectProperty ;
                   schema:domainIncludes sosa:Property ;
                   schema:rangeIncludes sosa:Observation ,
                                        sosa:ObservationCollection ;
                   rdfs:isDefinedBy sosa-obs: ;
                   rdfs:label "was observed by"@en ;
                   skos:definition """
  relation from a Property to an Observation that observed it
  """@en .


###  http://www.w3.org/ns/sosa/wasOriginatedBy
sosa:wasOriginatedBy rdf:type owl:ObjectProperty ;
                     schema:domainIncludes sosa:Observation ,
                                           sosa:ObservationCollection ;
                     schema:rangeIncludes sosa:Stimulus ;
                     rdfs:isDefinedBy sosa-obs: ;
                     rdfs:label "was originated by"@en ;
                     skos:definition """
  relation from an Observation to the Stimulus that originated it
  """@en .


###  https://undrr-hip.org/broader
hip:broader rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf skos:broader ;
            owl:inverseOf hip:narrower ;
            rdfs:label "broader" .


###  https://undrr-hip.org/coordinationOrganization
hip:coordinationOrganization rdf:type owl:ObjectProperty ;
                             rdfs:subPropertyOf prov:hadPrimarySource .


###  https://undrr-hip.org/definedAs
hip:definedAs rdf:type owl:ObjectProperty ;
              rdfs:label "defined as" .


###  https://undrr-hip.org/definitionSource
hip:definitionSource rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf prov:hadPrimarySource .


###  https://undrr-hip.org/describedAs
hip:describedAs rdf:type owl:ObjectProperty ;
                rdfs:label "described as" .


###  https://undrr-hip.org/hasMember
hip:hasMember rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf skos:member ;
              owl:inverseOf hip:isMemberOf ;
              rdfs:label "has member" .


###  https://undrr-hip.org/isMemberOf
hip:isMemberOf rdf:type owl:ObjectProperty ;
               rdfs:label "is member of" .


###  https://undrr-hip.org/narrower
hip:narrower rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf skos:narrower ;
             rdfs:label "narrower" .


#################################################################
#    Data properties
#################################################################

###  http://purl.org/dc/terms/bibliographicCitation
dcterms:bibliographicCitation rdf:type owl:DatatypeProperty .


###  http://purl.org/dc/terms/identifier
dcterms:identifier rdf:type owl:DatatypeProperty .


###  http://qudt.org/schema/qudt/numericValue
qudt:numericValue rdf:type owl:DatatypeProperty ;
                  rdfs:range dtype:numericUnion ;
                  rdfs:label "numeric value" .


###  http://www.opengis.net/ont/geosparql#asWKT
geo:asWKT rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf geo:hasSerialization ;
          rdfs:domain geo:Geometry ;
          rdfs:range geo:wktLiteral ;
          skos:definition "The WKT serialization of a Geometry."@en ;
          skos:prefLabel "as WKT"@en .


###  http://www.opengis.net/ont/geosparql#hasSerialization
geo:hasSerialization rdf:type owl:DatatypeProperty ;
                     rdfs:domain geo:Geometry ;
                     rdfs:range rdfs:Literal ;
                     skos:definition "Connects a Geometry object with its text-based serialization."@en ;
                     skos:prefLabel "has serialization"@en .


###  http://www.w3.org/ns/sosa/endTime
sosa:endTime rdf:type owl:DatatypeProperty ;
             schema:domainIncludes sosa:Deployment ,
                                   sosa:Execution ,
                                   sosa:ExecutionCollection ;
             rdfs:comment "The value would usually be encoded using xsd:dateTime xsd:date xsd:gYearMonth xsd:gYear"@en ;
             rdfs:isDefinedBy sosa-common: ;
             rdfs:label "end time"@en ;
             skos:definition """
  instant of time when the Execution or Deployment was ended or completed
  """@en .


###  http://www.w3.org/ns/sosa/hasSimpleResult
sosa:hasSimpleResult rdf:type owl:DatatypeProperty ,
                              owl:FunctionalProperty ;
                     schema:domainIncludes sosa:Execution ,
                                           sosa:ExecutionCollection ,
                                           sosa:Observation ,
                                           sosa:ObservationCollection ;
                     rdfs:isDefinedBy sosa-common: ;
                     rdfs:label "has simple result"@en ;
                     skos:definition """
  relation from an Execution to its value expressed as a literal

  In the case of an Actuation, the result may be the value of the Property following the execution of the Procedure by the Actuator. 

  In the case of an Observation, the result is the value of the Property produced by the execution of the Procedure by the Sensor. 
  """@en ;
                     skos:example "For instance, the values 23 or true."@en ;
                     skos:note "This DatatypeProperty provides an alternative to hasResult, to be used only if the execution result can be expressed as a Literal"@en .


###  http://www.w3.org/ns/sosa/resultTime
sosa:resultTime rdf:type owl:DatatypeProperty ;
                schema:domainIncludes sosa:Execution ,
                                      sosa:ExecutionCollection ,
                                      sosa:Observation ,
                                      sosa:ObservationCollection ;
                rdfs:comment "The value would usually be encoded using xsd:dateTime xsd:date xsd:gYearMonth xsd:gYear"@en ;
                rdfs:isDefinedBy sosa-common: ;
                rdfs:label "result time"@en ;
                skos:definition """
  instant of time when the result of the Execution became available
  """@en .


###  http://www.w3.org/ns/sosa/startTime
sosa:startTime rdf:type owl:DatatypeProperty ;
               schema:domainIncludes sosa:Deployment ,
                                     sosa:Execution ,
                                     sosa:ExecutionCollection ,
                                     sosa:Observation ,
                                     sosa:ObservationCollection ;
               rdfs:comment "The value would usually be encoded using xsd:dateTime xsd:date xsd:gYearMonth xsd:gYear"@en ;
               rdfs:isDefinedBy sosa-common: ;
               rdfs:label "start time"@en ;
               skos:definition """
  instant of time when the Execution or Deployment was initiated or tasked
  """@en .


###  https://undrr-hip.org/identifier
hip:identifier rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf dcterms:identifier .


###  https://www.w3.org/ns/activitystreams#latitude
as:latitude rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf geo:hasSerialization ;
            rdf:type owl:FunctionalProperty ;
            rdfs:range xsd:float ;
            rdfs:comment "The latitude"@en ;
            rdfs:label "latitude"@en .


###  https://www.w3.org/ns/activitystreams#longitude
as:longitude rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf geo:hasSerialization ;
             rdf:type owl:FunctionalProperty ;
             rdfs:range xsd:float ;
             rdfs:comment "The longitude"@en ;
             rdfs:label "longitude"@en .


