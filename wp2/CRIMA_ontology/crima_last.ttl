###  http://www.semanticweb.org/crima/crima-ecv#Peatlands
ecv:Peatlands rdf:type owl:NamedIndividual ,
                       ecv:ecv-product ;
              qudt:hasUnit unit:M ;
              ecv:isProductOf ecv:SoilCarbon ;
              skos:definition "Depth of peat measured on a regular grid (where peat exists)." ;
