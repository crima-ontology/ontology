                                            ecv:ecv-variable ;
                                   skos:broader ecv:UpperAtmosphere .


###  http://www.semanticweb.org/crima/crima-ecv#UpperAtmosphere
ecv:UpperAtmosphere rdf:type owl:NamedIndividual ,
                             ecv:ecv-subdomain ;
                    skos:member ecv:Atmosphere .


###  http://www.semanticweb.org/crima/crima-ecv#UpwardLong-WaveIrradianceAtEarthSurface
ecv:UpwardLong-WaveIrradianceAtEarthSurface rdf:type owl:NamedIndividual ,
                                                     ecv:ecv-product ;
                                            qudt:hasUnit unit:W-PER-M2 ;
                                            ecv:isProductOf ecv:SurfaceRadiationBudget ;
                                            skos:definition "Flux density of terrestrial radiation emitted by the Earth surface." ;
                                            skos:note "Main driver of the uncertainty in the components of the surface radiation budget is the composition of the atmosphere (e.g. Water vapour, Aerosols, Clouds)”. The Required Measurement Uncertainty (2-sigma) (see the VIM & GUM) includes both random and systematic components. The uncertainty is meant to be an uncertainty for the measurement device / instrument / ECV algorithm. The uncertainty of spatially and temporally averaged global mean value might be smaller." .


###  http://www.semanticweb.org/crima/crima-ecv#UpwardLong-WaveIrradianceAtTopOfTheAtmosphere
ecv:UpwardLong-WaveIrradianceAtTopOfTheAtmosphere rdf:type owl:NamedIndividual ,
                                                           ecv:ecv-product ;
                                                  qudt:hasUnit unit:W-PER-M2 ;
                                                  ecv:isProductOf ecv:EarthRadiationBudget .


###  http://www.semanticweb.org/crima/crima-ecv#UpwardShort-WaveIrradianceAtTopOfTheAtmosphere
ecv:UpwardShort-WaveIrradianceAtTopOfTheAtmosphere rdf:type owl:NamedIndividual ,
                                                            ecv:ecv-product ;
                                                   qudt:hasUnit unit:W-PER-M2 ;
                                                   ecv:isProductOf ecv:EarthRadiationBudget ;
                                                   skos:definition "Flux density of solar radiation, reflected by the Earth surface and atmosphere, emitted to space at the top of the atmosphere." ;
                                                   skos:note "The measurand for this ECV is radiance (W·sr−1·m−2). The current approach adopted by the Clouds and Earth’s Radiant Energy System (CERES) is to derive irradiances (Wm-2) from measured radiances using observed anisotropy factors over various scene types." .


###  http://www.semanticweb.org/crima/crima-ecv#VerticalMixing
ecv:VerticalMixing rdf:type owl:NamedIndividual ,
                            ecv:ecv-product ;
                   qudt:hasUnit unit:M-PER-SEC ;
                   ecv:isProductOf ecv:SubsurfaceCurrents ;
                   skos:definition "Ocean vector motion measured at or near the surface (3D, at stated depth)." ;
                   skos:note "A difference between Upper (<2000 m) and Deep (>2000 m) ocean is established." .


###  http://www.semanticweb.org/crima/crima-ecv#WaterLeavingRadiance
ecv:WaterLeavingRadiance rdf:type owl:NamedIndividual ,
                                  ecv:ecv-product ;
                         ecv:isProductOf ecv:OceanColour ;
                         skos:definition "Amount of light emanating from within the ocean." ;
                         skos:note """Ocean colour is the radiance emanating from the ocean normalized by the irradiance illuminating the ocean. Products derived from ocean colour remote sensing (OCRS) contain information on the ocean albedo and information on the constituents of the seawater, in particular, phytoplankton pigments such
as chlorophyll-a.""" ,
                                   "Unit: Dimensionless" .


###  http://www.semanticweb.org/crima/crima-ecv#WaterLevel
ecv:WaterLevel rdf:type owl:NamedIndividual ,
                        ecv:ecv-product ;
               qudt:hasUnit unit:M ;
               ecv:isProductOf ecv:RiverDischarge ;
               skos:definition "Water Level is the elevation of the water surface of a river (or a lake, reservoir) regarding a reference (the ellipsoid)." .


###  http://www.semanticweb.org/crima/crima-ecv#WaterVapourMixingRatioInTheMesosphere
ecv:WaterVapourMixingRatioInTheMesosphere rdf:type owl:NamedIndividual ,
                                                   ecv:ecv-product ;
                                          qudt:hasUnit unit:PPM ;
                                          ecv:isProductOf ecv:Upper-airWaterVapour ;
                                          skos:definition "3D field of water vapour mixing ratios in the mesosphere. Mixing ratio is the mole fraction of a substance in dry air." ;
                                          skos:note "Consistency with temperature requirements for the same layer was used as a primary guiding consideration for horizontal resolution. However, for the breakthrough, there is no justification to use the same value as for temperature that is significantly smaller." .


###  http://www.semanticweb.org/crima/crima-ecv#WaterVapourMixingRatioInTheMiddleAndUpperStratosphere
ecv:WaterVapourMixingRatioInTheMiddleAndUpperStratosphere rdf:type owl:NamedIndividual ,
                                                                   ecv:ecv-product ;
                                                          qudt:hasUnit unit:PPM ;
                                                          ecv:isProductOf ecv:Upper-airWaterVapour ;
                                                          skos:definition "3D field of water vapor mixing ratios in the middle and upper stratosphere. Mixing ratio is the mole fraction of a substance in dry air." ;
                                                          skos:note "Consistency with temperature requirements for the same layer was used as a primary guiding consideration for horizontal resolution. However, for the breakthrough, there is no justification to use the same value as for temperature that is significantly smaller." .


###  http://www.semanticweb.org/crima/crima-ecv#WaterVapourMixingRatioInTheUpperTroposphereAndLowerStratosphere
ecv:WaterVapourMixingRatioInTheUpperTroposphereAndLowerStratosphere rdf:type owl:NamedIndividual ,
                                                                             ecv:ecv-product ;
                                                                    qudt:hasUnit unit:PPM ;
                                                                    ecv:isProductOf ecv:Upper-airWaterVapour ;
                                                                    skos:definition "3D field of water vapour mixing ratios in the UTLS. Mixing ratio is the mole fraction of a substance in dry air." ;
                                                                    skos:note "Consistency with temperature requirements for the same layer was used as a primary guiding consideration for horizontal resolution. Vertical resolution needed for determining fine layer cirrus and complex tropopause." .


###  http://www.semanticweb.org/crima/crima-ecv#WaveHeight
ecv:WaveHeight rdf:type owl:NamedIndividual ,
                        ecv:ecv-product ;
               qudt:hasUnit unit:CentiM ;
               ecv:isProductOf ecv:SeaState ;
               skos:definition "The distance between the trough of the wave and the adjacent crest of the wave. The significant wave height is the mean wave height (trough to crest) of the highest third of the waves in a wave spectrum." .


###  http://www.semanticweb.org/crima/crima-ecv#Wind-horizontal-InTheBoundaryLayer
ecv:Wind-horizontal-InTheBoundaryLayer rdf:type owl:NamedIndividual ,
                                                ecv:ecv-product ;
                                       qudt:hasUnit unit:M-PER-SEC ;
                                       ecv:isProductOf ecv:Upper-airWindSpeedAndDirection ;
                                       skos:definition "3D field of the horizontal vector component (2D) of the 3D wind vector in the boundary layer." ;
                                       skos:note "The following requirements are inferred mainly from the viewpoint of reanalysis and its near- real-time continuation as users of this ECV. Some additional considerations are also made, for which explanations are given in notes below this table. Additional goal requirements for the lowermost part of the boundary layer (values in parentheses) are for better sampling of micrometeorological phenomena and accurate calculation of fluxes." .


