                           ecv:isProductOf ecv:AnthropogenicWaterUse ;
                           skos:definition "Volume of water used by country, by sector – agricultural, industrial and domestic." ;
                           skos:note "AQUASTAT contains estimates of water use by county." ,
                                     "Unit: Volume of water used by country." .


###  http://www.semanticweb.org/crima/crima-ecv#AnthropogenicCH4Emissions
ecv:AnthropogenicCH4Emissions rdf:type owl:NamedIndividual ,
                                       ecv:ecv-product ;
                              qudt:hasUnit cunit:MegaGM-CH4-PER-YR ;
                              ecv:isProductOf ecv:AnthropogenicGreenhouseGasEmissions ;
                              skos:definition "Anthropogenic CH4 emissions are mainly originating from fermentation processes in waste (landfills), manure, enteric fermentation, but also from fossil fuel extraction, transmission and distribution and use, and industrial processes." ;
                              skos:note "This corresponds to UNFCCC reporting of anthropogenic emissions of methane, except from wetlands." .


###  http://www.semanticweb.org/crima/crima-ecv#AnthropogenicCO2Emissions
ecv:AnthropogenicCO2Emissions rdf:type owl:NamedIndividual ,
                                       ecv:ecv-product ;
                              qudt:hasUnit cunit:MegaGM-CO2-PER-YR ;
                              ecv:isProductOf ecv:AnthropogenicGreenhouseGasEmissions ;
                              skos:definition "Anthropogenic long-cycle C emissions are mainly originating from combustion of fossil fuels, and for about 10% also from non-combustion sources, such as cement production, ferrous and non-ferrous metal production processes, urea production, agricultural liming and solvent use." ;
                              skos:note "This corresponds to UNFCCC reporting of anthropogenic emissions from non-LULUCF sources by country." .


###  http://www.semanticweb.org/crima/crima-ecv#AnthropogenicCO2Emissions-RemovalsByLandCategories
ecv:AnthropogenicCO2Emissions-RemovalsByLandCategories rdf:type owl:NamedIndividual ,
                                                                ecv:ecv-product ;
                                                       qudt:hasUnit cunit:MegaGM-CO2-PER-YR ;
                                                       ecv:isProductOf ecv:AnthropogenicGreenhouseGasEmissions ;
                                                       skos:definition "Short and long cycle C emissions from land use, land-use and forestry (including carbon stock gains and losses of biomass burning, disease, harvest, net deforestation)." ;
                                                       skos:note "This corresponds to UNFCCC reporting of anthropogenic emissions and removals from LULUCF." .


###  http://www.semanticweb.org/crima/crima-ecv#AnthropogenicF-GasEmissions
ecv:AnthropogenicF-GasEmissions rdf:type owl:NamedIndividual ,
                                         ecv:ecv-product ;
                                qudt:hasUnit cunit:MegaGM-CO2eq-PER-YR ;
                                ecv:isProductOf ecv:AnthropogenicGreenhouseGasEmissions ;
                                skos:definition "F-Gas emissions are anthropogenic and mainly originating from chemical industrial processes and F- gas-related product use. The different F-gases have different, all very high global warming potentials." ;
                                skos:note "This corresponds to UNFCCC reporting of anthropogenic emissions of fluorinated gases (HFC, PFC and SF6) aggregated according to the GWP as agreed by the UNFCCC." .


###  http://www.semanticweb.org/crima/crima-ecv#AnthropogenicGreenhouseGasEmissions
ecv:AnthropogenicGreenhouseGasEmissions rdf:type owl:NamedIndividual ,
                                                 ecv:ecv-variable ;
                                        skos:broader ecv:HumanUseOfNaturalResources ;
                                        skos:definition "Anthropogenic long-cycle C emissions are mainly originating from combustion of fossil fuels, and for about 10% also from non-combustion sources, such as cement production, ferrous and non-ferrous metal production processes, urea production, agricultural liming and solvent use." .


###  http://www.semanticweb.org/crima/crima-ecv#AnthropogenicN2OEmissions
ecv:AnthropogenicN2OEmissions rdf:type owl:NamedIndividual ,
