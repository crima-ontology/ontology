###  http://www.semanticweb.org/crima/crima-ecv#CarbonInSoil
ecv:CarbonInSoil rdf:type owl:NamedIndividual ,
                          ecv:ecv-product ;
                 ecv:isProductOf ecv:SoilCarbon ;
                 skos:definition "% of organic carbon in the topmost 30 cm and sub-soil 30-100cm." ;
