[ rdf:type owl:Ontology
 ] .

#################################################################
#    Annotation properties
#################################################################

###  http://data.europa.eu/nuts/level
ns5:level rdf:type owl:AnnotationProperty .


###  http://data.europa.eu/nuts/mergedFrom
ns5:mergedFrom rdf:type owl:AnnotationProperty .


###  http://data.europa.eu/nuts/mergedInto
ns5:mergedInto rdf:type owl:AnnotationProperty .


###  http://data.europa.eu/nuts/splitFrom
ns5:splitFrom rdf:type owl:AnnotationProperty .


###  http://data.europa.eu/nuts/splitInto
ns5:splitInto rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/isReplacedBy
dcterms:isReplacedBy rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/issued
dcterms:issued rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/replaces
dcterms:replaces rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#broader
skos:broader rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#inScheme
skos:inScheme rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#isReplacedBy
skos:isReplacedBy rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#narrower
skos:narrower rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#notation
skos:notation rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#prefLabel
skos:prefLabel rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#replaces
skos:replaces rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/adms#status
adms:status rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Classes
#################################################################

###  http://www.w3.org/2004/02/skos/core#Concept
skos:Concept rdf:type owl:Class .


###  http://www.w3.org/2004/02/skos/core#ConceptScheme
skos:ConceptScheme rdf:type owl:Class .


