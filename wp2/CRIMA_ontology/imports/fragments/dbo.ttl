dbo:RouteOfTransportation a owl:Class ;
    rdfs:label "Transportweg"@de,
        "route of transportation"@en,
        "Vía de transporte"@es,
        "نقل و حمل کا راستہ"@ur ;
    rdfs:comment "Unter Transportwegen (Verkehrswegen) versteht man Verkehrswege, auf denen Güter oder Personen transportiert werden. Dabei unterscheidet man zwischen Transportwegen zu Luft, zu Wasser und zu Lande, die dann für die unterschiedliche Verkehrsarten genutzt werden (http://de.wikipedia.org/wiki/Transportweg)."@de,
        "A route of transportation (thoroughfare) may refer to a public road, highway, path or trail or a route on water from one place to another for use by a variety of general traffic (http://en.wikipedia.org/wiki/Thoroughfare)."@en,
        "نقل و حمل کا ایک راستہ (مکمل راستہ) ایک عام سڑک ، شاہراہ ، راستہ یا راستے پر پانی سے ایک جگہ سے دوسری جگہ پر جانے کا حوالہ دے سکتا ہے"@ur ;
    rdfs:subClassOf dbo:Infrastructure .

dbo:GovernmentalAdministrativeRegion a owl:Class ;
    rdfs:label "staatliche Verwaltungsregion"@de,
        "governmental administrative region"@en,
        "région administrative d'état"@fr,
        "gebied onder overheidsbestuur"@nl,
        "حکومتی انتظامی علاقہ"@ur ;
    rdfs:comment "An administrative body governing some territorial unity, in this case a governmental administrative body"@en,
        "ایک انتظامی ادارہ جو کچھ علاقائی وحدت کو کنٹرول کرتا ہے ، اس صورت میں ایک سرکاری انتظامی ادارہ ہے۔"@ur ;
    rdfs:subClassOf dbo:AdministrativeRegion .

dbo:Infrastructure a owl:Class ;
    rdfs:label "infrastruktur"@da,
        "Infrastruktur"@de,
        "Υποδομή"@el,
        "infrastructure"@en,
        "infrastructure"@fr,
        "インフラストラクチャー"@ja,
        "infrastructure"@nl,
        "بنیادی ڈھانچہ"@ur ;
    rdfs:subClassOf dbo:ArchitecturalStructure .

dbo:ArchitecturalStructure a owl:Class ;
    rdfs:label "Bauwerk"@de,
        "αρχιτεκτονική κατασκευή"@el,
        "architectural structure"@en,
        "estructura arquitectural"@es,
        "structure architecturale"@fr,
        "struchtúr ailtireachta"@ga,
        "struttura architettonica"@it,
        "構造物"@ja,
        "건축 구조"@ko,
        "bouwsel"@nl,
        "تعمیراتی ڈھانچے"@ur ;
    rdfs:comment "Ein Bauwerk ist eine von Menschen errichtete Konstruktion mit ruhendem Kontakt zum Untergrund. Es ist in der Regel für eine langfristige Nutzungsdauer konzipiert (http://de.wikipedia.org/wiki/Bauwerk)."@de,
        "Μια αρχιτεκτονική κατασκευή είναι μια ανθρώπινη κατασκευή, επιδαπέδια, ακίνητη κατασκευή (http://en.wikipedia.org/wiki/Architectural_structure)."@el,
        "An architectural structure is a human-made, free-standing, immobile outdoor construction (http://en.wikipedia.org/wiki/Architectural_structure)."@en,
        "Une structure architecturale est une construction extérieure immobile, autonome et construite par l'homme (http://en.wikipedia.org/wiki/Architectural_structure)."@fr,
        "یہ تعمیراتی ڈھانچے مواد سے بنے ہیں۔، آزادانہ ، غیر مستحکم بیرونی تعمیر۔"@ur .

dbo:Building a owl:Class ;
    rdfs:label "bygning"@da,
        "Gebäude"@de,
        "κτίριο"@el,
        "building"@en,
        "edificio"@es,
        "bâtiment"@fr,
        "foirgneamh"@ga,
        "edificio"@it,
        "建築物"@ja,
        "건축물"@ko,
        "gebouw"@nl,
        "stavba"@sl,
        "عمارت"@ur ;
    rdfs:comment "Ein Gebäude, umgangssprachlich auch oft als Haus bezeichnet, ist ein Bauwerk, das Räume umschließt, betreten werden kann und zum Schutz von Menschen, Tieren oder Sachen dient (http://de.wikipedia.org/wiki/Geb%C3%A4ude)."@de,
        "Building is defined as a Civil Engineering structure such as a house, worship center, factory etc. that has a foundation, wall, roof etc. that protect human being and their properties from direct harsh effect of weather like rain, wind, sun etc. (http://en.wikipedia.org/wiki/Building)."@en,
        "عمارت کو سول انجینئرنگ ڈھانچے سے تعبیر کیا جاتا ہے جیسے مکان ، عبادت گاہ ، فیکٹری وغیرہ جس کی بنیاد ، دیوار ، چھت وغیرہ ہوتی ہے جو انسان اور ان کی خصوصیات کو موسم کے براہ راست سخت اثرات جیسے بارش ، ہوا ، سورج وغیرہ سے محفوظ رکھتی ہے۔"@ur ;
    rdfs:subClassOf dbo:ArchitecturalStructure .

dbo:Place a owl:Class ;
    rdfs:label "ቦታ"@am,
        "مكان"@ar,
        "lloc"@ca,
        "sted"@da,
        "Ort"@de,
        "περιοχή"@el,
        "place"@en,
        "lugar"@es,
        "lekua"@eu,
        "lieu"@fr,
        "áit"@ga,
        "立地"@ja,
        "plaats"@nl,
        "miejsce"@pl,
        "lugar"@pt,
        "جگہ"@ur ;
    rdfs:comment "uma localização"@pt,
        "غیر متحرک چیزیں یا مقامات۔"@ur .

dbo:PopulatedPlace a owl:Class ;
    rdfs:label "تجمع سكاني"@ar,
        "befolket sted"@da,
        "bewohnter Ort"@de,
        "πυκνοκατοικημένη περιοχή"@el,
        "populated place"@en,
        "lieu habité"@fr,
        "bebouwde omgeving"@nl,
        "آبادی والی جگہ"@ur ;
    rdfs:comment "Πυκνοκατοικημένη περιοχή, είναι η περιοχή ή το μέρος με μεγάλο αριθμό κτιρίων και μεγάλο μόνιμο πληθυσμό, σε σύγκριση με την γεωγραφική περιοχή που καταλαμβάνει (μεγαλούπολη, πόλη ή χωριό)."@el,
        "As defined by the United States Geological Survey, a populated place is a place or area with clustered or scattered buildings and a permanent human population (city, settlement, town, or village) referenced with geographic coordinates (http://en.wikipedia.org/wiki/Populated_place)."@en,
        "Selon la définition du United States Geological Survey, un lieu peuplé est un lieu ou une zone avec des bâtiments regroupés ou dispersés et une population humaine permanente (agglomération, colonie, ville ou village) référencée par des coordonnées géographiques (http://en.wikipedia. org/wiki/Populated_place)."@fr,
        "جیسا کہ امریکہ نے بیان کیا ہے۔ ارضیاتی سروے ، ایک آبادی والی جگہ وہ جگہ یا علاقہ ہے جہاں گروہ یا بکھرے ہوئے عمارتیں اور مستقل انسانی آبادی (شہر ، بستی ، قصبہ یا گاؤں) ہو۔"@ur ;
    rdfs:subClassOf dbo:Place .

dbo:NaturalPlace a owl:Class ;
    rdfs:label "natürlicher Ort"@de,
        "φυσική θέση"@el,
        "natural place"@en,
        "lieu naturel"@fr,
        "natuurgebied"@nl,
        "lugar natural"@pt,
        "قدرتی جگہ"@ur ;
    rdfs:comment "Der natürlicher Ort beinhaltet alle Orte die natürlicherweise im Universum existieren."@de,
        "Η φυσική θέση ερμηνεύει όλα τα σημεία που απαντώνται φυσικά στο σύμπαν"@el,
        "The natural place encompasses all places occurring naturally in universe."@en,
        "قدرتی جگہ کائنات میں قدرتی طور پر پائے جانے والے تمام مقامات پر محیط ہے۔"@ur ;
    rdfs:subClassOf dbo:Place .

