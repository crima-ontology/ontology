@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

dbo: a owl:Ontology .

dbo:Agglomeration a owl:Class ;
    rdfs:label "Ballungsgebiet"@de,
        "συσσώρευση"@el,
        "agglomeration"@en,
        "agglomération"@fr,
        "aglomeración"@gl,
        "agglomeratie"@nl,
        "aglomeracja"@pl,
        "جمع"@ur ;
    rdfs:subClassOf dbo:PopulatedPlace .

dbo:Airport a owl:Class ;
    rdfs:label "lufthavn"@da,
        "Flughafen"@de,
        "αεροδρόμιο"@el,
        "airport"@en,
        "aeropuerto"@es,
        "aéroport"@fr,
        "aerfort"@ga,
        "aeroporto"@gl,
        "aeroporto"@it,
        "空港"@ja,
        "공항"@ko,
        "luchthaven"@nl,
        "lotnisko"@pl,
        "aeroporto"@pt,
        "аэропорт"@ru,
        "ہوائی اڈہ"@ur,
        "機場"@zh ;
    rdfs:subClassOf dbo:Infrastructure .

dbo:Archipelago a owl:Class ;
    rdfs:label "Archipel"@de,
        "αρχιπέλαγος"@el,
        "archipelago"@en,
        "archipiélago"@es,
        "archipel"@fr,
        "多島海"@ja,
        "archipel"@nl,
        "arquipélago"@pt,
        "جزیرہ نما"@ur ;
    rdfs:subClassOf dbo:NaturalPlace .

dbo:Arrondissement a owl:Class ;
    rdfs:label "arrondissement"@de,
        "arrondissement"@en,
        "arrondissement"@fr,
        "フランスの群"@ja,
        "arrondissement"@nl,
        "فرانس کا انتظامی ضلع"@ur ;
    rdfs:comment "Das Wort Arrondissement dient zur Bezeichnung verschiedener Verwaltungsbezirke in Frankreich, Belgien, Kanada und anderen Ländern"@de,
        "An administrative (France) or lawcourts (Netherlands) body governing a territorial unity on the intermediate level, between local and national level"@en,
        "ایک انتظامی (فرانس) یا قانون کی عدالتیں (نیدرلینڈز) جو کہ علاقائی وحدت پر مقامی اور قومی سطح کے درمیان حکمرانی کرتی ہیں"@ur ;
    rdfs:subClassOf dbo:GovernmentalAdministrativeRegion .

dbo:Atoll a owl:Class ;
    rdfs:label "Atoll"@de,
        "ατόλη"@el,
        "atoll"@en,
        "atoll"@fr,
        "atollo"@it,
        "環礁"@ja,
        "환초"@ko,
        "atol"@nl,
        "اڈل"@ur ;
    rdfs:comment "مرجانی چٹانوں سے بنا ہواجزیرہ"@ur ;
    rdfs:subClassOf dbo:Island .

dbo:Bay a owl:Class ;
    rdfs:label "Bucht"@de,
        "bay"@en,
        "baie"@fr,
        "湾"@ja,
        "baai"@nl,
        "baía"@pt,
        "خلیج"@ur ;
    rdfs:subClassOf dbo:BodyOfWater .

dbo:Beach a owl:Class ;
    rdfs:label "platja"@ca,
        "strand"@da,
        "Strand"@de,
        "beach"@en,
        "playa"@es,
        "plage"@fr,
        "砂浜"@ja,
        "strand"@nl,
        "praia"@pt,
        "ساحل_سمندر"@ur ;
    rdfs:comment "The shore of a body of water, especially when sandy or pebbly."@en,
        "Ribera del mar o de un río grande, formada de arenales en superficie casi plana."@es,
        "پانی کے جسم کا ساحل ، خاص طور پر جب ریت بھرا یا کنکری"@ur ;
    rdfs:subClassOf dbo:NaturalPlace .

dbo:Bridge a owl:Class ;
    rdfs:label "সেতু"@bn,
        "bro"@da,
        "Brücke"@de,
        "γέφυρα"@el,
        "bridge"@en,
        "pont"@fr,
        "droichead"@ga,
        "ponte"@it,
        "橋"@ja,
        "다리"@ko,
        "brug"@nl,
        "ponte"@pt,
        "most"@sl,
        "پل"@ur ;
    rdfs:comment "A bridge is a structure built to span physical obstacles such as a body of water, valley, or road, for the purpose of providing passage over the obstacle (http://en.wikipedia.org/wiki/Bridge)."@en,
        "ایک پل ایک ایسا ڈھانچہ ہے جو جسمانی رکاوٹوں جیسے پانی ، وادی یا سڑک کی راہ میں رکاوٹ کو عبور کرنے کے مقصد سے بنایا گیا ہے"@ur ;
    rdfs:subClassOf dbo:RouteOfTransportation .

dbo:Canal a owl:Class ;
    rdfs:label "Kanal"@de,
        "κανάλι"@el,
        "canal"@en,
        "canal"@fr,
        "canáil"@ga,
        "canale"@it,
        "運河"@ja,
        "운하"@ko,
        "kanaal"@nl,
        "canal"@pt,
        "نہر"@ur ;
    rdfs:comment "ένα κανάλι για νερό φτιαγμένο από άνθρωπο"@el,
        "a man-made channel for water"@en ;
    rdfs:subClassOf dbo:Stream .

dbo:Canton a owl:Class ;
    rdfs:label "Kanton"@de,
        "canton"@en,
        "canton"@fr,
        "スイス連邦の州またはフランスの群"@ja,
        "kanton"@nl,
        "ضِلَع"@ur ;
    rdfs:comment "Das Wort Kanton dient zur Bezeichnung verschiedener (niederen) Verwaltungsbezirke in Frankreich, Belgien, Kanada und anderen Ländern"@de,
        "An administrative (France) or lawcourts (Netherlands) body governing a territorial unity on the municipal level or somewhat above"@en,
        "ایک انتظامی (فرانس) یا قانون کی عدالت (نیدرلینڈز) کا ادارہ جو علاقائی وحدت کا انتظام کرتا ہے بلدیاتی سطح پر یا اس سے کچھ اوپر"@ur ;
    rdfs:subClassOf dbo:GovernmentalAdministrativeRegion .

dbo:Cape a owl:Class ;
    rdfs:label "cape"@en,
        "cap"@fr,
        "kaap"@nl,
        "خشکی کا وہ حصہ جو سمندر کے اندر تک چلا گیا ہو"@ur ;
    rdfs:subClassOf dbo:NaturalPlace .

dbo:Capital a owl:Class ;
    rdfs:label "Hauptstadt"@de,
        "Κεφάλαιο"@el,
        "Capital"@en,
        "Capitale"@fr,
        "Capitale"@it,
        "首都"@ja,
        "hoofdstad"@nl,
        "دارالحکومت"@ur ;
    rdfs:comment "A municipality enjoying primary status in a state, country, province, or other region as its seat of government."@en,
        "ایک بلدیہ جو کسی ریاست، ملک، صوبے، یا دوسرے علاقے میں اپنی حکومت کی نشست کے طور پر بنیادی حیثیت سے لطف اندوز ہوتی ہے۔"@ur ;
    rdfs:subClassOf dbo:City .

dbo:CapitalOfRegion a owl:Class ;
    rdfs:label "Hauptstadt der Region"@de,
        "Capital of region"@en,
        "Capitale régionale"@fr,
        "hoofdstad van regio"@nl,
        "علاقے کا دارالحکومت"@ur ;
    rdfs:comment "seat of a first order administration division."@en,
        "فرسٹ آرڈر ایڈمنسٹریشن ڈویژن کی نشست۔"@ur ;
    rdfs:subClassOf dbo:City .

dbo:Casino a owl:Class ;
    rdfs:label "Kasino"@de,
        "καζίνο"@el,
        "casino"@en,
        "casino"@es,
        "casino"@fr,
        "casinò"@it,
        "カジノ"@ja,
        "카지노"@ko,
        "casino"@nl,
        "رقص گاہ"@ur ;
    rdfs:comment "To καζίνο είναι ένας χώρος στον οποίο μπορούμε να παίξουμε τυχερά παιχνίδια ποντάροντας χρήματα."@el,
        "In modern English, a casino is a facility which houses and accommodates certain types of gambling activities."@en,
        "Un casino est un lieu proposant des jeux d'argent et de hasard ou jeux de casino."@fr,
        """جدید انگریزی میں ، جوئے بازی کی اڈہ ایک ایسی سہولت ہے جس میں جوئے کی سرگرمیوں کی مخصوص اقسام ہوتی ہیں۔
."""@ur ;
    rdfs:subClassOf dbo:Building .

dbo:Castle a owl:Class ;
    rdfs:label "burg"@de,
        "κάστρο"@el,
        "castle"@en,
        "château"@fr,
        "caisleán"@ga,
        "castello"@it,
        "城"@ja,
        "성 (건축)"@ko,
        "kasteel"@nl,
        "قلعہ"@ur ;
    rdfs:comment "Castles often are, but need not be a military structure. They can serve for status, pleasure and hunt as well."@en,
        "قلعے اکثر ہوتے ہیں، لیکن فوجی ڈھانچہ ہونے کی ضرورت نہیں ہے۔ وہ حیثیت، خوشی اور شکار کے لیے بھی خدمت کر سکتے ہیں۔"@ur ;
    rdfs:subClassOf dbo:Building .

dbo:Cave a owl:Class ;
    rdfs:label "Höhle"@de,
        "σπηλιά"@el,
        "cave"@en,
        "grotte"@fr,
        "pluais"@ga,
        "grotta"@it,
        "洞窟"@ja,
        "동굴"@ko,
        "grot"@nl,
        "caverna"@pt,
        "غار"@ur ;
    rdfs:subClassOf dbo:NaturalPlace .

dbo:Cemetery a owl:Class ;
    rdfs:label "Friedhof"@de,
        "νεκροταφείο"@el,
        "cemetery"@en,
        "cementerio"@es,
        "cimetière"@fr,
        "reilig"@ga,
        "墓地"@ja,
        "begraafplaats"@nl,
        "قبرستان"@ur ;
    rdfs:comment "Νεκροταφείο (ή Κοιμητήριο) ονομάζεται ο χώρος ο προορισμένος για την ταφή των νεκρών."@el,
        "A burial place"@en,
        "Un cimetière est un groupement de sépultures monumentales."@fr,
        "ایک تدفین کی جگہ"@ur ;
    rdfs:subClassOf dbo:Place .

dbo:Church a owl:Class ;
    rdfs:label "kirke"@da,
        "Kirche"@de,
        "εκκλησία"@el,
        "church"@en,
        "iglesia"@es,
        "église"@fr,
        "eaglais"@ga,
        "chiesa"@it,
        "教会"@ja,
        "교회"@ko,
        "kerk"@nl,
        "kościół"@pl,
        "igreja"@pt,
        "گرجا"@ur ;
    rdfs:comment "This is used for church buildings, not any other meaning of church."@en,
        "یہ چرچ کی عمارتوں کے لیے استعمال ہوتا ہے ، چرچ کا کوئی دوسرا مطلب نہیں۔"@ur ;
    rdfs:subClassOf dbo:ReligiousBuilding .

dbo:Cinema a owl:Class ;
    rdfs:label "Theater"@de,
        "κινηματογράφος"@el,
        "cinema (movie theater)"@en,
        "cinéma"@fr,
        "bioscoop"@nl,
        "سنیما"@ur ;
    rdfs:comment "A building for viewing films."@en,
        "فلم دیکھنے کے لیے ایک عمارت۔"@ur ;
    rdfs:subClassOf dbo:Venue .

dbo:CityDistrict a owl:Class ;
    rdfs:label "Stadtviertel"@de,
        "city district"@en,
        "quartier"@fr,
        "stadswijk"@nl,
        "شہر کا ضلع"@ur ;
    rdfs:comment "District, borough, area or neighbourhood in a city or town"@en,
        "کسی شہر یا قصبے میں ضلع کا علاقہ یا محلہ۔"@ur ;
    rdfs:subClassOf dbo:Settlement .

dbo:CoalPit a owl:Class ;
    rdfs:label "Kohlengrube"@de,
        "coal pit"@en,
        "puits de charbon"@fr,
        "steenkolenmijn"@nl,
        "کوئلہ"@ur ;
    rdfs:comment "A coal pit is a place where charcoal is or was extracted"@en,
        "Un puits de charbon est un endroit d'où le charbon était - ou est encore - extrait"@fr,
        "Een mijn is een plaats waar steenkool wordt of werd gewonnen"@nl,
        "کوئلے کا گڑھا ایک ایسی جگہ ہے جہاں چارکول ہے یا نکالا جاتا ہے۔"@ur ;
    rdfs:subClassOf dbo:Mine .

dbo:Community a owl:Class ;
    rdfs:label "Community"@en,
        "Communauté"@fr,
        "برادری"@ur ;
    rdfs:comment "Κοινότητα είναι μία ομάδα ζώντων οργανισμών, ανθρώπων, φυτών ή ζώων που ζουν σε ένα κοινό περιβάλλον."@el,
        "A community is a group of living organisms, people, plants or animals that live in a common environment."@en,
        "Une communauté est un groupe d'organismes vivants, de personnes, de plantes ou d'animaux qui vivent dans un environnement commun."@fr,
        "کمیونٹی جانداروں، لوگوں، پودوں یا جانوروں کا ایک گروپ ہے جو ایک مشترکہ ماحول میں رہتے ہیں۔"@ur ;
    rdfs:subClassOf dbo:PopulatedPlace .

dbo:ConcentrationCamp a owl:Class ;
    rdfs:label "Konzentrationslager"@de,
        "Concentration camp"@en,
        "camp de concentration"@fr,
        "concentratiekamp"@nl,
        "حراستی کیمپ"@ur ;
    rdfs:subClassOf dbo:Place .

dbo:Continent a owl:Class ;
    rdfs:label "Kontinent"@de,
        "ήπειρος"@el,
        "continent"@en,
        "continente"@es,
        "continent"@fr,
        "ilchríoch"@ga,
        "continente"@it,
        "大陸"@ja,
        "대륙"@ko,
        "continent"@nl,
        "براعظم"@ur ;
    rdfs:comment "Un continente es una gran área de tierra emergida de la costra terrestre."@es,
        "Un continente è una grande area di terra emersa della crosta terrestre, è anzi la più vasta delle ripartizioni con le quali si suddividono le terre emerse."@it,
        "براعظم زمین کا ایک بڑا علاقہ ہے جو زمین کی پرت سے نکلا ہے ، درحقیقت یہ ان سب سے بڑی تقسیم ہے جس کے ساتھ ابھرتی ہوئی زمینیں تقسیم کی گئی ہیں۔"@ur ;
    rdfs:subClassOf dbo:PopulatedPlace .

dbo:CountrySeat a owl:Class ;
    rdfs:label "Landgut"@de,
        "country estate"@en,
        "buitenplaats"@nl,
        "ملک کی نشست"@ur ;
    rdfs:comment "A country seat is a rural patch of land owned by a land owner."@en,
        "Een buitenplaats is een landgoed."@nl,
        "یک کنٹری سیٹ زمین کا ایک دیہی پیچ ہے جو زمین کے مالک کی ملکیت ہے"@ur ;
    rdfs:subClassOf dbo:Place .

dbo:CricketGround a owl:Class ;
    rdfs:label "Cricketfeld"@de,
        "cricket ground"@en,
        "campo da cricket"@it,
        "cricketveld"@nl,
        "کرکٹ کا میدان"@ur ;
    rdfs:subClassOf dbo:SportFacility .

dbo:Dam a owl:Class ;
    rdfs:label "Damm"@de,
        "φράγμα"@el,
        "dam"@en,
        "barrage"@fr,
        "damba"@ga,
        "diga"@it,
        "ダム"@ja,
        "dam"@nl,
        "ڈیم"@ur ;
    rdfs:comment "Ένα φράγμα είναι μια κατασκευή που εμποδίζει, ανακατευθύνει ή επιβραδύνει την φυσική ροή υδάτων."@el,
        "A dam is part of a landscape infrastructure, like waterworks (canals) or roads, much more than a building, though, of course, it has been built, too."@en,
        "ڈیم ایک ایسا ڈھانچہ ہے جو پانی کے قدرتی بہاؤ کو روکتا، ری ڈائریکٹ یا سست کر دیتا ہے۔"@ur ;
    rdfs:subClassOf dbo:Infrastructure .

dbo:Deanery a owl:Class ;
    rdfs:label "Dekanat"@de,
        "κοσμητεία"@el,
        "deanery"@en,
        "proosdij"@nl,
        "عمید کا عہدہ"@ur ;
    rdfs:comment "The intermediate level of a clerical administrative body between parish and diocese"@en,
        "گرجا گھر کا حلقہ اور  بشپ کے دائرہ اختیار کا حلقہ کے مابین علمی انتظامی ادارے کی انٹرمیڈیٹ سطح۔"@ur ;
    rdfs:subClassOf dbo:ClericalAdministrativeRegion .

dbo:Desert a owl:Class ;
    rdfs:label "Wüste"@de,
        "Έρημος"@el,
        "Desert"@en,
        "Desierto"@es,
        "Désert"@fr,
        "gaineamhlach"@ga,
        "砂漠"@ja,
        "woestijn"@nl,
        "deserto"@pt,
        "صحرا"@ur ;
    rdfs:comment "Barren land where there is less rain."@en,
        "زمین کا بنجر علاقہ جہاں کم بارش ہوتی ہے۔"@ur ;
    rdfs:subClassOf dbo:NaturalPlace .

dbo:Dike a owl:Class ;
    rdfs:label "dike"@en,
        "levée"@fr,
        "diga"@it,
        "堤防"@ja,
        "dijk"@nl,
        "بند"@ur ;
    rdfs:comment "A dike is an elongated naturally occurring ridge or artificially constructed fill or wall, which regulates water levels"@en,
        "بند ایک لمبی قدرتی طور پر واقع رکاوٹ یا مصنوعی طور پر تعمیر شدہ ذخیرہ یا دیوار ہے ، جو پانی کی سطح کو کنٹرول کرتی ہے۔"@ur ;
    rdfs:subClassOf dbo:Infrastructure .

dbo:Diocese a owl:Class ;
    rdfs:label "Diözese"@de,
        "επισκοπή"@el,
        "diocese"@en,
        "diocèse"@fr,
        "deoise"@ga,
        "教区"@ja,
        "교구"@ko,
        "bisdom"@nl,
        "بشپ کے تحت حلقہ"@ur ;
    rdfs:comment "District or see under the supervision of a bishop."@en,
        "ڈسٹرکٹ یا ایک بشپ کی نگرانی میں دیکھیں۔"@ur ;
    rdfs:subClassOf dbo:ClericalAdministrativeRegion .

dbo:DistrictWaterBoard a owl:Class ;
    rdfs:label "Bezirkwasserwirtschaftsamt"@de,
        "district water board"@en,
        "waterschap"@nl,
        "پانی کا ضلعی اقتدار"@ur ;
    rdfs:comment "Conservancy, governmental agency dedicated to surface water management"@en,
        "تحفظ ،سطحی پانی کے انتظام کے لیے وقف سرکاری ایجنسی"@ur ;
    rdfs:subClassOf dbo:GovernmentalAdministrativeRegion .

dbo:ElectricalSubstation a owl:Class ;
    rdfs:label "electrical substation"@en,
        "poste électrique"@fr,
        "transformatorhuisje"@nl,
        "برقی ذیلی مرکز"@ur ;
    rdfs:comment "Substations transform voltage from high to low, or the reverse."@en,
        "poste de transformation abaisseur ou élévateur de tension."@fr,
        "برقی ذیلی مرکز وولٹیج کو زیادہ سے کم، یا برعکس میں تبدیل کرتے ہیں۔"@ur ;
    rdfs:subClassOf dbo:Infrastructure .

dbo:Factory a owl:Class ;
    rdfs:label "Fabrik"@de,
        "εργοστάσιο"@el,
        "factory"@en,
        "usine"@fr,
        "monarcha"@ga,
        "fabbrica"@it,
        "工場"@ja,
        "공장"@ko,
        "fabriek"@nl,
        "کارخانه"@ur ;
    rdfs:comment "Το εργοστάσιο είναι ένα κτίριο μέσα στο οποίο, με τη βοήθεια των μηχανημάτων και τη σημαντικότατη συνεισφορά εργασίας από τους εργάτες, παράγονται σήμερα όλα σχεδόν τα βιομηχανικά είδη, είτε αυτά χρειάζονται πάλι για την παραγωγή (όπως μηχανές κλπ.) είτε είναι καταναλωτικά αγαθά."@el,
        "A factory (previously manufactory) or manufacturing plant is an industrial site, usually consisting of buildings and machinery, or more commonly a complex having several buildings, where workers manufacture goods or operate machines processing one product into another."@en,
        "Une usine est un bâtiment ou un ensemble de bâtiments destinés à la production industrielle."@fr,
        "ایک کارخانه (پہلے کارخانه) ایک صنعتی رقبہ ہے ، عام طور پر عمارتوں اور مشینری پر مشتمل ہوتی ہے ، یا زیادہ عام طور پر ایک  مرکب جس میں کئی عمارتیں ہوتی ہیں ، جہاں مزدور سامان تیار کرتے ہیں یا مشینیں چلاتے ہیں جو ایک مصنوعات کو دوسری پر پروسیسنگ کرتے ہیں۔"@ur ;
    rdfs:subClassOf dbo:Building .

dbo:Forest a owl:Class ;
