            owl:onProperty qudt:qkdvNumerator ;
        ] ,
        [
            a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty qudt:ucumCode ;
        ] ,
        [
            a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
