    qudt:informativeReference "https://en.wikipedia.org/wiki/Atto?oldid=412748080"^^xsd:anyURI ;
    qudt:prefixMultiplier 0.000000000000000001 ;
    qudt:prefixMultiplierSN 1e-18 ;
    qudt:siExactMatch si-prefix:atto ;
    qudt:symbol "a" ;
    qudt:ucumCode "a" ;
    rdfs:isDefinedBy <http://qudt.org/vocab/prefix> ;
.

