   owl:annotatedSource :NonPhysicalEndurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid236 ;
   rdfs:comment "Everything that is constantly constituted by a non physical endurant is a non physical endurant."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :NonPhysicalEndurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid238 ;
   rdfs:comment "Everything that is constant constituent of a non physical endurant is a non physical endurant."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :NonPhysicalEndurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid241 ;
