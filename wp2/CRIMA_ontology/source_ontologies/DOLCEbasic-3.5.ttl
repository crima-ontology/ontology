   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid260 ;
   rdfs:comment "Everything that is constantly constituted by a perdurant is a perdurant."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :Perdurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid262 ;
