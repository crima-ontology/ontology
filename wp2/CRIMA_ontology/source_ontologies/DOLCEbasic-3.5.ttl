           owl:disjointWith :Quality ;
           ace_lexicon:CN_pl "perdurants" ;
           ace_lexicon:CN_sg "perdurant" ;
           rdfs:comment "A Perdurant is an entity that happens in time (examples: a person’s life, a soccer game, the reading of a book, the state of feeling happy). Some perdurants are temporally atomic (example: the change of a letter’s state due to the breaking of the seal)." ;
           rdfs:label "Perdurant" .

_:genid255 rdf:type owl:Restriction ;
            owl:onProperty :temporallyLocatedAt ;
            owl:someValuesFrom :TimeInterval .

_:genid257 rdf:type owl:Restriction ;
