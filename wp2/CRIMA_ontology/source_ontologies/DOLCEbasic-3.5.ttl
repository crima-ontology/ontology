 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :Perdurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid266 ;
   rdfs:comment "Everything that is constant constituent of a perdurant is a perdurant."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :Perdurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid269 ;
   rdfs:comment "Ad49 for dQt" ,
                "Everything that is direct quality of a perdurant is a temporal quality."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :Perdurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid272 ;
   rdfs:comment "Everything that overlaps a perdurant is a perdurant." ,
                "from Dd15, Ad2"
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :Perdurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid275 ;
   rdfs:comment "Ad2 (half)" ,
                "Everything that is part of a perdurant is a perdurant."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :Perdurant ;
   owl:annotatedProperty owl:disjointWith ;
   owl:annotatedTarget :Quality ;
