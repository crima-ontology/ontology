            owl:onProperty :overlaps ;
            owl:allValuesFrom :Perdurant .

_:genid264 rdf:type owl:Restriction ;
            owl:onProperty :partOf ;
            owl:allValuesFrom :Perdurant .

_:genid266 rdf:type owl:Restriction ;
            owl:onProperty [ owl:inverseOf :constantConstituentOf
                           ] ;
            owl:allValuesFrom :Perdurant .

_:genid269 rdf:type owl:Restriction ;
            owl:onProperty [ owl:inverseOf :directQualityOf
                           ] ;
            owl:allValuesFrom :TemporalQuality .

_:genid272 rdf:type owl:Restriction ;
            owl:onProperty [ owl:inverseOf :overlaps
                           ] ;
            owl:allValuesFrom :Perdurant .

_:genid275 rdf:type owl:Restriction ;
            owl:onProperty [ owl:inverseOf :partOf
                           ] ;
            owl:allValuesFrom :Perdurant .

