 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :Perdurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid255 ;
   rdfs:comment "Every perdurant is temporally located at a time interval."
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :Perdurant ;
   owl:annotatedProperty rdfs:subClassOf ;
   owl:annotatedTarget _:genid257 ;
   rdfs:comment "Ad49 for dQt" ,
                "Every perdurant has a temporal location as direct quality."
 ] .

[ rdf:type owl:Axiom ;
