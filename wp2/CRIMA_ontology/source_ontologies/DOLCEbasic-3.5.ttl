###  https://w3id.org/DOLCE/OWL/DOLCEbasic#Particular
:Particular rdf:type owl:Class ;
            owl:disjointUnionOf _:genid252 ;
            ace_lexicon:CN_pl "particulars" ;
            ace_lexicon:CN_sg "particular" ;
            rdfs:comment "A Particular is an entity that cannot have instances, in this sense it is opposed to universals (examples: a person, a soccer game, a plan, the color red, a feeling, a fact, a theory, number forty-two)." ;
            rdfs:label "Particular" .

_:genid252 rdf:type rdf:List ;
            rdf:first :Abstract ;
            rdf:rest ( :Endurant
                       :Perdurant
                       :Quality
                     ) .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :Particular ;
   owl:annotatedProperty owl:disjointUnionOf ;
   owl:annotatedTarget _:genid252 ;
   rdfs:comment "A particular is either an abstract, an endurant, a perdurant, or a quality, and the classes Abstract, Endurant, Perdurant and Quality are all disjoint."
 ] .


###  https://w3id.org/DOLCE/OWL/DOLCEbasic#Perdurant
:Perdurant rdf:type owl:Class ;
           rdfs:subClassOf :Particular ,
                           _:genid255 ,
                           _:genid257 ,
                           _:genid260 ,
                           _:genid262 ,
                           _:genid264 ,
                           _:genid266 ,
                           _:genid269 ,
                           _:genid272 ,
