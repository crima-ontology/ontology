                     ace_lexicon:CN_sg "non physical endurant" ;
                     rdfs:comment "A Non-Physical Endurant is an endurant with no direct spatial quality (examples: democracy, the United Nations, the general secretary of Amnesty International)." ;
                     rdfs:label "Non-Physical Endurant" .

_:genid236 rdf:type owl:Restriction ;
            owl:onProperty :constantConstituentOf ;
            owl:allValuesFrom :NonPhysicalEndurant .

_:genid238 rdf:type owl:Restriction ;
            owl:onProperty [ owl:inverseOf :constantConstituentOf
                           ] ;
            owl:allValuesFrom :NonPhysicalEndurant .

_:genid241 rdf:type owl:Restriction ;
            owl:onProperty [ owl:inverseOf :constantPartOf
                           ] ;
            owl:allValuesFrom :NonPhysicalEndurant .

